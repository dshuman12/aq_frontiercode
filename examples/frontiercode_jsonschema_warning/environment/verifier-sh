#!/bin/sh

if [ "$#" -gt 0 ] && [ "$1" = "/tests/test.sh" ]; then
    /bin/sh "$@"
    status=$?
    mkdir -p /logs/verifier
    if [ "$status" -eq 0 ]; then
        printf '{"reward": 1}\n' > /logs/verifier/reward.json
    else
        printf '{"reward": 0}\n' > /logs/verifier/reward.json
    fi
    exit "$status"
fi

exec /bin/sh "$@"
