+// TombstoneKeys returns all keys that carry a tombstone (deleted entries).
+func (s *StateStore) TombstoneKeys() []string {
+	s.mu.RLock()
+	defer s.mu.RUnlock()
+	var keys []string
+	for k, e := range s.entries {
+		if e.Tombstone {
+			keys = append(keys, k)
+		}
+	}
+	sort.Strings(keys)
+	return keys
+}
