+// tombstoneSentinel is the tree value used to represent a tombstoned (deleted) key.
+// It must be distinct from any value a live entry could produce.
+var tombstoneSentinel = []byte("\x00tombstone")
+
 func storeToTree(store *gossip.StateStore) *merkle.Tree {
 	tree := merkle.NewTree()
 	entries := make(map[string][]byte)
 	for _, key := range store.Keys() {
 		v, ok := store.Get(key)
 		if ok {
-			entries[key] = v
+			// Prefix live values so they can't collide with tombstoneSentinel.
+			live := make([]byte, 1+len(v))
+			live[0] = 1
+			copy(live[1:], v)
+			entries[key] = live
 		}
 	}
+	for _, key := range store.TombstoneKeys() {
+		entries[key] = tombstoneSentinel
+	}
 	tree.PutBatch(entries)
 	return tree
 }
