+// --- Lamport clock tests ---
+
+func TestLamport_Tick(t *testing.T) {
+	lc := NewLamportClock("n1")
+	ts := lc.Tick("n1").(*LamportTimestamp)
+	if ts.Counter != 1 { t.Fatalf("expected 1, got %d", ts.Counter) }
+	ts2 := lc.Tick("n1").(*LamportTimestamp)
+	if ts2.Counter != 2 { t.Fatalf("expected 2, got %d", ts2.Counter) }
+}
+
+func TestLamport_Witness(t *testing.T) {
+	a := NewLamportClock("a")
+	b := NewLamportClock("b")
+	a.Tick("a"); a.Tick("a"); a.Tick("a")
+	tsA := a.Now()
+	tsB := b.Witness("b", tsA).(*LamportTimestamp)
+	if tsB.Counter != 4 { t.Fatalf("expected 4 (max(0,3)+1), got %d", tsB.Counter) }
+}
+
+func TestLamport_Compare(t *testing.T) {
+	a := &LamportTimestamp{Counter: 1, NodeID: "a"}
+	b := &LamportTimestamp{Counter: 2, NodeID: "b"}
+	if a.Compare(b) != Before { t.Fatal("a should be before b") }
+	if b.Compare(a) != After { t.Fatal("b should be after a") }
+}
+
+func TestLamport_Value(t *testing.T) {
+	lc := NewLamportClock("n")
+	lc.Tick("n"); lc.Tick("n")
+	if lc.Value() != 2 { t.Fatal("expected 2") }
+}
+
+func TestLamport_Bytes(t *testing.T) {
+	lt := &LamportTimestamp{Counter: 42, NodeID: "node"}
+	b := lt.Bytes()
+	if len(b) != 12 { t.Fatalf("expected 12 bytes, got %d", len(b)) }
+}
