 /**
- * Default Cognito user pool + "Repflow Creator Panel" app client when env vars are unset.
- * - `next dev` → Dev pool (us-east-2_s82ysRbW8)
- * - `next build` / `next start` / production → Prod pool (us-east-2_UOedUZggp)
+ * Cognito user pool + app client when `AWS_COGNITO_*` env vars are unset or blank.
  *
- * Override with AWS_COGNITO_USER_POOL_ID and AWS_COGNITO_CLIENT_ID in .env.local when needed.
+ * **Do not use `NODE_ENV` alone:** hosted dev (e.g. App Runner `repflow-frontend-dev`) runs with
+ * `NODE_ENV=production` but must use the **dev** pool to match `repflow-backend-dev` JWTs.
+ *
+ * Resolution order:
+ * 1. Infer from `NEXT_PUBLIC_API_BASE_URL` (same signal as `API_BASE_URL` / which API you call).
+ * 2. `NODE_ENV === 'development'` → local `next dev` → dev pool.
+ * 3. Fallback → prod pool (Vercel prod, etc.).
+ *
+ * Override pool/client anytime with `AWS_COGNITO_USER_POOL_ID` / `AWS_COGNITO_CLIENT_ID` in env / Secrets Manager.
+ *
+ * @see repflow/docs/DEPLOYMENT-ENVIRONMENTS.md — prod vs dev pools
  */
-export function defaultCognitoPoolAndClient(): { userPoolId: string; clientId: string } {
-    if (process.env.NODE_ENV === 'production') {
-        return {
-            userPoolId: 'us-east-2_UOedUZggp',
-            clientId: '1jcl067l8ampqksfh3103mv5s3',
-        }
+
+/** Dev stack — must match `repflow` dev branch / `repflow-backend-dev` */
+export const COGNITO_DEV = {
+    userPoolId: 'us-east-2_s82ysRbW8',
+    clientId: '7mfnjnh9b4i464qlmt42c24fjk',
+} as const
+
+/** Production — must match `repflow` main / production backend + creator auth */
+export const COGNITO_PROD = {
+    userPoolId: 'us-east-2_UOedUZggp',
+    clientId: '1jcl067l8ampqksfh3103mv5s3',
+} as const
+
+/** Backend App Runner default hosts (us-east-2) — Cognito issuer must match API `COGNITO_POOL_ID` */
+const DEV_API_HOST_SNIPPET = 'i2mk8mby5p'
+const PROD_API_HOST_SNIPPET = 'qppc8ivf44'
+
+function normalizedApiBase(): string {
+    return (process.env.NEXT_PUBLIC_API_BASE_URL || '')
+        .trim()
+        .toLowerCase()
+        .replace(/\/$/, '')
+}
+
+export function defaultCognitoPoolAndClient(): {
+    userPoolId: string
+    clientId: string
+} {
+    const api = normalizedApiBase()
+    if (api.includes(DEV_API_HOST_SNIPPET)) {
+        return { ...COGNITO_DEV }
+    }
+    if (api.includes(PROD_API_HOST_SNIPPET)) {
+        return { ...COGNITO_PROD }
     }
-    return {
-        userPoolId: 'us-east-2_s82ysRbW8',
-        clientId: '7mfnjnh9b4i464qlmt42c24fjk',
+    if (process.env.NODE_ENV === 'development') {
+        return { ...COGNITO_DEV }
     }
+    return { ...COGNITO_PROD }
 }
