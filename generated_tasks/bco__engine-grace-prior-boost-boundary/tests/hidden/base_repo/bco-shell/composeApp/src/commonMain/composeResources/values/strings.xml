    <string name="settings_section_switching">Switching</string>
    <string name="settings_switching_base_priority">Base priority</string>
    <string name="settings_switching_base_priority_summary">Give this device a head start in priority scoring. Higher values make it more likely to win the headset. This setting is per-device.</string>
    <string name="settings_switching_stickiness">Stickiness bonus</string>
    <string name="settings_switching_stickiness_summary">Bonus points for the device currently holding the headset, preventing unnecessary switches during brief priority ties.</string>
    <string name="settings_switching_bt_safety">BT auto-connect policy</string>
    <string name="settings_switching_bt_safety_summary">Controls when BCO automatically connects Bluetooth to the winning device. Shared across all devices.</string>
    <string name="settings_switching_bt_safety_conservative">Conservative</string>
    <string name="settings_switching_bt_safety_conservative_desc">Only auto-connect if a device in your network already holds the headset. Safest option — avoids stealing BT from non-BCO devices.</string>
    <string name="settings_switching_bt_safety_smart">Smart</string>
    <string name="settings_switching_bt_safety_smart_desc">Auto-connect when you are the only device. When peers are present, only auto-connect if one of them already has the headset.</string>
    <string name="settings_switching_bt_safety_aggressive">Aggressive</string>
    <string name="settings_switching_bt_safety_aggressive_desc">Always auto-connect when this device wins priority, regardless of whether any peer holds the headset.</string>
    <string name="settings_switching_cooldown">Switch cooldown</string>
    <string name="settings_switching_cooldown_summary">Minimum gap between back-to-back headset handoffs. Prevents rapid switching when priorities are close.</string>
    <string name="settings_switching_grace">Media pause grace</string>
    <string name="settings_switching_grace_summary">How long to keep priority after you pause or stop media, so a brief pause doesn\'t hand off the headset.</string>
    <string name="settings_switching_manual_timeout">Manual connect timeout</string>
    <string name="settings_switching_manual_timeout_summary">When you connect Bluetooth manually (outside BCO), that device gets top priority. This sets how long that boost lasts before normal scoring resumes.</string>
    <string name="settings_switching_scope_this_device">This device only</string>
    <string name="settings_switching_scope_synced">Synced across all devices</string>
