# OpenAI API Key (REQUIRED for embeddings)
# Get from: https://platform.openai.com/api-keys
# Used for: text-embedding-3-small model (minimal cost, ~$0.001 per 1000 docs)
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# OpenRouter API Key (REQUIRED for LLM)
# Get from: https://openrouter.ai/keys
# Used for: DeepSeek chat model (cheap, high-quality responses)
OPENROUTER_API_KEY=sk-or-your_openrouter_api_key_here

# RAG LLM Configuration
RAG_LLM_MODEL=deepseek/deepseek-chat
RAG_LLM_BASE_URL=https://openrouter.ai/api/v1

# Server Configuration
UVICORN_PORT=8000

# Optional: ChromaDB Storage Directory
# CHROMA_STORE_DIR=chroma_store
