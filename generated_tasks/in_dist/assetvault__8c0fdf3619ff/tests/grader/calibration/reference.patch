+  "email": "ahmed@example.com"
+}
+
+### ========================================
+### 9. TOKEN VERIFICATION
+### ========================================
+
+### Verify Valid Token
+# Replace TOKEN_HERE with actual token from signin response
+POST {{baseUrl}}/api/auth/verify
+Content-Type: {{contentType}}
+Authorization: Bearer eyJhbGciOiJIUzUxMiJ9.eyJzdWIiOiI1NTBlODQwMC1lMjliLTQxZDQtYTcxNi00NDY2NTU0NDAwMDAiLCJlbWFpbCI6ImFobWVkQGV4YW1wbGUuY29tIiwicm9sZSI6InBhdGllbnQiLCJpYXQiOjE3NzExNTA2OTcsImV4cCI6MjA4NjcyNjY5N30.TOKEN_SIGNATURE
+
+### Error: Invalid Token Format
+POST {{baseUrl}}/api/auth/verify
+Content-Type: {{contentType}}
+Authorization: Bearer invalid.token.format
+
+### Error: Missing Authorization Header
+POST {{baseUrl}}/api/auth/verify
+Content-Type: {{contentType}}
+
+### Error: Wrong Authorization Format (missing Bearer)
+POST {{baseUrl}}/api/auth/verify
+Content-Type: {{contentType}}
+Authorization: eyJhbGciOiJIUzUxMiJ9.TOKEN_WITHOUT_BEARER
+
+### ========================================
+### 10. SAMPLE TOKENS (for testing reference)
+### ========================================
