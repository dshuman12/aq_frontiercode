# Set default behavior to automatically normalize line endings
* text=auto

# Source code and config files use LF
*.sol text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.java text eol=lf
*.kt text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.sh text eol=lf

# Windows scripts use CRLF
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Ignore line ending warnings for node_modules
node_modules/** -text
