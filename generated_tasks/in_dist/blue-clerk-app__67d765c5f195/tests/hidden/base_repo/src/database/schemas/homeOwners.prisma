model HomeOwners {
    id             Int              @id @default(autoincrement())
    alternativeId  String           @default(cuid())
    profile        Json
    info           Json
    contact        Json
    address        Jobsite          @relation(fields: [addressId], references: [id])
    addressId      Int              @unique
    servicetickets Servicetickets[]
    jobs           Job[]
    jobSites       Jobsite[]     @relation("jobsiteHomeOwner")
}
