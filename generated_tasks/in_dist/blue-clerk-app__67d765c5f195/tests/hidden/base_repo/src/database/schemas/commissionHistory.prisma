model CommissionHistory {
    id                         Int       @id @default(autoincrement())
    alternativeId              String    @unique
    technicianIdORContractorId Int
    technician                 User?     @relation("commissionHistoryTechnician", fields: [technicianIdORContractorId], references: [id], map: "commissionHistory_technician_fkey")
    contractor                 Company?  @relation("commissionHistoryContractor", fields: [technicianIdORContractorId], references: [id], map: "commissionHistory_contractor_fkey")
    type                       String
    effectiveDate              DateTime?
    commission                 Float?
    addition                   Json?
    deduction                  Json?
    commissionType             String?
    editedUserId               Int?
    editedBy                   User?     @relation("commissionHistoryEditedBy", fields: [editedUserId], references: [id])
    jobId                      Int
    job                        Job       @relation(fields: [jobId], references: [id])
    createdAt                  DateTime  @default(now())
    updatedAt                  DateTime  @updatedAt

    @@index([effectiveDate])
}
