model Jobsite {
    id            Int         @id @default(autoincrement())
    alternativeId String      @default(cuid())
    name          String?
    location      Json?
    isActive      Boolean?    @default(true)
    address       Json?
    jobLocation   Joblocation @relation(fields: [locationId], references: [id])
    locationId    Int
    customer      Customer?   @relation(fields: [customerId], references: [id])
    customerId    Int?
    homeOwnerId   Int?
    homeOwner     HomeOwners? @relation("jobsiteHomeOwner", fields: [homeOwnerId], references: [id])
    tickets     Servicetickets[] @relation("jobsite")
    homeTickets Servicetickets[] @relation("homejobsite")

    invoice Invoice[]

    jobRequest Jobrequest[]
    homeJobs   Job[]
    jobs       Job[]        @relation("jobJobsite")
    tags       Tag[]

    @@index([isActive])
    @@index([id, isActive])
    @@index([address])
}
