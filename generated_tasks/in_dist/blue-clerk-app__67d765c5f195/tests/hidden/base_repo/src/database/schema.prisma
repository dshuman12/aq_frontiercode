generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model EmailDefault {
  id            Int      @id @default(autoincrement())
  alternativeId String?  @unique
  subject       String?
  message       String
  companyId     Int
  company       Company  @relation(fields: [companyId], references: [id])
  updatedBy     Int?
  user          User?    @relation(fields: [updatedBy], references: [id])
  emailType     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId, emailType])
}

model EmailSchedule {
  id            Int     @id @default(autoincrement())
  alternativeId String? @unique
  userId        Int
  user          User    @relation(fields: [userId], references: [id])
  type          Int     @default(0)
  jobs          Job[]
  pulled        Boolean @default(false)

  @@index([pulled])
}

model HomeOwners {
  id             Int              @id @default(autoincrement())
  alternativeId  String           @default(cuid())
  profile        Json
  info           Json
  contact        Json
  address        Jobsite          @relation(fields: [addressId], references: [id])
  addressId      Int              @unique
  servicetickets Servicetickets[]
  jobs           Job[]
  jobSites       Jobsite[]        @relation("jobsiteHomeOwner")
}

model Industry {
  id            Int     @id @default(autoincrement())
  alternativeId String? @unique
  title         String
  createdBy     Int
  user          User    @relation(fields: [createdBy], references: [id])

  companyInfos CompanyInfo[]
  jobTypes     JobType[]

  @@index([title])
}

model ItemTier {
  id          Int       @id @default(autoincrement())
  tierId      Int
  tier        PriceTier @relation(fields: [tierId], references: [id])
  charge      Int
  updatedById Int
  updatedBy   User      @relation(fields: [updatedById], references: [id])
  updatedAt   DateTime  @updatedAt

  itemId Int
  item   Items @relation(fields: [itemId], references: [id])
}

model ItemCosting {
  id          Int        @id @default(autoincrement())
  tierId      Int
  tier        JobCosting @relation(fields: [tierId], references: [id])
  charge      Int
  updatedById Int
  updatedBy   User       @relation(fields: [updatedById], references: [id])
  updatedAt   DateTime   @updatedAt

  itemId Int
  item   Items @relation(fields: [itemId], references: [id])
}

model Items {
  id             Int           @id @default(autoincrement())
  name           String
  description    String
  sku            String
  isFixed        Boolean       @default(true)
  charges        Int           @default(0)
  tax            Int           @default(0)
  tiers          ItemTier[]
  costing        ItemCosting[]
  isDiscountItem Boolean       @default(false)
  isJobType      Boolean       @default(true)
  jobTypeId      Int
  jobType        JobType       @relation(fields: [jobTypeId], references: [id])
  itemType       Item          @default(Service)
  productCost    Int
  salePrice      Int
  companyId      Int
  company        Company       @relation(fields: [companyId], references: [id])
  isActive       Boolean       @default(true)
  quickbookId    String
  createdAt      Boolean       @default(true)
  updatedAt      Boolean       @default(true)

  servicetickets Servicetickets[]
}

enum Item {
  Service
  Product
}

model JobTaskJobType {
