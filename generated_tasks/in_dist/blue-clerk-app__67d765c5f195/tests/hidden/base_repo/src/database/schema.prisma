model Advancepayment {
  id                     Int                     @id @default(autoincrement())
  alternativeId          String                  @default(cuid())
  companyId              Int
  company                Company                 @relation(fields: [companyId], references: [id])
  amount                 Int                     @default(0)
  balance                Int                     @default(0)
  paymentType            String?
  referenceNumber        String?
  paidAt                 DateTime?
  appliedAt              DateTime?
  note                   String?
  isVoid                 Boolean?                @default(false)
  voidedAt               DateTime?
  createdByUser          User                    @relation("advancePaymentUserCreatedBy", fields: [createdById], references: [id])
  createdById            Int
  updatedByUser          User                    @relation("advancePaymentUserUpdatedBy", fields: [updatedById], references: [id])
  updatedById            Int
  voidedByUser           User                    @relation("advancePaymentUserVoidedBy", fields: [voidedById], references: [id])
  voidedById             Int
  workType               Worktype[]
  companyLocation        CompanyLocation[]
  advancePaymentVendor   Advancepaymentvendor?
  advancePaymentEmployee Advancepaymentemployee?

  @@index([companyId])
  @@index([paidAt])
  @@index([isVoid, paidAt])
}

model Advancepaymentvendor {
  id               Int            @id @default(autoincrement())
  alternativeId    String         @default(cuid())
  contractorId     Int
  contractor       Company        @relation(fields: [contractorId], references: [id])
  advancePaymentId Int            @unique
  advancePayment   Advancepayment @relation(fields: [advancePaymentId], references: [id])

  @@index([contractorId])
  @@index([advancePaymentId])
}

model Advancepaymentemployee {
  id               Int            @id @default(autoincrement())
  alternativeId    String         @default(cuid())
  employeeId       Int
  employee         User           @relation(fields: [employeeId], references: [id])
  advancePaymentId Int            @unique
  advancePayment   Advancepayment @relation(fields: [advancePaymentId], references: [id])

  @@index([employeeId])
  @@index([advancePaymentId])
}
model Assignedvendor {
  id            Int     @id @default(autoincrement())
  alternativeId String  @default(cuid())
  vendor        Company @relation(fields: [vendorId], references: [id])
  vendorId      Int
  workTypes     Json

  companyLocations CompanyLocation[]
}

enum ChatChannels {
  serviceTicket
  jobRequest
  job
}

model Chat {
  id            Int          @id @default(autoincrement())
  alternativeId String       @default(cuid())
  chatChannel   ChatChannels
  user          User?        @relation(fields: [userId], references: [id])
  userId        Int
  company       Company?     @relation(fields: [companyId], references: [id])
  companyId     Int
  customer      Customer     @relation(fields: [customerId], references: [id])
  customerId    Int
  replyTo       Int
  reply         Chat         @relation("Replies", fields: [replyTo], references: [id])
  replies       Chat[]       @relation("Replies")
  message       String
  images        Json
  readStatus    Json
}

model Companyadmin {
  id            Int       @id @default(autoincrement())
  alternativeId String    @default(cuid())
  company       Company?  @relation(fields: [companyId], references: [id])
  companyId     Int       @unique
  userId        Int       @unique
  user          User      @relation(fields: [userId], references: [id])
  companies     Company[] @relation("admin")
}

model Supplieradmin {
  id            Int      @id @default(autoincrement())
  alternativeId String   @default(cuid())
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  supplierId    Int
}

model Companycustomer {
  id            Int      @id @default(autoincrement())
  alternativeId String   @default(cuid())
  company       Company? @relation(fields: [companyId], references: [id])
  companyId     Int
  customer      Customer @relation(fields: [customerId], references: [id])
  customerId    Int
  status        Int      @default(1)
  isPreferred   Boolean  @default(false)
  createdAt     DateTime
}

model Companyinvoice {
  id                     Int       @id @default(autoincrement())
  alternativeId          String    @default(cuid())
  technicians            Int?      @default(0)
  managers               Int?      @default(0)
  officeAdmins           Int?      @default(0)
  admins                 Int?      @default(0)
  contractors            Int?      @default(0)
  charges                Int       @default(0)
  tax                    Int       @default(0)
  total                  Int       @default(0)
  isDraft                Boolean   @default(false)
  stripeId               String?
  stripeHostedInvoiceUrl String?
  stripeInvoicePdf       String?
  paid                   Boolean   @default(false)
  paidAt                 DateTime?
  note                   String?
  company                Company   @relation(fields: [companyId], references: [id])
  companyId              Int
  emailHistory           Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model Companyprefix {
  id            Int     @id @default(autoincrement())
  alternativeId String  @default(cuid())
  prefix        String
  maxJobId      Int
  company       Company @relation(fields: [companyId], references: [id])
  companyId     Int
}

model Contract {
  id               Int      @id @default(autoincrement())
  companyId        Int
  company          Company  @relation("contractCompany", fields: [companyId], references: [id])
  contractorId     Int
  contractor       Company  @relation("contractContractor", fields: [contractorId], references: [id])
  contractorEmail  String
  status           Int      @default(0)
  createdById      Int
  createdBy        User     @relation("contractCreatedBy", fields: [createdById], references: [id])
  finishedById     Int
  finishedBy       User     @relation("contractFinishedBy", fields: [finishedById], references: [id])
  finishedAt       DateTime
  extraPermissions Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum InvoiceStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

model Invoice {
  id                  Int                @id @default(autoincrement())
  alternativeId       String             @default(cuid())
  invoiceId           String
  invoiceType         Int                @default(0)
  job                 Job?               @relation(fields: [jobId], references: [id])
  jobId               Int?
  purchaseOrderId     Int?
  // TODO: PURCHASEORDER RELATIONSHIP
  estimateId          Int?
  // TODO: ESTIMATE RELATIONSHIP
  jobPurchaseOrdersId Int?
  // TODO: JOBPURCHASEORDER RELATIONSHIP
  issuedDate          DateTime
  dueDate             DateTime
  isDraft             Boolean            @default(false)
  paymentTerm         Paymentterm        @relation(fields: [paymentTermId], references: [id])
  paymentTermId       Int
  note                String?
  customerPO          String
  customerContact     Contact            @relation(fields: [customerContactId], references: [id])
  customerContactId   Int
  vendorId            String
  customer            Customer           @relation(fields: [customerId], references: [id])
  customerId          Int
  jobLocation         Joblocation        @relation(fields: [jobLocationId], references: [id])
  jobLocationId       Int
  jobSite             Jobsite            @relation(fields: [jobSiteId], references: [id])
  jobSiteId           Int
  company             Company            @relation(fields: [companyId], references: [id])
  companyId           Int
  charges             Int                @default(0)
  taxAmount           Int                @default(0)
  subTotal            Int                @default(0)
  total               Int                @default(0)
  shippingCost        Int                @default(0)
  tax                 Int
  taxPercentage       Int
  createdBy           User               @relation(fields: [createdById], references: [id])
  createdById         Int
  timeSpent           Int                @default(0)
  items               Json?
  paymentApplied      Int                @default(0)
  balanceDue          Int
  paid                Boolean            @default(false)
  serviceType         InvoiceStatus      @default(UNPAID)
  emailHistory        Json
  bouncedEmailFlag    Boolean            @default(false)
  lastEmailSent       DateTime
  quickbookId         String
  invoicecommission   Invoicecommission?
  isVoid              Boolean            @default(false)
  workType            Worktype           @relation(fields: [workTypeId], references: [id])
  workTypeId          Int
  companyLocation     CompanyLocation    @relation(fields: [companyLocationId], references: [id])
  companyLocationId   Int
  technicianMessages  Json
  showJobId           Boolean            @default(true)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  paymentcustomer     Paymentcustomer[]
  paymentvendors      Paymentvendor[]
  JobReport           JobReport[]

  @@index([customerPO])
  @@index([vendorId])
  @@index([customerContactId])
  @@index([isDraft])
  @@index([issuedDate, isDraft])
  @@index([isVoid])
  @@index([quickbookId, isDraft, isVoid])
  @@index([createdAt, id, isDraft, isVoid])
  @@index([issuedDate, note, vendorId, invoiceId])
  @@index([createdAt, isDraft, isVoid, invoiceId, customerPO, vendorId])
}

model Invoicecommission {
  id            Int      @id @default(autoincrement())
  alternativeId String   @default(cuid())
  invoice       Invoice  @relation(fields: [invoiceId], references: [id])
  invoiceId     Int      @unique
  technicians   Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Invoiceprefix {
  id            Int     @id @default(autoincrement())
  alternativeId String  @default(cuid())
  prefix        String
  maxInvoiceId  Int
  company       Company @relation(fields: [companyId], references: [id])
  companyId     Int
}

model Joblocation {
  id            Int       @id @default(autoincrement())
  alternativeId String    @default(cuid())
  name          String
  contacts      Json
  location      Json?
  address       Json?
  jobSites      Json?
  isActive      Boolean?
  customer      Customer  @relation(fields: [customerId], references: [id])
  customerId    Int
  company       Company   @relation(fields: [companyId], references: [id])
  companyId     Int
  inactiveAt    DateTime?
  inactiveBy    User?     @relation(fields: [inactiveById], references: [id])
  inactiveById  Int?
  quickbookId   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tickets     Servicetickets[] @relation("jobLocation")
  homeTickets Servicetickets[] @relation("homeJobLocation")

  invoice Invoice[]

  jobRequest Jobrequest[]

  jobSite          Jobsite[]
  homeJobs         Job[]
  jobs             Job[]              @relation("jobJobLocation")
  tags             Tag[]
  customerContract CustomerContract[]

  @@index([contacts])
  @@index([isActive])
  @@index([address])
  @@index([id, isActive])
  @@index([quickbookId])
  @@index([name, address, location])
}

model Jobrequest {
  id                Int             @id @default(autoincrement())
  alternativeId     String          @default(cuid())
  requestId         String
  status            Int             @default(0)
  dueDate           DateTime?
  jobLocation       Joblocation     @relation(fields: [jobLocationId], references: [id])
  jobLocationId     Int
  jobSite           Jobsite         @relation(fields: [jobSiteId], references: [id])
  jobSiteId         Int
  requests          Json
  customer          Customer?       @relation(fields: [customerId], references: [id])
  customerId        Int?
  customerContact   User?           @relation(fields: [customerContactId], references: [id])
  customerContactId Int?
  company           Company         @relation(fields: [companyId], references: [id])
  companyId         Int
  jobCreated        Boolean         @default(false)
  job               Job             @relation(fields: [jobId], references: [id])
  jobId             Int
  track             Json
  createdByUser     User            @relation("jobRequestUserCreatedBy", fields: [createdById], references: [id])
  createdById       Int
  editedByUser      User            @relation("jobRequestUsereditedBy", fields: [editedById], references: [id])
  editedById        Int
  editedAt          DateTime        @updatedAt
  workType          Worktype        @relation(fields: [workTypeId], references: [id])
  workTypeId        Int
  companyLocation   CompanyLocation @relation(fields: [companyLocationId], references: [id])
  companyLocationId Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  jobs Job[] @relation("jobrequest")

  @@index([status])
}

model Jobsite {
  id            Int              @id @default(autoincrement())
  alternativeId String           @default(cuid())
  name          String?
  location      Json?
  isActive      Boolean?         @default(true)
  address       Json?
  jobLocation   Joblocation      @relation(fields: [locationId], references: [id])
  locationId    Int
  customer      Customer?        @relation(fields: [customerId], references: [id])
  customerId    Int?
  homeOwnerId   Int?
  homeOwner     HomeOwners?      @relation("jobsiteHomeOwner", fields: [homeOwnerId], references: [id])
  tickets       Servicetickets[] @relation("jobsite")
  homeTickets   Servicetickets[] @relation("homejobsite")

  invoice Invoice[]

  jobRequest Jobrequest[]
  homeJobs   Job[]
  jobs       Job[]        @relation("jobJobsite")
  tags       Tag[]
  HomeOwners HomeOwners?

  @@index([isActive])
  @@index([id, isActive])
  @@index([address])
}

model Paymentterm {
  id               Int                @id @default(autoincrement())
  alternativeId    String             @default(cuid())
  name             String
  dueDays          Int
  isActive         Boolean            @default(true)
  company          Company            @relation(fields: [companyId], references: [id])
  companyId        Int
  quickbookId      String
  createdBy        User               @relation(fields: [createdById], references: [id])
  createdById      Int
  deleteAt         DateTime
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  invoice          Invoice[]
  companies        Company[]          @relation("companyPaymentTerm")
  customer         Customer[]
  customerContract CustomerContract[]
}

model Payment {
  id              Int      @id @default(autoincrement())
  alternativeId   String   @default(cuid())
  amountPaid      Int      @default(0)
  referenceNumber String
  paymentType     String
  line            Json
  paidAt          DateTime
  isVoid          Boolean  @default(false)
  voidedAt        DateTime
  note            String
  company         Company  @relation(fields: [companyId], references: [id])
  companyId       Int
  quickbookId     String
  quickbookRefNum String
  createdBy       User     @relation("paymentUserCreatedBy", fields: [createdById], references: [id])
  createdById     Int
  createdAt       DateTime
  updatedBy       User     @relation("paymentUserupdatedBy", fields: [updatedById], references: [id])
  updatedById     Int
  workType        Json
  companyLocation Json
  updatedAt       DateTime

  @@index([quickbookId])
  @@index([quickbookId, isVoid])
  @@index([paidAt, isVoid])
  @@index([quickbookId, referenceNumber, paymentType, isVoid])
  @@index([quickbookId, referenceNumber, paymentType, isVoid, line])
}

model Paymentcustomer {
  id               Int               @id @default(autoincrement())
  alternativeId    String            @default(cuid())
  customerId       Int
  // TODO: CUSTOMER RELATIONSHIP
  invoice          Invoice?          @relation(fields: [invoiceId], references: [id])
  invoiceId        Int?
  worktypes        Worktype[]
  companyLocations CompanyLocation[]
}

model Paymentvendor {
  id            Int       @id @default(autoincrement())
  alternativeId String    @default(cuid())
  contractor    Company   @relation(fields: [contractorId], references: [id])
  contractorId  Int
  invoices      Invoice[]
  jobs          Job[]
  startDate     DateTime
  endDate       DateTime
  offset        Int
  creditUsed    Int       @default(0)
}

model Paymentemployee {
  id            Int      @id @default(autoincrement())
  alternativeId String   @default(cuid())
  employee      User     @relation(fields: [employeeId], references: [id])
  employeeId    Int
  invoices      Json
  startDate     DateTime
  endDate       DateTime
  offset        Int
  creditUsed    Int      @default(0)

  @@index([invoices])
}

enum serviceType {
  Ticket
  PORequest
  AllPORequest
}

model ServiceTicketTasks {
  id        String         @id @default(cuid())
  ticket    Servicetickets @relation(fields: [ticketId], references: [id])
  ticketId  Int
  jobType   JobType?       @relation(fields: [jobTypeId], references: [id])
  jobTypeId Int?
  quantity  Int            @default(1)
  price     Int
}

model Servicetickets {
  id                Int                  @id @default(autoincrement())
  alternativeId     String               @unique
  createdAt         DateTime
  dueDate           DateTime?
  customer          Customer?            @relation(fields: [customerId], references: [id])
  customerId        Int?
  createdByUser     User                 @relation("serviceTicketUserCreatedBy", fields: [createdById], references: [id])
  createdById       Int
  note              String
  customerContact   Contact?             @relation(fields: [customerContactId], references: [id])
  customerContactId Int?
  customerPO        String
  image             String
  images            Json?
  company           Company              @relation(fields: [companyId], references: [id])
  companyId         Int
  technicianUser    User                 @relation("serviceTicketUsertechnician", fields: [technicianId], references: [id])
  technicianId      Int
  status            Int                  @default(0)
  track             Json
  editedByUser      User                 @relation("serviceTicketUsereditedBy", fields: [editedById], references: [id])
  editedById        Int
  editedAt          DateTime
  ticketId          String
  jobLocation       Joblocation          @relation("jobLocation", fields: [jobLocationId], references: [id])
  jobLocationId     Int
  jobSite           Jobsite              @relation("jobsite", fields: [jobSiteId], references: [id])
  jobSiteId         Int
  isHomeOccupied    Boolean              @default(false)
  homeOwner         HomeOwners           @relation(fields: [homeOwnerId], references: [id])
  homeOwnerId       Int
  homeJobLocation   Joblocation          @relation("homeJobLocation", fields: [homeJobLocationId], references: [id])
  bouncedEmailFlag  Boolean              @default(false)
  homeJobLocationId Int
  homeJobSite       Jobsite              @relation("homejobsite", fields: [homeJobSiteId], references: [id])
  homeJobSiteId     Int
  jobType           JobType              @relation(fields: [jobTypeId], references: [id])
  jobTypeId         Int
  tasks             ServiceTicketTasks[]
  item              Items                @relation(fields: [itemId], references: [id])
  itemId            Int
  jobCreated        Boolean              @default(false)
  source            String               @default("blueclerk")
  workType          Worktype             @relation(fields: [workTypeId], references: [id])
  workTypeId        Int
  companyLocation   CompanyLocation      @relation(fields: [companyLocationId], references: [id])
  companyLocationId Int
  pooverriddenById  Int
  //TODO: pooverriddenBy RELATIONSHIP
  type              serviceType          @default(Ticket)
  emailHistory      Json
  lastEmailSent     DateTime

  jobs Job[]

  @@index([itemId])
  @@index([jobCreated, status])
  @@index([jobCreated, status, type])
  @@index([id])
}

model Worktype {
  id                Int                @id @default(autoincrement())
  alternativeId     String             @default(cuid())
  title             String
  // TODO: TRIM @map("title") @before(validateAndTrim)
  createdAt         DateTime
  advancePayments   Advancepayment[]
  servicetickets    Servicetickets[]
  jobrequest        Jobrequest[]
  invoice           Invoice[]
  companyLocations  CompanyLocation[]
  jobs              Job[]
  assignedEmployees AssignedEmployee[]
  paymentcustomers  Paymentcustomer[]
}
model AssignedEmployee {
  id               Int               @id @default(autoincrement())
  alternativeId    String?           @unique
  employeeId       Int
  // TODO: implement employee
  workTypes        Worktype[]
  companyLocations CompanyLocation[]
}

model BouncedEmail {
  id            Int      @id @default(autoincrement())
  alternativeId String?  @unique
  email         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([email])
}

model CommissionHistory {
  id                         Int       @id @default(autoincrement())
  alternativeId              String    @unique
  technicianIdORContractorId Int
  technician                 User?     @relation("commissionHistoryTechnician", fields: [technicianIdORContractorId], references: [id], map: "commissionHistory_technician_fkey")
  contractor                 Company?  @relation("commissionHistoryContractor", fields: [technicianIdORContractorId], references: [id], map: "commissionHistory_contractor_fkey")
  type                       String
  effectiveDate              DateTime?
  commission                 Float?
  addition                   Json?
  deduction                  Json?
  commissionType             String?
  editedUserId               Int?
  editedBy                   User?     @relation("commissionHistoryEditedBy", fields: [editedUserId], references: [id])
  jobId                      Int
  job                        Job       @relation(fields: [jobId], references: [id])
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  @@index([effectiveDate])
}

model CompanyInfo {
  id           Int       @id @default(autoincrement())
  companyName  String?
  industryId   Int?      @unique
  industry     Industry? @relation(fields: [industryId], references: [id])
  logoUrl      String?
  companyEmail String?
  displayName  String?
  company      Company?

  @@index([companyEmail])
}

model CompanyBlockchain {
  id           Int       @id @default(autoincrement())
  verified     Boolean   @default(false)
  verifiedAt   DateTime?
  verifiedById Int?
  verifiedBy   User?     @relation("CompanyBlockchainVerifiedBy", fields: [verifiedById], references: [id])
  deniedAt     DateTime?
  deniedById   Int?
  deniedBy     User?     @relation("CompanyBlockchainDeniedBy", fields: [deniedById], references: [id])
  company      Company?
}

model Company {
  id                  Int                @id @default(autoincrement())
  alternativeId       String?            @unique
  info                CompanyInfo?       @relation(fields: [companyInfoId], references: [id])
  companyInfoId       Int?               @unique
  address             Json?
  contact             Json?
  other               Json?
  employees           Employee[]
  customers           Customer[]
  employee            User?              @relation(fields: [employeeId], references: [id])
  employeeId          Int?
  stripeId            String?
  paid                Boolean            @default(false)
  type                Int                @default(0)
  plan                Int                @default(0)
  chargeDate          DateTime
  trialEndDate        DateTime?
  maxTechnicians      Int                @default(0)
  maxManagers         Int                @default(0)
  maxOfficeAdmins     Int                @default(0)
  maxAdmins           Int                @default(0)
  userPermissions     Json
  currentJobId        Int                @default(0)
  prefix              String?
  adminId             Int?
  admin               Companyadmin?      @relation("admin", fields: [adminId], references: [id])
  qbAccessToken       String?
  qbRefreshToken      String?
  realmId             String?
  qbCompanyName       String?
  qbCompanyEmail      String?
  customersSynced     Boolean?
  customersSyncedAt   DateTime?
  qbSync              Json?
  socketId            String?
  qbAuthorized        Boolean            @default(false)
  qbRefeshTokenExpiry DateTime?
  currentInvoiceId    Int                @default(0)
  emailPreferences    Json?
  invoicePrefix       String?
  currentPOId         Int                @default(0)
  currentEstimateId   Int                @default(0)
  itemTier            Json?
  costing             Json?
  paymentTermId       Int?
  paymentTerm         Paymentterm?       @relation("companyPaymentTerm", fields: [paymentTermId], references: [id])
  balance             Int                @default(0)
  credit              Int                @default(0)
  commission          Int?
  commissionType      String             @default("%")
  // TODO: commissionTier: {type: Schema.Types.ObjectId, ref: 'JobCosting'},
  // TODO: companyInvoices: [{ type: Schema.Types.ObjectId, ref: 'CompanyInvoice' }],
  blockchain          CompanyBlockchain? @relation(fields: [companyBlockchainId], references: [id])
  companyBlockchainId Int?               @unique
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  contractorJobs                Job[]                  @relation("jobContractor")
  companyJobs                   Job[]                  @relation("jobCompany")
  jobTasks                      JobTask[]
  companyCards                  CompanyCard[]
  contractorCommissionHistories CommissionHistory[]    @relation("commissionHistoryContractor")
  advancePayment                Advancepayment[]
  advancePaymentVendor          Advancepaymentvendor[]
  assignedvendor                Assignedvendor[]
  chat                          Chat[]
  companyadmin                  Companyadmin[]
  companycustomer               Companycustomer[]
  servicetickets                Servicetickets[]
  joblocation                   Joblocation[]
  jobrequest                    Jobrequest[]
  invoice                       Invoice[]
  paymentterm                   Paymentterm[]
  emaildefaults                 EmailDefault[]
  companyLocations              CompanyLocation[]
  jobCharges                    JobCharges[]
  saletaxes                     SaleTax[]
  invoiceprefix                 Invoiceprefix[]
  payment                       Payment[]
  paymentvendor                 Paymentvendor[]
  companyinvoice                Companyinvoice[]
  companyprefix                 Companyprefix[]
  companyContracts              Contract[]             @relation("contractCompany")
  contractorContracts           Contract[]             @relation("contractContractor")
  tags                          Tag[]
  customerContract              CustomerContract[]
  jobReportsCompany             JobReport[]            @relation("jobReportCompany")
  jobReportsContractor          JobReport[]            @relation("jobReportContractor")
  Items                         Items[]
  JobCosting                    JobCosting[]
  Notification                  Notification[]
  PriceTier                     PriceTier[]

  @@index([plan, chargeDate])
}

model CompanyCard {
  id              Int      @id @default(autoincrement())
  alternativeId   String?  @unique
  ending          String?
  expirationMonth String?
  expirationYear  String?
  cardType        String?
  name            String?
  token           String?
  cardStripeId    String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  companyId       Int      @unique
  company         Company  @relation(fields: [companyId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CompanyLocation {
  id                        Int                @id @default(autoincrement())
  alternativeId             String?            @unique
  name                      String?
  isActive                  Boolean            @default(true)
  isMainLocation            Boolean            @default(true)
  contactName               String
  info                      Json
  address                   Json
  isAddressAsBillingAddress Boolean            @default(false)
  billingAddress            Json
  contact                   Json
  companyId                 Int
  company                   Company            @relation(fields: [companyId], references: [id])
