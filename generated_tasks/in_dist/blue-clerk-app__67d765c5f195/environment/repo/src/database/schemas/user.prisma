model UserAuth {
    id                   Int       @id @default(autoincrement())
    email                String    @unique
    password             String
    resetPasswordToken   String?
    resetPasswordExpires DateTime?
    socialId             String?
    connectorType        Int?      @default(0)
    User                 User?

    @@index([email])
    @@index([socialId, connectorType])
}

model Employee {
    id                    Int     @id @default(autoincrement())
    companyId             Int
    company               Company @relation(fields: [companyId], references: [id])
    status                Int     @default(1)
    extraPermissions      Json
    agreed                Boolean @default(false)
    canAccessAllLocations Boolean @default(false)
    userId                Int?    @unique
    user                  User?   @relation(fields: [userId], references: [id])
}

model User {
    id                            Int                      @id @default(autoincrement())
    alternativeId                 String?                  @unique
    accountType                   Int?
    auth                          UserAuth?                @relation(fields: [userAuthId], references: [id])
    userAuthId                    Int?                     @unique
    profile                       Json?
    address                       Json?
    location                      Json?
    contact                       Json?
    permissions                   Json?
    emailPreferences              Json?
    // TODO: Contats need to be implemented
    balance                       Int                      @default(0)
    credit                        Int                      @default(0)
    commission                    Int?
    firebaseTokens                Json
    createdAt                     DateTime                 @default(now())
    updatedAt                     DateTime                 @updatedAt
    employee                      Employee?
    companyAdmin                  Companyadmin?
    
    companyBlockchainsVerified    CompanyBlockchain[]      @relation("CompanyBlockchainVerifiedBy")
    companyBlockchainsdenied      CompanyBlockchain[]      @relation("CompanyBlockchainDeniedBy")
    industriesCreated             Industry[]
    jobCostingsInactivated        JobCosting[]
    priceTiersInactivated         PriceTier[]
    jobTypesCreated               JobType[]
    jobstimeUpdated               Job[]                    @relation("jobTimeUpdatedBy")
    jobsCreated                   Job[]                    @relation("jobCreatedBy")
    jobTracks                     JobTrack[]
    jobs                          Job[]
    jobTechnicianImages           JobTechnicianImage[]
    jobImages                     JobImage[]
    jobTasks                      JobTask[]
    jobTasksJobTypesTimeUpdated   JobTaskJobType[]
    technicianCommissionHistories CommissionHistory[]      @relation("commissionHistoryTechnician")
    editedCommissionHistories     CommissionHistory[]      @relation("commissionHistoryEditedBy")
    createdAdvancePayment         Advancepayment[]         @relation("advancePaymentUserCreatedBy")
    updatedAdvancePayment         Advancepayment[]         @relation("advancePaymentUserUpdatedBy")
    voidedAdvancePayment          Advancepayment[]         @relation("advancePaymentUserVoidedBy")
    advancePaymentEmployee        Advancepaymentemployee[]
    chat                          Chat[]
    createdServiceTicket          Servicetickets[]         @relation("serviceTicketUserCreatedBy")
    technicianServiceTicket       Servicetickets[]         @relation("serviceTicketUsertechnician")
    editedServiceTicket           Servicetickets[]         @relation("serviceTicketUsereditedBy")
    joblocation                   Joblocation[]
    createdJobRequest             Jobrequest[]             @relation("jobRequestUserCreatedBy")
    editedJobRequest              Jobrequest[]             @relation("jobRequestUsereditedBy")
    invoice                       Invoice[]
    paymentterm                   Paymentterm[]
    emaildefaultsUpdated          EmailDefault[]
    jobChargesCreated             JobCharges[]
    saleTaxesCreated              SaleTax[]
    emailSchedules                EmailSchedule[]
    updatedItemTiers              ItemTier[]
    updatedItemCostings           ItemCosting[]
    dismissedNotifications        Notification[]           @relation("notificationDismissedBy")
    readedNotifications           Notification[]           @relation("notificationReadBy")
    createdPayment                Payment[]                @relation("paymentUserCreatedBy")
    updatedPayment                Payment[]                @relation("paymentUserupdatedBy")
    paymentemployee               Paymentemployee[]
    inactiveByCustomer            Customer[]               @relation("customerUserinactiveBy")
    adminCustomer                 Customer[]               @relation("customerUserAdmin")
    contactUser                   Contact[]
    jobrequest                    Jobrequest[]
    Notification                  Notification[]
    contractsCreated              Contract[]               @relation("contractCreatedBy")
    contractsFinished             Contract[]               @relation("contractFinishedBy")
    tagsCreated                   Tag[]
    company                       Company[]
}
