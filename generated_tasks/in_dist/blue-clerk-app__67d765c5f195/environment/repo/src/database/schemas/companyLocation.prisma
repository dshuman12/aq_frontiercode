model CompanyLocation {
  id                        Int                @id @default(autoincrement())
  alternativeId             String?            @unique
  name                      String?
  isActive                  Boolean            @default(true)
  isMainLocation            Boolean            @default(true)
  contactName               String
  info                      Json
  address                   Json
  isAddressAsBillingAddress Boolean            @default(false)
  billingAddress            Json
  contact                   Json
  companyId                 Int
  company                   Company            @relation(fields: [companyId], references: [id])
  workTypes                 Worktype[]
  assignedVendors           Assignedvendor[]
  assignedEmployees         AssignedEmployee[]
  poRequestEmailSender      String
  jobs                      Job[]
  servicetickets            Servicetickets[]
  jobrequest                Jobrequest[]
  invoice                   Invoice[]
  advancepayments           Advancepayment[]
  paymentcustomers          Paymentcustomer[]

  @@index([companyId, isActive, isMainLocation])
  @@index([companyId, isActive, isMainLocation, id])
}