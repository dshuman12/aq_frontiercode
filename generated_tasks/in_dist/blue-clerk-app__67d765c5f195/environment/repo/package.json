{
  "name": "blueclerk-server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "tsc": "tsc",
    "watch:tsc": "tsc --watch",
    "dev": "concurrently \"tsc --watch\" \"nodemon ./dist/server.js\"",
    "schema": "cd ./src/database/schemas && cat *.prisma > ../schema.prisma && npx prisma format && npx prisma generate && npx prisma migrate deploy",
    "schema:dev": "cd ./src/database/schemas && cat *.prisma > ../schema.prisma && npx prisma format && npx prisma migrate dev --name init",
    "tsoa": "tsoa spec-and-routes",
    "dev:tsoa": "concurrently \"tsc --watch\" \"onchange ./dist/**/*.controller.js -- tsoa spec-and-routes\" \"nodemon ./dist/server.js\"",
    "test": "nyc mocha -r ts-node/register --recursive \"src/**/*.test.ts\"",
    "test:coverage": "npx jest src/tests --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "prisma": {
    "schema": "./src/database/schema.prisma"
  },
