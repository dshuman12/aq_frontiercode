+def _to_ws_base_url(raw_base_url: str) -> str:
+    base_url = (raw_base_url or "").strip()
+    if not base_url:
+        return ""
+    parsed = urlparse(base_url)
+    if not parsed.scheme or not parsed.netloc:
+        return ""
+    scheme = parsed.scheme.lower()
+    if scheme == "http":
+        ws_scheme = "ws"
+    elif scheme == "https":
+        ws_scheme = "wss"
+    elif scheme in {"ws", "wss"}:
+        ws_scheme = scheme
+    else:
+        return ""
+    path = parsed.path.rstrip("/")
+    return urlunparse((ws_scheme, parsed.netloc, path, "", "", "")).rstrip("/")
+
+
+def _default_local_assignment(lobby: Lobby) -> dict[str, str] | None:
+    cfg = get_app_config()
+    if not cfg.MAIN_APP_INCLUDE_GAME_WS:
+        return None
+    game_ws_base_url = _to_ws_base_url(cfg.GAME_WS_PUBLIC_BASE_URL or cfg.BACKEND_PUBLIC_BASE_URL)
+    chat_ws_base_url = _to_ws_base_url(cfg.CHAT_WS_PUBLIC_BASE_URL or cfg.BACKEND_PUBLIC_BASE_URL)
+    if not game_ws_base_url or not chat_ws_base_url:
+        return None
+    return _materialize_assignment(
+        lobby,
+        {
+            "game_server_id": (cfg.DEFAULT_GAME_SERVER_ID or "").strip() or "local-main-app",
+            "region": (cfg.DEFAULT_GAME_SERVER_REGION or "").strip() or (lobby.server_region or ""),
+            "game_ws_base_url": game_ws_base_url,
+            "chat_ws_base_url": chat_ws_base_url,
+        },
+    )
+
