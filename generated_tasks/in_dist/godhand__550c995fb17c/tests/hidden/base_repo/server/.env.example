FASTAPI_ENV=development

# Required security keys
SECRET_KEY=replace-with-32-byte-secret
JWT_SECRET_KEY=replace-with-32-byte-secret

# MongoDB Atlas connection
MONGO_USER=your-mongo-username
MONGO_PASSWORD=your-mongo-password
MONGO_HOST=your-cluster.mongodb.net
MONGO_PARAMS=retryWrites=true&w=majority&appName=project-godhand
MONGO_DB=godhand

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
BACKEND_PUBLIC_BASE_URL=http://localhost:5050
GAME_WS_PUBLIC_BASE_URL=http://localhost:5051
CHAT_WS_PUBLIC_BASE_URL=http://localhost:5050
FRONTEND_PUBLIC_BASE_URL=http://localhost:5173
MAIN_APP_INCLUDE_GAME_WS=false
DEFAULT_GAME_SERVER_ID=game-server-usw2a
DEFAULT_GAME_SERVER_REGION=us-west-2
GAME_SERVER_REGISTRY_JSON=
GAME_SERVER_INTERNAL_TOKEN=replace-with-internal-game-server-token
GAME_SERVER_CREDENTIALS_JSON=
GAME_SERVER_SIGNATURE_MAX_SKEW_SECONDS=60
GAME_SERVER_HEARTBEAT_TTL_SECONDS=20
GAME_SERVER_HEARTBEAT_INTERVAL_SECONDS=5
DEV_ADMIN_TOKEN=replace-with-dev-admin-token
CONTROL_PLANE_INTERNAL_BASE_URL=http://localhost:5050
GAME_SERVER_SELF_ID=
GAME_SERVER_SELF_REGION=
GAME_SERVER_SELF_OFFICIAL_KEYS=
GAME_SERVER_SELF_SIGNING_SECRET=
GAME_SERVER_SECRET_NA_WEST_1=
GAME_SERVER_SECRET_NA_WEST_2=
GAME_SERVER_SECRET_NA_WEST_3=
GOOGLE_OAUTH_REDIRECT_PATH=/api/v1/auth/google/callback
FRONTEND_OAUTH_SUCCESS_PATH=/lobby
FRONTEND_OAUTH_FAILURE_PATH=/?auth_error=oauth
FRONTEND_OAUTH_LINK_SUCCESS_PATH=/profile?google_linked=1
FRONTEND_OAUTH_LINK_FAILURE_PATH=/profile?google_link_error=1

# Optional auth cookie tuning
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=Lax

# Optional auth endpoint rate limits
AUTH_RATE_LIMIT_LOGIN_MAX=10
AUTH_RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REGISTER_MAX=5
AUTH_RATE_LIMIT_REGISTER_WINDOW_SECONDS=300

# Legacy email-verification options (kept for future re-enable; inactive by default)
AUTH_REQUIRE_EMAIL_VERIFICATION=false
EMAIL_VERIFY_TOKEN_TTL_HOURS=24
POSTMARK_SERVER_TOKEN=your-postmark-server-token
POSTMARK_FROM_EMAIL=noreply@yourdomain.com
POSTMARK_VERIFY_TEMPLATE_ID=12345678
FRONTEND_VERIFY_SUCCESS_PATH=/verify/success
FRONTEND_VERIFY_FAILURE_PATH=/verify/failure
