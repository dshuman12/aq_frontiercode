+@dataclass
+class RateLimitConfig:
+    """Configuration for rate limiting."""
+    max_attempts: int = 5
+    window_seconds: float = 300.0
+    lockout_seconds: float = 600.0
+
+
+class AuthRateLimiter:
+    """Per-backend rate limiting for authentication attempts."""
+
+    def __init__(self, config: RateLimitConfig | None = None) -> None:
+        self._config = config or RateLimitConfig()
+        self._attempts: dict[str, list[float]] = {}
+        self._lockouts: dict[str, float] = {}
+
+    def check_rate_limit(self, key: str) -> bool:
+        """Return True if the request is allowed, False if rate-limited."""
+        now = time.time()
+        lockout_until = self._lockouts.get(key)
+        if lockout_until and now < lockout_until:
+            return False
+        if lockout_until and now >= lockout_until:
+            del self._lockouts[key]
+        return True
+
+    def record_attempt(self, key: str, success: bool) -> None:
+        now = time.time()
+        if key not in self._attempts:
+            self._attempts[key] = []
+        self._attempts[key].append(now)
+        cutoff = now - self._config.window_seconds
+        self._attempts[key] = [t for t in self._attempts[key] if t > cutoff]
+        if not success and len(self._attempts[key]) >= self._config.max_attempts:
+            self._lockouts[key] = now + self._config.lockout_seconds
+
+    def is_locked_out(self, key: str) -> bool:
+        lockout_until = self._lockouts.get(key)
+        if lockout_until is None:
+            return False
+        if time.time() >= lockout_until:
+            del self._lockouts[key]
+            return False
+        return True
+
+    def remaining_lockout(self, key: str) -> float:
+        lockout_until = self._lockouts.get(key)
+        if lockout_until is None:
+            return 0.0
+        remaining = lockout_until - time.time()
+        return max(0.0, remaining)
+
+    def clear(self, key: str | None = None) -> None:
+        if key:
+            self._attempts.pop(key, None)
+            self._lockouts.pop(key, None)
+        else:
+            self._attempts.clear()
+            self._lockouts.clear()
+
+    @property
+    def locked_out_count(self) -> int:
+        now = time.time()
+        return sum(1 for v in self._lockouts.values() if v > now)
+
