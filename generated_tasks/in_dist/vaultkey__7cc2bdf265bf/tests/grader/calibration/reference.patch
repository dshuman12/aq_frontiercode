+@dataclass
+class AuthSession:
+    """An authenticated session."""
+    session_id: str
+    entity_id: str
+    auth_backend: str
+    created_at: float = field(default_factory=time.time)
+    expires_at: float = 0.0
+    last_activity: float = field(default_factory=time.time)
+    metadata: dict[str, str] = field(default_factory=dict)
+    revoked: bool = False
+
+    def __post_init__(self) -> None:
+        if self.expires_at == 0.0:
+            self.expires_at = self.created_at + 3600.0
+
+    @property
+    def is_expired(self) -> bool:
+        return time.time() >= self.expires_at
+
+    @property
+    def is_valid(self) -> bool:
+        return not self.revoked and not self.is_expired
+
+    def touch(self) -> None:
+        self.last_activity = time.time()
+
+
+class AuthSessionManager:
+    """Manages authenticated sessions."""
+
+    def __init__(self, session_ttl: float = 3600.0, max_sessions: int = 10000) -> None:
+        self._sessions: dict[str, AuthSession] = {}
+        self._entity_sessions: dict[str, list[str]] = {}
+        self._session_ttl = session_ttl
+        self._max_sessions = max_sessions
+
+    def create_session(self, entity_id: str, auth_backend: str, metadata: dict[str, str] | None = None) -> AuthSession:
+        session = AuthSession(
+            session_id=generate_id("sess"),
+            entity_id=entity_id,
+            auth_backend=auth_backend,
+            expires_at=time.time() + self._session_ttl,
+            metadata=dict(metadata or {}),
+        )
+        if len(self._sessions) >= self._max_sessions:
+            self._evict_oldest()
+        self._sessions[session.session_id] = session
+        if entity_id not in self._entity_sessions:
+            self._entity_sessions[entity_id] = []
+        self._entity_sessions[entity_id].append(session.session_id)
+        return session
+
+    def get_session(self, session_id: str) -> AuthSession | None:
+        session = self._sessions.get(session_id)
+        if session and session.is_valid:
+            session.touch()
+            return session
+        return None
+
+    def revoke_session(self, session_id: str) -> bool:
+        session = self._sessions.get(session_id)
+        if session is None:
+            return False
+        session.revoked = True
+        return True
+
+    def revoke_entity_sessions(self, entity_id: str) -> int:
+        session_ids = self._entity_sessions.get(entity_id, [])
+        count = 0
+        for sid in session_ids:
+            session = self._sessions.get(sid)
+            if session and not session.revoked:
+                session.revoked = True
+                count += 1
+        return count
+
+    def list_entity_sessions(self, entity_id: str) -> list[AuthSession]:
+        session_ids = self._entity_sessions.get(entity_id, [])
+        return [self._sessions[sid] for sid in session_ids if sid in self._sessions and self._sessions[sid].is_valid]
+
+    def tidy(self) -> int:
+        to_remove = [sid for sid, s in self._sessions.items() if not s.is_valid]
+        for sid in to_remove:
+            session = self._sessions.pop(sid)
+            ids = self._entity_sessions.get(session.entity_id, [])
+            if sid in ids:
+                ids.remove(sid)
+        return len(to_remove)
+
+    def _evict_oldest(self) -> None:
+        if not self._sessions:
+            return
+        oldest_id = min(self._sessions, key=lambda k: self._sessions[k].created_at)
+        session = self._sessions.pop(oldest_id)
+        ids = self._entity_sessions.get(session.entity_id, [])
+        if oldest_id in ids:
+            ids.remove(oldest_id)
+
+    @property
+    def active_count(self) -> int:
+        return sum(1 for s in self._sessions.values() if s.is_valid)
+
+
+@dataclass
+class MFAChallenge:
+    """A multi-factor authentication challenge."""
+    challenge_id: str
+    method: str
+    entity_id: str
+    created_at: float = field(default_factory=time.time)
+    expires_at: float = 0.0
+    verified: bool = False
+    code: str = ""
+
+    def __post_init__(self) -> None:
+        if self.expires_at == 0.0:
+            self.expires_at = self.created_at + 300.0
+
+    @property
+    def is_expired(self) -> bool:
+        return time.time() >= self.expires_at
+
+
+class MultiFactorAuthChain:
+    """Chains multiple authentication factors."""
+
+    def __init__(self) -> None:
+        self._pending_challenges: dict[str, list[MFAChallenge]] = {}
+        self._required_methods: list[str] = ["totp"]
+
+    def set_required_methods(self, methods: list[str]) -> None:
+        self._required_methods = list(methods)
+
+    def create_challenge(self, entity_id: str, method: str) -> MFAChallenge:
+        import secrets
+        challenge = MFAChallenge(
+            challenge_id=generate_id("mfa"),
+            method=method,
+            entity_id=entity_id,
+            code=str(secrets.randbelow(1000000)).zfill(6),
+        )
+        if entity_id not in self._pending_challenges:
+            self._pending_challenges[entity_id] = []
+        self._pending_challenges[entity_id].append(challenge)
+        return challenge
+
+    def verify_challenge(self, entity_id: str, challenge_id: str, code: str) -> bool:
+        challenges = self._pending_challenges.get(entity_id, [])
+        for ch in challenges:
+            if ch.challenge_id == challenge_id:
+                if ch.is_expired:
+                    return False
+                if ch.code == code:
+                    ch.verified = True
+                    return True
+                return False
+        return False
+
+    def is_fully_authenticated(self, entity_id: str) -> bool:
+        challenges = self._pending_challenges.get(entity_id, [])
+        verified_methods = {ch.method for ch in challenges if ch.verified and not ch.is_expired}
+        return all(m in verified_methods for m in self._required_methods)
+
+    def clear_challenges(self, entity_id: str) -> None:
+        self._pending_challenges.pop(entity_id, None)
+
+    @property
+    def required_methods(self) -> list[str]:
+        return list(self._required_methods)
+
+
+@dataclass
+class AuthEventEntry:
+    """An authentication event for logging."""
+    event_id: str
+    backend: str
+    entity_id: str
+    success: bool
+    timestamp: float = field(default_factory=time.time)
+    source_address: str = ""
+    error: str = ""
+
+
+class AuthEventLogger:
+    """Logs authentication events."""
+
+    def __init__(self, max_entries: int = 10000) -> None:
+        self._entries: list[AuthEventEntry] = []
+        self._max_entries = max_entries
+
+    def log(self, backend: str, entity_id: str, success: bool, source_address: str = "", error: str = "") -> AuthEventEntry:
+        entry = AuthEventEntry(
+            event_id=generate_id("aevt"),
+            backend=backend,
+            entity_id=entity_id,
+            success=success,
+            source_address=source_address,
+            error=error,
+        )
+        if len(self._entries) >= self._max_entries:
+            self._entries.pop(0)
+        self._entries.append(entry)
+        return entry
+
+    def get_entries(self, backend: str | None = None, entity_id: str | None = None, since: float = 0) -> list[AuthEventEntry]:
+        results = self._entries
+        if backend:
+            results = [e for e in results if e.backend == backend]
+        if entity_id:
+            results = [e for e in results if e.entity_id == entity_id]
+        if since:
+            results = [e for e in results if e.timestamp >= since]
+        return results
+
+    def failure_count(self, entity_id: str | None = None, since: float = 0) -> int:
+        entries = self.get_entries(entity_id=entity_id, since=since)
+        return sum(1 for e in entries if not e.success)
+
+    @property
+    def total_entries(self) -> int:
+        return len(self._entries)
+
