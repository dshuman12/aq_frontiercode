+@dataclass
+class Certificate:
+    name: str
+    fingerprint: str
+    policies: list[str] = field(default_factory=list)
+    allowed_dns_sans: list[str] = field(default_factory=list)
+    ttl: float = 3600.0
+    created_at: float = field(default_factory=time.time)
