+"""Authentication backends."""
+from __future__ import annotations
+
+import hashlib
+import hmac
+import os
+import time
+from abc import ABC, abstractmethod
+from dataclasses import dataclass, field
+from typing import Any
+
+from vaultkey.crypto.hashing import hash_digest, HashAlgorithm
+from vaultkey.crypto.random import generate_id, generate_token, secure_random_bytes
+from vaultkey.utils.errors import AuthenticationError, VaultError
+
+
+@dataclass(frozen=True)
+class AuthResult:
+    """Result of a successful authentication."""
+    entity_id: str
+    policies: list[str]
+    metadata: dict[str, str]
+    ttl: float = 3600.0
+    renewable: bool = True
+    auth_backend: str = ""
+
+    def to_dict(self) -> dict[str, Any]:
+        return {
+            "entity_id": self.entity_id,
+            "policies": list(self.policies),
+            "metadata": dict(self.metadata),
+            "ttl": self.ttl,
+            "auth_backend": self.auth_backend,
+        }
+
+
+class AuthBackend(ABC):
+    """Base class for authentication backends."""
+
+    def __init__(self, name: str) -> None:
+        self._name = name
+        self._enabled = True
+        self._config: dict[str, Any] = {}
+
+    @property
+    def name(self) -> str:
+        return self._name
+
+    @property
+    def enabled(self) -> bool:
+        return self._enabled
+
+    def enable(self) -> None:
+        self._enabled = True
+
+    def disable(self) -> None:
+        self._enabled = False
+
+    def configure(self, config: dict[str, Any]) -> None:
+        self._config.update(config)
+
+    @abstractmethod
+    def authenticate(self, credentials: dict[str, Any]) -> AuthResult:
+        ...
+
+    @abstractmethod
+    def backend_type(self) -> str:
+        ...
+
+
+@dataclass
+class UserEntry:
+    username: str
+    password_hash: bytes
+    salt: bytes
+    policies: list[str] = field(default_factory=list)
+    metadata: dict[str, str] = field(default_factory=dict)
+    disabled: bool = False
+    created_at: float = field(default_factory=time.time)
+    last_login: float | None = None
+    login_count: int = 0
+
+
+class UserpassBackend(AuthBackend):
+    """Username/password authentication backend."""
+
+    def __init__(self, name: str = "userpass") -> None:
+        super().__init__(name)
+        self._users: dict[str, UserEntry] = {}
+        self._iterations = 100000
+
+    def backend_type(self) -> str:
+        return "userpass"
+
+    def create_user(self, username: str, password: str, policies: list[str] | None = None) -> None:
+        if username in self._users:
+            raise AuthenticationError(f"user already exists: {username}")
+        salt = secure_random_bytes(32)
+        pw_hash = self._hash_password(password, salt)
+        self._users[username] = UserEntry(
+            username=username,
+            password_hash=pw_hash,
+            salt=salt,
+            policies=list(policies or []),
+        )
+
+    def update_password(self, username: str, password: str) -> None:
+        user = self._users.get(username)
+        if user is None:
+            raise AuthenticationError(f"user not found: {username}")
+        user.salt = secure_random_bytes(32)
+        user.password_hash = self._hash_password(password, user.salt)
+
+    def delete_user(self, username: str) -> bool:
+        return self._users.pop(username, None) is not None
+
+    def list_users(self) -> list[str]:
+        return sorted(self._users.keys())
+
+    def authenticate(self, credentials: dict[str, Any]) -> AuthResult:
+        if not self._enabled:
+            raise AuthenticationError("auth backend is disabled")
+        username = credentials.get("username", "")
+        password = credentials.get("password", "")
+        if not username or not password:
+            raise AuthenticationError("username and password are required")
+
+        user = self._users.get(username)
+        if user is None:
+            raise AuthenticationError("invalid credentials")
+        if user.disabled:
+            raise AuthenticationError("user is disabled")
+
+        pw_hash = self._hash_password(password, user.salt)
+        if not hmac.compare_digest(pw_hash, user.password_hash):
+            raise AuthenticationError("invalid credentials")
+
+        user.last_login = time.time()
+        user.login_count += 1
+
+        return AuthResult(
+            entity_id=generate_id("entity"),
+            policies=list(user.policies),
+            metadata={"username": username},
+            auth_backend=self._name,
+        )
+
+    def _hash_password(self, password: str, salt: bytes) -> bytes:
+        return hashlib.pbkdf2_hmac("sha256", password.encode(), salt, self._iterations)
+
+
+@dataclass
+class AppRole:
+    role_id: str
+    secret_id_hash: bytes
+    secret_id_salt: bytes
+    policies: list[str] = field(default_factory=list)
+    bind_secret_id: bool = True
+    secret_id_ttl: float = 0.0
+    token_ttl: float = 3600.0
+    token_max_ttl: float = 0.0
+    secret_id_num_uses: int = 0
+    secret_id_uses_remaining: int = 0
+    created_at: float = field(default_factory=time.time)
+
+    def __post_init__(self) -> None:
+        if self.secret_id_num_uses > 0 and self.secret_id_uses_remaining == 0:
+            self.secret_id_uses_remaining = self.secret_id_num_uses
+
+
+class AppRoleBackend(AuthBackend):
+    """Application role-based authentication backend."""
+
+    def __init__(self, name: str = "approle") -> None:
+        super().__init__(name)
+        self._roles: dict[str, AppRole] = {}
+        self._role_id_map: dict[str, str] = {}
+
+    def backend_type(self) -> str:
+        return "approle"
+
+    def create_role(self, role_name: str, policies: list[str] | None = None, bind_secret_id: bool = True) -> str:
+        if role_name in self._roles:
+            raise AuthenticationError(f"role already exists: {role_name}")
+
+        role_id = generate_id("role")
+        secret_id = generate_token(32)
+        salt = secure_random_bytes(32)
+        secret_hash = hashlib.pbkdf2_hmac("sha256", secret_id.encode(), salt, 100000)
+
+        role = AppRole(
+            role_id=role_id,
+            secret_id_hash=secret_hash,
+            secret_id_salt=salt,
+            policies=list(policies or []),
+            bind_secret_id=bind_secret_id,
+        )
+        self._roles[role_name] = role
+        self._role_id_map[role_id] = role_name
+        return secret_id
+
+    def get_role_id(self, role_name: str) -> str:
+        role = self._roles.get(role_name)
+        if role is None:
+            raise AuthenticationError(f"role not found: {role_name}")
+        return role.role_id
+
+    def delete_role(self, role_name: str) -> bool:
+        role = self._roles.pop(role_name, None)
+        if role:
+            self._role_id_map.pop(role.role_id, None)
+            return True
+        return False
+
+    def list_roles(self) -> list[str]:
+        return sorted(self._roles.keys())
+
+    def authenticate(self, credentials: dict[str, Any]) -> AuthResult:
+        if not self._enabled:
+            raise AuthenticationError("auth backend is disabled")
+
+        role_id = credentials.get("role_id", "")
+        secret_id = credentials.get("secret_id", "")
+
+        if not role_id:
+            raise AuthenticationError("role_id is required")
+
+        role_name = self._role_id_map.get(role_id)
+        if role_name is None:
+            raise AuthenticationError("invalid role_id")
+
+        role = self._roles[role_name]
+
+        if role.bind_secret_id:
+            if not secret_id:
+                raise AuthenticationError("secret_id is required")
+            computed = hashlib.pbkdf2_hmac("sha256", secret_id.encode(), role.secret_id_salt, 100000)
+            if not hmac.compare_digest(computed, role.secret_id_hash):
+                raise AuthenticationError("invalid secret_id")
+            if role.secret_id_num_uses > 0:
+                if role.secret_id_uses_remaining <= 0:
+                    raise AuthenticationError("secret_id has no remaining uses")
+                role.secret_id_uses_remaining -= 1
+
+        return AuthResult(
+            entity_id=generate_id("entity"),
+            policies=list(role.policies),
+            metadata={"role_name": role_name, "role_id": role_id},
+            ttl=role.token_ttl,
+            auth_backend=self._name,
+        )
+
