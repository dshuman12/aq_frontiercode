+
+class AuthConfigValidator:
+    """Validates authentication backend configurations."""
+
+    def validate_userpass(self, config: dict[str, Any]) -> AuthConfigValidationResult:
+        errors: list[str] = []
+        warnings: list[str] = []
+        iterations = config.get("iterations", 100000)
+        if iterations < 10000:
+            errors.append("iterations must be >= 10000 for security")
+        if iterations < 100000:
