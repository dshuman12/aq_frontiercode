+class CertBackend(AuthBackend):
+    """Certificate-based authentication backend."""
+
+    def __init__(self, name: str = "cert") -> None:
+        super().__init__(name)
+        self._certs: dict[str, Certificate] = {}
+
+    def backend_type(self) -> str:
+        return "cert"
+
+    def register_certificate(self, name: str, fingerprint: str, policies: list[str] | None = None) -> Certificate:
+        cert = Certificate(
+            name=name,
+            fingerprint=fingerprint,
+            policies=list(policies or []),
+        )
+        self._certs[name] = cert
+        return cert
+
+    def delete_certificate(self, name: str) -> bool:
+        return self._certs.pop(name, None) is not None
+
+    def list_certificates(self) -> list[str]:
+        return sorted(self._certs.keys())
+
+    def authenticate(self, credentials: dict[str, Any]) -> AuthResult:
+        if not self._enabled:
+            raise AuthenticationError("auth backend is disabled")
+
+        cert_fingerprint = credentials.get("fingerprint", "")
+        if not cert_fingerprint:
+            raise AuthenticationError("certificate fingerprint is required")
+
+        for cert in self._certs.values():
+            if cert.fingerprint == cert_fingerprint:
+                return AuthResult(
+                    entity_id=generate_id("entity"),
+                    policies=list(cert.policies),
+                    metadata={"cert_name": cert.name},
+                    ttl=cert.ttl,
+                    auth_backend=self._name,
+                )
+
+        raise AuthenticationError("no matching certificate found")
+
+
+class TokenBackend(AuthBackend):
+    """Token-based authentication (validates existing tokens)."""
+
+    def __init__(self, name: str = "token") -> None:
+        super().__init__(name)
+        self._valid_tokens: dict[str, dict[str, Any]] = {}
+
+    def backend_type(self) -> str:
+        return "token"
+
+    def register_token(self, token_value: str, entity_id: str, policies: list[str]) -> None:
+        self._valid_tokens[token_value] = {
+            "entity_id": entity_id,
+            "policies": policies,
+        }
+
+    def revoke_token(self, token_value: str) -> bool:
+        return self._valid_tokens.pop(token_value, None) is not None
+
+    def authenticate(self, credentials: dict[str, Any]) -> AuthResult:
+        if not self._enabled:
+            raise AuthenticationError("auth backend is disabled")
+
+        token_value = credentials.get("token", "")
+        if not token_value:
+            raise AuthenticationError("token is required")
+
+        entry = self._valid_tokens.get(token_value)
+        if entry is None:
+            raise AuthenticationError("invalid token")
+
+        return AuthResult(
+            entity_id=entry["entity_id"],
+            policies=entry["policies"],
+            metadata={},
+            auth_backend=self._name,
+        )
+
+
+class AuthManager:
+    """Manages multiple authentication backends."""
+
+    def __init__(self) -> None:
+        self._backends: dict[str, AuthBackend] = {}
+
+    def register(self, backend: AuthBackend) -> None:
+        self._backends[backend.name] = backend
+
+    def unregister(self, name: str) -> bool:
+        return self._backends.pop(name, None) is not None
+
+    def get(self, name: str) -> AuthBackend | None:
+        return self._backends.get(name)
+
+    def list_backends(self) -> list[str]:
+        return sorted(self._backends.keys())
+
+    def authenticate(self, backend_name: str, credentials: dict[str, Any]) -> AuthResult:
+        backend = self._backends.get(backend_name)
+        if backend is None:
+            raise AuthenticationError(f"auth backend not found: {backend_name}")
+        return backend.authenticate(credentials)
+
