diff --git a/src/db/seeds/migrate-mongodb.ts b/src/db/seeds/migrate-mongodb.ts
new file mode 100644
index 0000000..d96b7de
--- /dev/null
+++ b/src/db/seeds/migrate-mongodb.ts
@@ -0,0 +1,361 @@
+import { config } from 'dotenv';
+config({ path: '.env' });
+
+import { createId } from '@paralleldrive/cuid2';
+import { sql } from 'drizzle-orm';
+import { readFileSync } from 'fs';
+import { resolve } from 'path';
+import { db } from '../index';
+import {
+  attendance,
+  businessHistory,
+  counters,
+  customers,
+  employees,
+  orderItems,
+  orders,
+  payments,
+} from '../schema';
+
+// ── MongoDB JSON Types ──────────────────────────────────────
+interface MongoOid { $oid: string }
+interface MongoDate { $date: string }
+
+interface MongoCustomer {
+  _id: MongoOid;
+  cName: string;
+  cPhone: string;
+  cAddress: string | null;
+  cPaidAmount: number;
+  cOutstandingAmt: number;
+  cOrders: MongoOid[];
+  cImgUrl: string | null;
+  cNIC?: string | null;
+  createdAt: MongoDate;
+  updatedAt: MongoDate;
+}
+
+interface MongoOrderItem {
+  item: MongoOid;
+  product_name_snapshot: string;
+  product_category_snapshot: string;
+  quantity: number;
+  price_type: string;
+  applied_price: number;
+  cost_price_snapshot?: number;
+  discount_amount: number;
+  item_total: number;
+  item_profit?: number;
+  _id: MongoOid;
+}
+
+interface MongoPayment {
+  amount: number;
+  payment_date: MongoDate;
+  payment_method_used: string;
+  notes?: string;
+  _id: MongoOid;
+}
+
+interface MongoOrder {
+  _id: MongoOid;
+  business_name: string | null;
+  location: string | null;
+  phone_num: string | null;
+  invoice_id: string;
+  order_items: MongoOrderItem[];
+  payment_method: string | null;
+  subtotal: number;
+  total_discount: number;
+  total_price: number;
+  total_profit?: number;
+  is_wholesale: boolean;
+  payments_received: MongoPayment[];
+  order_paid_amount: number;
+  order_outstanding_amount: number;
+  order_status: string;
+  customer?: MongoOid;
+  walkInCustomerName?: string | null;
+  walkInCustomerCNIC?: string | null;
+  walkInCustomerPhone?: string | null;
+  isArchived: boolean;
+  createdAt: MongoDate;
+  updatedAt: MongoDate;
+}
+
+interface MongoAttendanceRecord {
+  date: MongoDate;
+  status: string;
+  payment: string;
+}
+
+interface MongoEmployee {
+  _id: MongoOid;
+  name: string;
+  cnic: string;
+  phone: string;
+  salary: number;
+  imgUrl: string | null;
+  attendance: MongoAttendanceRecord[];
+  createdAt: MongoDate;
+  updatedAt: MongoDate;
+}
+
+interface MongoBusinessHistory {
+  year: number;
+  months: { month: number; days: { day: number; totalProfit: number; totalOrders: number }[] }[];
+}
+
+// ── Drizzle Insert Types ────────────────────────────────────
+type CustomerInsert = typeof customers.$inferInsert;
+type OrderInsert = typeof orders.$inferInsert;
+type OrderItemInsert = typeof orderItems.$inferInsert;
+type PaymentInsert = typeof payments.$inferInsert;
+type EmployeeInsert = typeof employees.$inferInsert;
+type AttendanceInsert = typeof attendance.$inferInsert;
+
+// ── Enum Mappers ────────────────────────────────────────────
+function mapPaymentMethod(method: string | null | undefined): 'CASH' | 'CARD' | 'ONLINE_PAYMENT' | null {
+  if (!method) return null;
+  const m = method.toLowerCase().trim();
+  if (m === 'cash') return 'CASH';
+  if (m === 'card') return 'CARD';
+  if (m.includes('online')) return 'ONLINE_PAYMENT';
+  return 'CASH';
+}
+
+function mapOrderStatus(status: string): 'PENDING' | 'PARTIALLY_PAID' | 'FULLY_PAID' | 'CANCELLED' {
+  const s = status.toLowerCase();
+  if (s.includes('fully')) return 'FULLY_PAID';
+  if (s.includes('partial')) return 'PARTIALLY_PAID';
+  if (s.includes('cancel')) return 'CANCELLED';
+  return 'PENDING';
+}
+
+function mapPriceType(type: string): 'RETAIL' | 'WHOLESALE' {
+  return type.toLowerCase() === 'wholesale' ? 'WHOLESALE' : 'RETAIL';
+}
+
+function mapAttendanceStatus(status: string): 'PRESENT' | 'ABSENT' | 'LEAVE' | 'HALF_DAY' {
+  const s = status.toLowerCase();
+  if (s === 'present') return 'PRESENT';
+  if (s === 'absent') return 'ABSENT';
+  if (s === 'halfday') return 'HALF_DAY';
+  return 'PRESENT';
+}
+
+function mapPaymentStatus(payment: string): 'PAID' | 'UNPAID' {
+  return payment.toLowerCase() === 'unpaid' ? 'UNPAID' : 'PAID';
+}
+
+// ── Batch Insert Helper ─────────────────────────────────────
+async function batchInsert<T>(
+  data: T[],
+  insertFn: (batch: T[]) => Promise<unknown>,
+  batchSize: number,
+  label: string,
+): Promise<void> {
+  if (data.length === 0) { console.log(`  ⏭️  No ${label} to insert`); return; }
+  for (let i = 0; i < data.length; i += batchSize) {
+    const batch = data.slice(i, i + batchSize);
+    await insertFn(batch);
+    console.log(`  ✅ ${Math.min(i + batchSize, data.length)}/${data.length} ${label}`);
+  }
+}
+
+// ── File Reader ─────────────────────────────────────────────
+function readBackup<T>(filename: string): T {
+  const filePath = resolve(__dirname, '../../../backup', filename);
+  console.log(`  📂 Reading ${filename}...`);
+  return JSON.parse(readFileSync(filePath, 'utf-8')) as T;
+}
+
+// ── Main ────────────────────────────────────────────────────
+async function main(): Promise<void> {
+  console.log('\n══════════════════════════════════════════');
+  console.log('  MongoDB → PostgreSQL Migration');
+  console.log('══════════════════════════════════════════\n');
+
+  // Pre-check existing invoice IDs to avoid conflicts
+  const existing = await db.select({ invoiceId: orders.invoiceId }).from(orders);
+  const existingInvoiceIds = new Set(existing.map(o => o.invoiceId));
+  console.log(`ℹ️  ${existingInvoiceIds.size} existing orders in DB\n`);
+
+  // ── 1. CUSTOMERS ──────────────────────────────
+  console.log('┌─ 1/5 CUSTOMERS ─────────────────────────');
+  const mongoCustomers = readBackup<MongoCustomer[]>('SubhanTraders.customers.json');
+  // Pre-load existing customers by phone so we can map their IDs correctly
+  const existingCustomers = await db.select({ id: customers.id, phone: customers.phone }).from(customers);
+  const existingByPhone = new Map(existingCustomers.map(c => [c.phone, c.id]));
+  console.log(`  ℹ️  ${existingByPhone.size} customers already in DB`);
+
+  const custData: CustomerInsert[] = [];
+  const customerOidMap = new Map<string, string>();
+  const seenPhones = new Set<string>(existingByPhone.keys()); // seed with already-existing phones
+
+  for (const mc of mongoCustomers) {
+    let phone = mc.cPhone ?? 'unknown';
+
+    // If phone already in DB, map OID to existing DB ID — no insert needed
+    if (existingByPhone.has(phone)) {
+      customerOidMap.set(mc._id.$oid, existingByPhone.get(phone)!);
+      continue;
+    }
+
+    // Deduplicate within current batch
+    if (seenPhones.has(phone)) {
+      let suffix = mc._id.$oid.slice(-4);
+      let candidate = `${phone}-${suffix}`;
+      let counter = 0;
+      while (seenPhones.has(candidate)) {
+        candidate = `${phone}-${suffix}-${++counter}`;
+      }
+      phone = candidate;
+    }
+    seenPhones.add(phone);
+
+    const newId = createId();
+    customerOidMap.set(mc._id.$oid, newId);
+    custData.push({
+      id: newId,
+      name: mc.cName,
+      cnic: mc.cNIC ?? null,
+      phone,
+      address: mc.cAddress ?? null,
+      paidAmount: String(mc.cPaidAmount ?? 0),
+      outstandingAmount: String(mc.cOutstandingAmt ?? 0),
+      imgUrl: mc.cImgUrl ?? null,
+      isActive: true,
+      createdAt: new Date(mc.createdAt.$date),
+      updatedAt: new Date(mc.updatedAt.$date),
+    });
+  }
+
+  await batchInsert(custData, async (b) => { await db.insert(customers).values(b).onConflictDoNothing(); }, 25, 'customers');
+  const totalInDb = existingByPhone.size + custData.length;
+  console.log(`└─ ✅ ${custData.length} new inserted, ${existingByPhone.size} already existed, ${totalInDb} total mapped\n`);
+
+  // ── 2. ORDERS + ORDER ITEMS + PAYMENTS ────────
+  console.log('┌─ 2/5 ORDERS ────────────────────────────');
+  const mongoOrders = readBackup<MongoOrder[]>('SubhanTraders.orders.json');
+  const ordData: OrderInsert[] = [];
+  const oiData: OrderItemInsert[] = [];
+  const pmData: PaymentInsert[] = [];
+  const seenInvoices = new Set<string>();
+  let skipped = 0;
+
+  for (const mo of mongoOrders) {
+    if (existingInvoiceIds.has(mo.invoice_id)) { skipped++; continue; }
+
+    let invoiceId = mo.invoice_id;
+    if (seenInvoices.has(invoiceId)) {
+      invoiceId = `${invoiceId}-${mo._id.$oid.slice(-6)}`;
+    }
+    seenInvoices.add(invoiceId);
+
+    const orderId = createId();
+    const customerId = mo.customer?.$oid ? customerOidMap.get(mo.customer.$oid) ?? null : null;
+
+    ordData.push({
+      id: orderId,
+      invoiceId,
+      businessName: mo.business_name ?? null,
+      location: mo.location ?? null,
+      phoneNum: mo.phone_num ?? null,
+      customerId,
+      walkInCustomerName: mo.walkInCustomerName ?? null,
+      walkInCustomerCNIC: mo.walkInCustomerCNIC ?? null,
+      walkInCustomerPhone: mo.walkInCustomerPhone ?? null,
+      subtotal: String(mo.subtotal ?? 0),
+      totalDiscount: String(mo.total_discount ?? 0),
+      totalPrice: String(mo.total_price ?? 0),
+      totalProfit: String(mo.total_profit ?? 0),
+      paidAmount: String(mo.order_paid_amount ?? 0),
+      outstandingAmount: String(mo.order_outstanding_amount ?? 0),
+      isWholesale: mo.is_wholesale ?? false,
+      paymentMethod: mapPaymentMethod(mo.payment_method),
+      orderStatus: mapOrderStatus(mo.order_status),
+      isArchived: mo.isArchived ?? false,
+      createdAt: new Date(mo.createdAt.$date),
+      updatedAt: new Date(mo.updatedAt.$date),
+    });
+
+    for (const oi of mo.order_items) {
+      oiData.push({
+        id: createId(),
+        orderId,
+        itemId: null, // Old MongoDB product refs don't exist in new DB
+        productNameSnapshot: oi.product_name_snapshot ?? '(Unknown Product)',
+        productCategorySnapshot: oi.product_category_snapshot ?? null,
+        quantity: oi.quantity,
+        priceType: mapPriceType(oi.price_type),
+        appliedPrice: String(oi.applied_price ?? 0),
+        costPriceSnapshot: String(oi.cost_price_snapshot ?? 0),
+        discountAmount: String(oi.discount_amount ?? 0),
+        itemTotal: String(oi.item_total ?? 0),
+        itemProfit: String(oi.item_profit ?? 0),
+        createdAt: new Date(mo.createdAt.$date),
+      });
+    }
+
+    for (const pr of mo.payments_received) {
+      pmData.push({
+        id: createId(),
+        orderId,
+        amount: String(pr.amount ?? 0),
+        paymentMethod: mapPaymentMethod(pr.payment_method_used) ?? 'CASH',
+        notes: pr.notes ?? null,
+        paymentDate: new Date(pr.payment_date.$date),
+        createdAt: new Date(pr.payment_date.$date),
+      });
+    }
+  }
+
+  if (skipped > 0) console.log(`  ⏭️  Skipped ${skipped} duplicate orders`);
+  await batchInsert(ordData, async (b) => { await db.insert(orders).values(b).onConflictDoNothing(); }, 50, 'orders');
+  await batchInsert(oiData, async (b) => { await db.insert(orderItems).values(b).onConflictDoNothing(); }, 100, 'order items');
+  await batchInsert(pmData, async (b) => { await db.insert(payments).values(b).onConflictDoNothing(); }, 100, 'payments');
+  console.log(`└─ ✅ ${ordData.length} orders, ${oiData.length} items, ${pmData.length} payments\n`);
+
+  // ── 3. EMPLOYEES + ATTENDANCE (SKIPPED) ────────
+  console.log('┌─ 3/5 EMPLOYEES ── SKIPPED ──────────────');
+  console.log('└─ ⏭️  Skipping employees & attendance\n');
+
+  // ── 4. BUSINESS HISTORY (SKIPPED) ─────────────
+  console.log('┌─ 4/5 BUSINESS HISTORY ── SKIPPED ───────');
+  console.log('└─ ⏭️  Skipping business history\n');
+
+  // ── 5. COUNTERS ───────────────────────────────
+  console.log('┌─ 5/5 COUNTERS ──────────────────────────');
+  const mongoCounters = readBackup<{ _id: string; sequence_value: number }[]>('SubhanTraders.counters.json');
+  for (const mc of mongoCounters) {
+    await db.insert(counters).values({
+      id: 'invoice_counter',
+      sequenceValue: mc.sequence_value,
+    }).onConflictDoUpdate({
+      target: counters.id,
+      set: { sequenceValue: sql`GREATEST(${counters.sequenceValue}, ${mc.sequence_value})` },
+    });
+    console.log(`  ✅ Counter → ${mc.sequence_value}`);
+  }
+  console.log('└─ ✅ Counter updated\n');
+
+  // ── Summary ───────────────────────────────────
+  console.log('══════════════════════════════════════════');
+  console.log('  Migration Complete!');
+  console.log('══════════════════════════════════════════');
+  console.log(`  Customers:        ${custData.length}`);
+  console.log(`  Orders:           ${ordData.length} (${skipped} skipped)`);
+  console.log(`  Order Items:      ${oiData.length}`);
+  console.log(`  Payments:         ${pmData.length}`);
+  console.log(`  Employees:        SKIPPED`);
+  console.log(`  Business History: SKIPPED`);
+  console.log('══════════════════════════════════════════\n');
+
+  process.exit(0);
+}
+
+main().catch((err) => {
+  console.error('❌ Migration failed:', err);
+  process.exit(1);
+});
