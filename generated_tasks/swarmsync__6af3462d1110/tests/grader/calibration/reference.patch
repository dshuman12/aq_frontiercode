+// PutBatch inserts multiple key-value pairs with a single tree rebuild.
+// Far more efficient than calling Put repeatedly.
+func (t *Tree) PutBatch(entries map[string][]byte) {
+	t.mu.Lock()
+	defer t.mu.Unlock()
+	for k, v := range entries {
+		cp := make([]byte, len(v))
+		copy(cp, v)
+		t.data[k] = cp
+	}
 	t.rebuild()
 }
 
