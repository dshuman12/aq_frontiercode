diff --git a/tests/test_centrality.cpp b/tests/test_centrality.cpp
index da2ee8a..b3c9b02 100644
--- a/tests/test_centrality.cpp
+++ b/tests/test_centrality.cpp
@@ -158,4 +158,43 @@ CRYO_TEST(MaxCent, Basic) {
     auto g = make_star5();
     auto cm = degree_centrality(g);
     assert_eq(max_centrality_node(cm), (NodeId)0);
+}
+
+// ── Optimized betweenness + pagerank tests ─────────────────────────────────
+
+CRYO_TEST(Betweenness, VectorOptPath) {
+    Graph g(GraphType::Undirected);
+    for (int i = 0; i < 5; i++) g.add_node_with_id(i);
+    g.add_edge(0, 1); g.add_edge(1, 2); g.add_edge(2, 3); g.add_edge(3, 4);
+    auto bc = betweenness_centrality(g);
+    assert_gt(bc[2], bc[0]);
+    assert_gt(bc[2], bc[4]);
+    assert_gt(bc[1], bc[0]);
+}
+
+CRYO_TEST(Betweenness, VectorOptComplete) {
+    GraphGenerator gen(42);
+    auto g = gen.complete(5);
+    auto bc = betweenness_centrality(g);
+    for (int i = 0; i < 5; i++) {
+        assert_near(bc[i], 0.0, 1e-6);
+    }
+}
+
+CRYO_TEST(PageRank, VectorOptConvergence) {
+    Graph g(GraphType::Directed);
+    for (int i = 0; i < 4; i++) g.add_node_with_id(i);
+    g.add_edge(0, 1); g.add_edge(1, 2); g.add_edge(2, 3); g.add_edge(3, 0);
+    auto pr = pagerank(g);
+    double total = 0;
+    for (auto& [_, v] : pr) total += v;
+    assert_near(total, 1.0, 1e-6);
+}
+
+CRYO_TEST(PageRank, VectorOptDangling) {
+    Graph g(GraphType::Directed);
+    for (int i = 0; i < 3; i++) g.add_node_with_id(i);
+    g.add_edge(0, 1); g.add_edge(1, 2);
+    auto pr = pagerank(g);
+    assert_gt(pr[2], pr[0]);
 }
