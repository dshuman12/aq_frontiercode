# Repflow Frontend Environment Variables
# Copy this file to .env.local and fill in your actual values
#
# Base URL for Stripe Payment Link "return to site" after checkout (no trailing slash).
# Used by scripts/stripe-sync-env.mjs when creating/updating Payment Links.
# REPFLOW_STRIPE_PAYMENT_RETURN_BASE=http://localhost:3000
# Production: REPFLOW_STRIPE_PAYMENT_RETURN_BASE=https://your-production-domain.com
#
# Local `npm run dev` (Stripe test-only):
# - `next dev` always behaves as Stripe test mode (never uses embedded live Payment Links).
# - Put test keys + Payment Links in `.env.development.local` (overrides `.env.local` for the same keys).
#   Generate the managed block with test keys: `npm run stripe:sync:dev`
#   (requires sk_test_ / pk_test_ in .env.stripe.secrets — use https://dashboard.stripe.com/test/apikeys ).
# - Or set `NEXT_PUBLIC_*_TEST` vars alongside live values in `.env.local` (see constants.ts).
#
# Hosted dev (e.g. AWS App Runner `repflow-frontend-dev`): NODE_ENV is production, so you MUST set
# NEXT_PUBLIC_STRIPE_TEST_MODE=true and use pk_test_ + test Payment Link URLs in the service
# build env (same as this block). Copy values from `npm run stripe:sync:dev` output / .env.development.local.

# ===========================================
# STRIPE CONFIGURATION (dev vs production)
# ===========================================
#
# app/constants/constants.ts uses NEXT_PUBLIC_STRIPE_TEST_MODE on production builds:
# - true  → Stripe test mode (hosted dev/staging OR explicit); use pk_test + test price/link IDs.
# - unset → live defaults are used when an env var is omitted (production App Runner / Vercel prod).
# `next dev` forces test mode without this flag; hosted dev does not — set the flag there.
#
# Backend webhooks still use STRIPE_SECRET_KEY on the API (dev/Repflow-stack vs prod secret).
# See ../repflow/docs/DEPLOYMENT-ENVIRONMENTS.md §4.
#

# --- Development / staging frontend (Stripe test mode) ---
NEXT_PUBLIC_STRIPE_TEST_MODE=true
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Create Payment Links in Dashboard with Test mode ON, same tier amounts as prod, then paste URLs:
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_test_starter_monthly
NEXT_PUBLIC_STRIPE_GROWTH_PRICE_ID=price_test_growth_monthly
NEXT_PUBLIC_STRIPE_SCALE_PRICE_ID=price_test_scale_monthly
NEXT_PUBLIC_STRIPE_STARTER_PAYMENT_LINK=https://buy.stripe.com/test_...
NEXT_PUBLIC_STRIPE_GROWTH_PAYMENT_LINK=https://buy.stripe.com/test_...
NEXT_PUBLIC_STRIPE_SCALE_PAYMENT_LINK=https://buy.stripe.com/test_...
NEXT_PUBLIC_STRIPE_STARTER_YEARLY_PAYMENT_LINK=https://buy.stripe.com/test_...
NEXT_PUBLIC_STRIPE_GROWTH_YEARLY_PAYMENT_LINK=https://buy.stripe.com/test_...
NEXT_PUBLIC_STRIPE_SCALE_YEARLY_PAYMENT_LINK=https://buy.stripe.com/test_...

# --- Production frontend (Stripe live mode) — example; omit NEXT_PUBLIC_STRIPE_TEST_MODE ---
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_SECRET_KEY=sk_live_...
# Optional overrides (defaults in code match live Payment Links created for active products):
# NEXT_PUBLIC_STRIPE_STARTER_PAYMENT_LINK=https://buy.stripe.com/fZuaEY8yu7fMe8v6N78Ra0d
# NEXT_PUBLIC_STRIPE_STARTER_YEARLY_PAYMENT_LINK=https://buy.stripe.com/5kQdRa4iefMic0nfjD8Ra0g
# NEXT_PUBLIC_STRIPE_GROWTH_PAYMENT_LINK=https://buy.stripe.com/7sYdRa6qmfMi9Sf4EZ8Ra0e
# NEXT_PUBLIC_STRIPE_GROWTH_YEARLY_PAYMENT_LINK=https://buy.stripe.com/aFa8wQaGC9nU5BZ9Zj8Ra0h
# NEXT_PUBLIC_STRIPE_SCALE_PAYMENT_LINK=https://buy.stripe.com/dRm14obKGcA6d4r3AV8Ra0f
# NEXT_PUBLIC_STRIPE_SCALE_YEARLY_PAYMENT_LINK=https://buy.stripe.com/4gM5kE7uqbw2fcz3AV8Ra0i

# ===========================================
# BACKEND API CONFIGURATION
# ===========================================

# FastAPI base URL (no trailing slash). Must match the backend that uses the SAME Cognito pool as below.
# Full checklist: ../repflow/docs/DEPLOYMENT-ENVIRONMENTS.md §5
# Local backend:
#   NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Dev App Runner (example — use your dev service URL):
#   NEXT_PUBLIC_API_BASE_URL=https://YOUR-DEV-API.us-east-2.awsapprunner.com
# Production:
#   NEXT_PUBLIC_API_BASE_URL=https://YOUR-PROD-API.us-east-2.awsapprunner.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ===========================================
# NEXTAUTH CONFIGURATION
# ===========================================

# Required for NextAuth (signing/encryption). Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# Canonical URL of the app (use http://localhost:3000 for local dev)
NEXTAUTH_URL=http://localhost:3000

# ===========================================
# AWS COGNITO CONFIGURATION
# ===========================================

# IAM credentials for server-side Cognito / S3 API calls (Required for signup, password flows, uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_COGNITO_REGION=us-east-2

# Optional overrides — if unset, `next dev` uses the Dev pool + "Repflow Creator Panel" client;
# production builds use the Prod pool + client (see app/lib/cognito-env-defaults.ts).
#
# Dev pool "Repflow Creator Panel": client id 7mfnjnh9b4i464qlmt42c24fjk, pool us-east-2_s82ysRbW8
# Prod pool "Repflow Creator Panel": client id 1jcl067l8ampqksfh3103mv5s3, pool us-east-2_UOedUZggp
#
# Client secret is required for these app clients (confidential). It is not in git — fetch with AWS CLI:
#   aws cognito-idp describe-user-pool-client --region us-east-2 \
#     --user-pool-id us-east-2_s82ysRbW8 --client-id 7mfnjnh9b4i464qlmt42c24fjk \
#     --query 'UserPoolClient.ClientSecret' --output text
# (Use prod pool id + prod client id for production secrets.)
# AWS_COGNITO_USER_POOL_ID=us-east-2_s82ysRbW8
# AWS_COGNITO_CLIENT_ID=7mfnjnh9b4i464qlmt42c24fjk
AWS_COGNITO_CLIENT_SECRET=your_cognito_client_secret_here

# ===========================================
# OPENAI CONFIGURATION
# ===========================================

# OpenAI API Key (Required for AI features)
OPENAI_API_KEY=sk-proj_your_openai_api_key_here

# ===========================================
# ENVIRONMENT NOTES
# ===========================================

# For TEST mode:
# - Use keys starting with pk_test_ and sk_test_
# - Use test payment links and price IDs
# - Test with Stripe test card numbers

# For LIVE mode:
# - Use keys starting with pk_live_ and sk_live_
# - Use live payment links and price IDs
# - Ensure HTTPS is enabled
# - Test thoroughly before going live
