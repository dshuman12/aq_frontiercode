// Find all primes up to N using trial division
fn is_prime(n: int) -> bool {
    if n < 2 { return false }
    let mut i = 2
    while i * i <= n {
        if n % i == 0 { return false }
        i += 1
    }
    true
}

let mut count = 0
for n in 2..100 {
    if is_prime(n) {
        print(str(n) + " ")
        count += 1
    }
}
println("")
println("Found " + str(count) + " primes under 100")