+
+// --- Counting filter saturation (no false negatives) ---
+
+func TestCountingFilter_NoFalseNegativeAfterSaturation(t *testing.T) {
+	// Adding one element far more than the 4-bit counter ceiling saturates its
+	// positions. Removing fewer times than it was added must leave it present:
+	// a counting Bloom filter must never produce a false negative.
+	cf := NewCountingFilter(100, 0.01)
+	data := []byte("hot-key")
+	for i := 0; i < 20; i++ {
+		cf.Add(data)
+	}
+	for i := 0; i < 15; i++ {
+		cf.Remove(data)
+	}
+	if !cf.Contains(data) {
+		t.Fatal("saturated counters must not be driven to a false negative by Remove")
+	}
+}
+
+func TestCountingFilter_SaturationDoesNotLeakToOthers(t *testing.T) {
+	// A normal add/remove of a different element must still behave normally
+	// even when another element has saturated some shared counters.
+	cf := NewCountingFilter(100, 0.01)
+	hot := []byte("hot-key")
+	for i := 0; i < 20; i++ {
+		cf.Add(hot)
+	}
+	cold := []byte("cold-key")
+	cf.Add(cold)
+	if !cf.Contains(cold) {
+		t.Fatal("freshly added element should be present")
+	}
+	cf.Remove(cold)
+	if !cf.Contains(hot) {
+		t.Fatal("removing another element must not drop the saturated element")
+	}
+}
+
+// --- FillRatio fast path ---
+
+func TestFilter_FillRatioReflectsState(t *testing.T) {
+	f := NewFilterRaw(1024, 3)
+	if f.FillRatio() != 0 {
+		t.Fatalf("empty filter should have fill ratio 0, got %v", f.FillRatio())
+	}
+	for i := 0; i < 10; i++ {
+		f.Add([]byte(fmt.Sprintf("fr-%d", i)))
+	}
+	fr := f.FillRatio()
+	if fr <= 0 || fr > 1 {
+		t.Fatalf("fill ratio should be in (0,1], got %v", fr)
+	}
+	f.Reset()
+	if f.FillRatio() != 0 {
+		t.Fatalf("fill ratio should be 0 after reset, got %v", f.FillRatio())
+	}
+}
+
+func TestFilter_FillRatioAfterUnion(t *testing.T) {
+	a := NewFilterRaw(1024, 3)
+	b := NewFilterRaw(1024, 3)
+	a.Add([]byte("alpha"))
+	b.Add([]byte("beta"))
+	if !a.Union(b) {
+		t.Fatal("union of matching filters should succeed")
+	}
+	if !a.Contains([]byte("alpha")) || !a.Contains([]byte("beta")) {
+		t.Fatal("union should contain both elements")
+	}
+	fr := a.FillRatio()
+	if fr <= 0 || fr > 1 {
+		t.Fatalf("fill ratio should be in (0,1] after union, got %v", fr)
+	}
+}
+
+func TestFilter_FillRatioUnionNoDoubleCount(t *testing.T) {
+	// Unioning a filter with an identical one leaves the bit array unchanged,
+	// so the reported fill ratio must not change. A fill-ratio fast path that
+	// simply adds the two counts together would wrongly double it.
+	a := NewFilterRaw(2048, 4)
+	b := NewFilterRaw(2048, 4)
+	for i := 0; i < 25; i++ {
+		key := []byte(fmt.Sprintf("dup-%d", i))
+		a.Add(key)
+		b.Add(key)
+	}
+	before := a.FillRatio()
+	if !a.Union(b) {
+		t.Fatal("union of matching filters should succeed")
+	}
+	if got := a.FillRatio(); got != before {
+		t.Fatalf("union with an identical filter must not change fill ratio: before=%v after=%v", before, got)
+	}
+}
+
+func TestFilter_FillRatioConsistentAfterResetAndRefill(t *testing.T) {
+	// Whatever fast path FillRatio uses must stay consistent across the full
+	// lifecycle: fill, reset to zero, then refill to the same population.
+	f := NewFilterRaw(2048, 4)
+	for i := 0; i < 30; i++ {
+		f.Add([]byte(fmt.Sprintf("k-%d", i)))
+	}
+	full := f.FillRatio()
+	f.Reset()
+	if f.FillRatio() != 0 {
+		t.Fatalf("fill ratio must be 0 after reset, got %v", f.FillRatio())
+	}
+	for i := 0; i < 30; i++ {
+		f.Add([]byte(fmt.Sprintf("k-%d", i)))
+	}
+	if got := f.FillRatio(); got != full {
+		t.Fatalf("refilling the same keys should reproduce the fill ratio: first=%v second=%v", full, got)
+	}
+}
+
+func TestCountingFilter_NoFalseNegativeWithInterleavedTraffic(t *testing.T) {
+	// One element is added far past the counter ceiling; meanwhile other
+	// elements churn through add/remove. The saturated element must remain
+	// present throughout, and afterwards.
+	cf := NewCountingFilter(64, 0.01)
+	hot := []byte("hot")
+	for i := 0; i < 40; i++ {
+		cf.Add(hot)
+	}
+	for round := 0; round < 30; round++ {
+		k := []byte(fmt.Sprintf("churn-%d", round))
+		cf.Add(k)
+		cf.Remove(k)
+		if !cf.Contains(hot) {
+			t.Fatalf("saturated element dropped during interleaved traffic at round %d", round)
+		}
+	}
+	// And it survives its own (partial) removals.
+	for i := 0; i < 20; i++ {
+		cf.Remove(hot)
+	}
+	if !cf.Contains(hot) {
+		t.Fatal("saturated element must survive partial removal")
+	}
+}
