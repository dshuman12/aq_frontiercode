-# `authentication` (this service's own gateway) is deliberately absent.
-# Including it would create a dependency cycle: authorizer env vars →
-# gateway_ids → rest_api_gateway → (lambda_authorizers input) → authorizer.
-# The authorizer learns its own gateway id at request time from
-# `event.methodArn` instead; local-route ARN patterns use a `*` wildcard
-# in the gateway-id slot (see `scope-map/index.ts:compileRoute`).
+#   module.authorizer (env vars) → local.gateway_ids → rest_api_id
+#                                                  ↑
+#   module.rest_api_gateway (lambda_authorizer_name) ───────────┘
+#
+# `depends_on` defers resolution to apply time so the gateway exists
+# before the data source reads it. The graph edge from
+# `module.rest_api_gateway → module.authorizer.name` is broken in
+# `3-gateway.tf` by `local.authorizer_lambda_name`.
+data "aws_api_gateway_rest_api" "authentication" {
+  name       = "${var.ENVIRONMENT}-authentication"
+  depends_on = [module.rest_api_gateway]
+}
+
+# Keys are the `GatewayKey` type in `scope-map/types.ts`. The authorizer
+# reads `process.env.GATEWAY_IDS` and looks up by key at cold start.
 locals {
   gateway_ids = merge(
     { for k, v in data.aws_api_gateway_rest_api.env_prefixed : k => v.id },
     {
+      authentication = data.aws_api_gateway_rest_api.authentication.id
       api_broker     = data.aws_api_gateway_rest_api.api_broker.id
       device_channel = one(data.aws_apigatewayv2_apis.device_channel.ids)
     }
