{
  "name": "authentication",
  "author": "joe <joe.kadi@onmo.app>",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "test": "vitest run --pool=forks --dir src/functions",
    "test-targets": "vitest run --pool=forks src/test-e2e/forgotten-passcode/*/change-passcode.test.ts",
    "test-e2e": "vitest run --pool=forks --no-file-parallelism --dir src/test-e2e",
    "test-suite": "vitest run --pool=forks $npm_config_suite",
    "test-ui": "vitest --ui",
    "test-file": "NODE_ENV=development vitest run --pool=forks $npm_config_file",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check .",
    "lint-fix": "prettier --write .",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@aws-sdk/client-pinpoint": "^3.556.0",
    "@aws-sdk/lib-dynamodb": "^3.1027.0",
    "@onmoapp/core-banking": "^9.2.1",
    "@onmoapp/handler-middleware": "^2.10.0",
    "@onmoapp/logger": "^4.3.1",
    "@onmoapp/notification-provider": "2.0.0",
    "@onmoapp/onmo-action-validator": "^1.0.4",
    "@onmoapp/onmo-adapters": "^18.2.0",
    "@onmoapp/onmo-dynamodb": "^1.1.1",
    "@onmoapp/onmo-rate-limiter": "1.1.0",
    "@onmoapp/onmo-s3": "^1.1.0",
    "@onmoapp/onmo-secrets-manager": "^1.1.1",
    "@onmoapp/onmo-sns": "^1.0.0",
    "@onmoapp/onmo-sqs": "^1.0.0",
    "@onmoapp/onmo-ssm": "^1.0.0",
    "@onmoapp/onmo-types": "^9.0.1",
    "@onmoapp/salesforce-adapter": "4.0.0",
    "@sendgrid/mail": "^8.1.3",
    "@simplewebauthn/server": "^10.0.1",
    "@simplewebauthn/types": "^10.0.0",
    "axios": "^1.13.5",
    "base64url": "^3.0.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "hybrid-crypto-js": "^0.2.4",
    "jsonwebtoken": "^9.0.2",
    "posthog-node": "^5.14.0",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@aws-sdk/client-lambda": "^3.556.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@expo/devcert": "^1.2.1",
    "@hono/node-server": "^1.19.9",
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@types/aws-lambda": "^8.10.137",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.12.7",
    "@types/uuid": "^9.0.8",
    "@vitest/ui": "^1.3.1",
    "aws-lambda": "^1.0.7",
    "dotenv": "^17.4.1",
    "esbuild": "^0.20.2",
    "esbuild-plugin-yaml": "^0.0.1",
    "hono": "^4.11.9",
    "only-allow": "^1.2.2",
    "prettier": "^3.2.5",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.3",
    "vite-tsconfig-paths": "^4.3.1",
    "vitest": "^1.3.1"
  }
