            "required": true,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "previewType",
            "in": "header",
            "description": "this header is required if environment is preview type",
            "required": false,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "string",
              "enum": [
                "app",
                "wip",
                "APP",
                "WIP"
              ]
            }
          }
        ],
        "requestBody": {
          "description": "Array of VaultRequest objects.\n\n Values accepted for 'type' in VaultRequest object are :\n\n| types |\n|----------|\n|CREDIT_CARD_NUMBER|\n|CREDIT_CARD_EXPIRY_MONTH |\n|CREDIT_CARD_EXPIRY_YEAR |\n|GIFT_CARD_NUMBER |\n|GIFT_CARD_PIN |\n|GIFT_CARD_TRACK2 |\n ",
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/VaultRequest"
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "returns array of VaultResponse objects.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/VaultResponse"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Indexes are not unique. (errorCode 1)\n Some types are invalid. (errorCode 2)\n Index, type or plaintext is missing. (errorCode 3)\n Invalid credit card length - maximum allowed length is 30 and minimum allowed length is 13. (errorcode 11)\n Invalid credit card  - Some credit card numbers are invalid.Only digits are allowed (errorcode 5)\n Invalid gift card - Some gift card numbers are invalid. Only digits are allowed (errorcode 7) \n Invalid gift card length - maximum allowed length is 20 and minimum allowed length is 16. (errorcode 6)\n Invalid giftcard pin  - Some gift card pin numbers are invalid. Only digits are allowed (errorcode 10)\n Invalid Gift Card Pin Length - maximum allowed length is 20 and minimum allowed length is 4. (errorcode 10)\n Invalid gift card track2 length - maximum allowed length is 64 and minimum allowed length is 16. (errorcode 13)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEntity"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error. (errorCode 0)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEntity"
                }
              }
            }
          }
        },
        "x-codegen-request-body-name": "body"
      }
