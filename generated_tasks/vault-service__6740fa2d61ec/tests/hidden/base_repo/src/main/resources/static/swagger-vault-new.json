        "parameters": [
          {
            "name": "X-App-Name",
            "in": "header",
            "description": "Application name calling the end point,",
            "required": false,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Content-Type",
            "in": "header",
            "description": "Content type",
            "required": false,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "string",
              "enum": [
                "application/json"
              ]
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "api token is required as [Bearer TOKEN VALUE]",
            "required": true,
            "style": "simple",
            "explode": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "previewType",
