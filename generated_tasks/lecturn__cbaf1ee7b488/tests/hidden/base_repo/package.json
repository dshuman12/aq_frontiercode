{
  "name": "lecturn",
  "private": true,
  "version": "1.0.0",
  "description": "Self-hosted lecture hall for your video courses.",
  "workspaces": ["backend", "frontend"],
  "scripts": {
    "dev:backend": "bun --cwd backend run dev",
    "dev:frontend": "bun --cwd frontend run dev",
    "test": "bun run -r test",
    "lint": "bun run -r lint",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.1.0"
  }
}
