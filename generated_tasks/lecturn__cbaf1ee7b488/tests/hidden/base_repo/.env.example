# --- Database ---
POSTGRES_USER=lecturn
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lecturn
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgres://lecturn:change-me@localhost:5432/lecturn

# --- Redis / Queue ---
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380
TRANSCODE_CONCURRENCY=2
TRANSCODE_DISK_THRESHOLD_GB=5

# --- Backend (Fastify) ---
API_PORT=4000
API_HOST=0.0.0.0
API_LOG_LEVEL=info
API_CORS_ORIGIN=http://localhost:3000
API_PUBLIC_URL=http://localhost:4000
WEB_PUBLIC_URL=http://localhost:3000

# --- Auth ---
# Must be at least 32 characters. Generate with: openssl rand -hex 32
AUTH_SECRET=replace-me-with-a-32-char-secret-please-rotate

# --- Library ---
# Absolute path to the directory containing course folders.
# Defaults to the bundled `examples/sample-library` so a fresh checkout has
# something to play with — point it at your own collection when ready.
LIBRARY_ROOT=/absolute/path/to/lecturn/examples/sample-library

# Where transcoded HLS bundles get written. Each episode produces a
# subdirectory `<MEDIA_ROOT>/transcoded/<episodeId>/{master.m3u8, 480p/, 720p/, 1080p/}`.
MEDIA_ROOT=/absolute/path/to/lecturn/media

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
