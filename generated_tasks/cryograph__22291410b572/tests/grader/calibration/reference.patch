+    size_t count = 0;
+    struct Frame {
+        NodeId node;
+        size_t edge_idx;
+    };
+
+    std::stack<Frame> stk;
+    std::unordered_set<NodeId> on_path;
+    stk.push({src, 0});
+    on_path.insert(src);
+
+    while (!stk.empty()) {
+        auto& frame = stk.top();
+        auto& edges = g.out_edges(frame.node);
+
+        if (frame.edge_idx < edges.size() && stk.size() <= max_depth) {
+            NodeId next = edges[frame.edge_idx].dst;
+            frame.edge_idx++;
+
+            if (next == dst) {
+                count++;
+                if (count >= 1000) break;
+            } else if (!on_path.count(next)) {
+                on_path.insert(next);
+                stk.push({next, 0});
+            }
+        } else {
+            on_path.erase(frame.node);
+            stk.pop();
+        }
+    }
+    return count;
 }
 
