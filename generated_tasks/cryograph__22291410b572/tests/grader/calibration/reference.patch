+        std::queue<NodeId> q;
+        q.push(ids[i]);
+        dist[ids[i]] = 0;
+        while (!q.empty()) {
+            NodeId cur = q.front();
+            q.pop();
+            for (auto& e : g.out_edges(cur)) {
+                if (!dist.count(e.dst)) {
+                    dist[e.dst] = dist[cur] + 1;
+                    q.push(e.dst);
+                }
+            }
+        }
+        for (auto& [_, d] : dist) {
+            max_dist = std::max(max_dist, d);
