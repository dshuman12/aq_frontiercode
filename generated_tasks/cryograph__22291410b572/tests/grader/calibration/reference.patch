diff --git a/tests/test_query.cpp b/tests/test_query.cpp
index dd3f3fa..73e55d9 100644
--- a/tests/test_query.cpp
+++ b/tests/test_query.cpp
@@ -138,4 +138,42 @@ CRYO_TEST(Query, KHopZero) {
     g.add_edge(0, 1);
     auto n = k_hop_neighbors(g, 0, 0);
     assert_eq(n.size(), (size_t)0);
+}
+
+// ── Optimized count_paths + diameter_approx tests ──────────────────────────
+
+CRYO_TEST(Query, CountPathsDFS) {
+    Graph g(GraphType::Directed);
+    for (int i = 0; i < 4; i++) g.add_node_with_id(i);
+    g.add_edge(0, 1); g.add_edge(0, 2);
+    g.add_edge(1, 3); g.add_edge(2, 3);
+    size_t c = count_paths(g, 0, 3);
+    assert_eq(c, (size_t)2);
+}
+
+CRYO_TEST(Query, CountPathsNoPath) {
+    Graph g(GraphType::Directed);
+    g.add_node_with_id(0); g.add_node_with_id(1);
+    assert_eq(count_paths(g, 0, 1), (size_t)0);
+}
+
+CRYO_TEST(Query, CountPathsSameNode) {
+    Graph g(GraphType::Directed);
+    g.add_node_with_id(0);
+    assert_eq(count_paths(g, 0, 0), (size_t)1);
+}
+
+CRYO_TEST(Query, DiameterApproxPath) {
+    Graph g(GraphType::Undirected);
+    for (int i = 0; i < 5; i++) g.add_node_with_id(i);
+    g.add_edge(0, 1); g.add_edge(1, 2); g.add_edge(2, 3); g.add_edge(3, 4);
+    size_t d = graph_diameter_approx(g, 5);
+    assert_eq(d, (size_t)4);
+}
+
+CRYO_TEST(Query, DiameterApproxComplete) {
+    GraphGenerator gen(42);
+    auto g = gen.complete(6);
+    size_t d = graph_diameter_approx(g, 6);
+    assert_eq(d, (size_t)1);
 }
