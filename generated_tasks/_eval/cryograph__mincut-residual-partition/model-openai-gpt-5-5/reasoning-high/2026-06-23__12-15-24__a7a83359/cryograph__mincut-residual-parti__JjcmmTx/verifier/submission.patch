@@ -0,0 +1,96 @@
+#include "test_framework.hpp"
+#include "flow/flow.hpp"
+#include <unordered_set>
+
+using namespace cryo;
+using namespace cryo_test;
+
+static void assert_min_cut_invariants(const Graph& g, const MinCutResult& cut,
+                                      NodeId source, NodeId sink) {
+    assert_true(cut.source_side.count(source) == 1, "source must be on source side");
+    assert_true(cut.sink_side.count(sink) == 1, "sink must be on sink side");
+
+    for (auto id : g.node_ids()) {
+        bool in_source = cut.source_side.count(id) == 1;
+        bool in_sink = cut.sink_side.count(id) == 1;
+        assert_true(in_source != in_sink, "each node must be in exactly one side");
+    }
+
+    assert_eq(cut.source_side.size() + cut.sink_side.size(), g.node_count(),
+              "partition must include every node");
+
+    std::unordered_set<EdgeId> cut_edge_ids;
+    double cut_edge_total = 0.0;
+    for (const auto& edge : cut.cut_edges) {
+        assert_true(cut.source_side.count(edge.src) == 1, "cut edge source must be on source side");
+        assert_true(cut.sink_side.count(edge.dst) == 1, "cut edge destination must be on sink side");
+        assert_true(cut_edge_ids.insert(edge.id).second, "cut edges must not contain duplicates");
+        cut_edge_total += edge.weight;
+    }
+
+    double crossing_total = 0.0;
+    g.for_each_edge([&](const Edge& edge) {
+        if (cut.source_side.count(edge.src) == 1 && cut.sink_side.count(edge.dst) == 1) {
+            crossing_total += edge.weight;
+            assert_true(cut_edge_ids.count(edge.id) == 1, "all crossing edges must be listed");
+        }
+    });
+
+    assert_near(cut_edge_total, cut.cut_value);
+    assert_near(crossing_total, cut.cut_value);
+}
+
+CRYO_TEST(Flow, MinCutSaturatedEdgeDoesNotLeakSinkSide) {
+    Graph g(GraphType::Directed);
+    for (int i = 0; i < 4; i++) g.add_node_with_id(i);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(1, 2, 1.0);
+    g.add_edge(2, 3, 1.0);
+
+    auto cut = min_cut(g, 0, 3);
+
+    assert_min_cut_invariants(g, cut, 0, 3);
+    assert_near(cut.cut_value, 1.0);
+    assert_eq(cut.source_side.size(), (size_t)1);
+    assert_true(cut.source_side.count(0) == 1);
+    assert_true(cut.sink_side.count(1) == 1);
+    assert_true(cut.sink_side.count(2) == 1);
+    assert_true(cut.sink_side.count(3) == 1);
+}
+
+CRYO_TEST(Flow, MinCutUsesReverseResidualReachability) {
+    Graph g(GraphType::Directed);
+    for (int i = 0; i < 5; i++) g.add_node_with_id(i);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(1, 2, 1.0);
+    g.add_edge(2, 4, 1.0);
+    g.add_edge(0, 3, 1.0);
+    g.add_edge(3, 2, 1.0);
+
+    auto cut = min_cut(g, 0, 4);
+
+    assert_min_cut_invariants(g, cut, 0, 4);
+    assert_near(cut.cut_value, 1.0);
+    assert_true(cut.source_side.count(1) == 1, "node 1 is reachable through a reverse residual edge");
+    assert_true(cut.source_side.count(2) == 1);
+    assert_true(cut.source_side.count(3) == 1);
+    assert_true(cut.sink_side.count(4) == 1);
+}
+
+CRYO_TEST(Flow, MinCutDisconnectedNodesAreSinkSide) {
+    Graph g(GraphType::Directed);
+    for (int i = 0; i < 6; i++) g.add_node_with_id(i);
+    g.add_edge(0, 1, 2.0);
+    g.add_edge(1, 3, 2.0);
+    g.add_edge(4, 5, 7.0);
+
+    auto cut = min_cut(g, 0, 3);
+
+    assert_min_cut_invariants(g, cut, 0, 3);
+    assert_near(cut.cut_value, 2.0);
+    assert_true(cut.source_side.count(0) == 1);
+    assert_true(cut.sink_side.count(1) == 1);
+    assert_true(cut.sink_side.count(3) == 1);
+    assert_true(cut.sink_side.count(4) == 1);
+    assert_true(cut.sink_side.count(5) == 1);
+}
