index 0000000..957a2c9
--- /dev/null
+++ b/repo/tests/test_flow.cpp
@@ -0,0 +1,99 @@
+#include "test_framework.hpp"
+#include "flow/flow.hpp"
+#include <unordered_set>
+
+using namespace cryo;
+using namespace cryo_test;
+
+namespace {
+
+void assert_min_cut_consistent(const Graph& g, const MinCutResult& cut,
+                               NodeId source, NodeId sink) {
+    assert_true(cut.source_side.count(source) == 1, "source must be on source side");
+    assert_true(cut.sink_side.count(sink) == 1, "sink must be on sink side");
+
+    for (NodeId node : g.node_ids()) {
+        bool in_source = cut.source_side.count(node) == 1;
+        bool in_sink = cut.sink_side.count(node) == 1;
+        assert_ne(in_source, in_sink, "node must be in exactly one partition");
+    }
+
+    std::unordered_set<EdgeId> expected_edges;
+    double expected_capacity = 0.0;
+    g.for_each_edge([&](const Edge& e) {
+        if (cut.source_side.count(e.src) == 1 && cut.sink_side.count(e.dst) == 1) {
+            expected_edges.insert(e.id);
+            expected_capacity += e.weight;
+        }
+    });
+
+    std::unordered_set<EdgeId> actual_edges;
+    double actual_capacity = 0.0;
+    for (const Edge& e : cut.cut_edges) {
+        assert_true(cut.source_side.count(e.src) == 1, "cut edge source must be on source side");
+        assert_true(cut.sink_side.count(e.dst) == 1, "cut edge destination must be on sink side");
+        actual_edges.insert(e.id);
+        actual_capacity += e.weight;
+    }
+
+    assert_eq(actual_edges.size(), expected_edges.size(), "cut edge count");
+    for (EdgeId edge_id : expected_edges) {
+        assert_true(actual_edges.count(edge_id) == 1, "missing cut edge");
+    }
+    assert_near(actual_capacity, cut.cut_value, 1e-9, "cut edge capacity must equal cut value");
+    assert_near(expected_capacity, cut.cut_value, 1e-9, "crossing capacity must equal cut value");
+}
+
+} // namespace
+
+CRYO_TEST(Flow, MinCutSaturatedEdgeDoesNotLeakSinkSide) {
+    Graph g(GraphType::Directed);
+    for (int i = 0; i < 3; i++) g.add_node_with_id(i);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(1, 2, 1.0);
+
+    auto cut = min_cut(g, 0, 2);
+
+    assert_near(cut.cut_value, 1.0);
+    assert_eq(cut.source_side.size(), (size_t)1);
+    assert_true(cut.source_side.count(0) == 1);
+    assert_true(cut.sink_side.count(1) == 1);
+    assert_true(cut.sink_side.count(2) == 1);
+    assert_min_cut_consistent(g, cut, 0, 2);
+}
+
+CRYO_TEST(Flow, MinCutPartitionAndCutEdgesMatchMaxFlow) {
+    Graph g(GraphType::Directed);
+    for (int i = 0; i < 5; i++) g.add_node_with_id(i);
+    g.add_edge(0, 1, 3.0);
+    g.add_edge(0, 2, 2.0);
+    g.add_edge(1, 2, 1.0);
+    g.add_edge(1, 3, 2.0);
+    g.add_edge(2, 3, 4.0);
+    g.add_edge(3, 4, 3.0);
+
+    auto cut = min_cut(g, 0, 4);
+
+    assert_near(cut.cut_value, max_flow_value(g, 0, 4));
+    assert_near(cut.cut_value, 3.0);
+    assert_min_cut_consistent(g, cut, 0, 4);
+}
+
+CRYO_TEST(Flow, MinCutDisconnectedNodesAreOnSinkSide) {
+    Graph g(GraphType::Directed);
+    for (int i = 0; i < 6; i++) g.add_node_with_id(i);
+    g.add_edge(0, 1, 2.0);
+    g.add_edge(1, 3, 2.0);
+    g.add_edge(4, 5, 7.0);
+
+    auto cut = min_cut(g, 0, 3);
+
+    assert_near(cut.cut_value, 2.0);
+    assert_true(cut.source_side.count(0) == 1);
+    assert_true(cut.sink_side.count(1) == 1);
+    assert_true(cut.sink_side.count(2) == 1);
+    assert_true(cut.sink_side.count(3) == 1);
+    assert_true(cut.sink_side.count(4) == 1);
+    assert_true(cut.sink_side.count(5) == 1);
+    assert_min_cut_consistent(g, cut, 0, 3);
+}
