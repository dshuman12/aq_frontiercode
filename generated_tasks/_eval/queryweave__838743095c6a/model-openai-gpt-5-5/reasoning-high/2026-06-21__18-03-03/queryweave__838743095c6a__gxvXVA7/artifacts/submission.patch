@@ -0,0 +1,210 @@
+from __future__ import annotations
+
+import pytest
+
+from queryweave.parser.ast_nodes import (
+    AggregateExpr,
+    AliasExpr,
+    BetweenExpr,
+    BinaryExpr,
+    CaseExpr,
+    ColumnDef,
+    ColumnRef,
+    CreateTableStmt,
+    DeleteStmt,
+    DropTableStmt,
+    FunctionCall,
+    InsertStmt,
+    JoinClause,
+    LikeExpr,
+    LiteralExpr,
+    SelectStmt,
+    StarExpr,
+    UnionStmt,
+    UpdateStmt,
+    WindowExpr,
+)
+from queryweave.parser.parser import ParserError, parse
+
+
+def test_simple_and_aliased_select_list() -> None:
+    stmt = parse("SELECT id, name AS label, users.* FROM users")
+
+    assert isinstance(stmt, SelectStmt)
+    assert isinstance(stmt.columns[0], ColumnRef)
+    assert stmt.columns[0].name == "id"
+    assert isinstance(stmt.columns[1], AliasExpr)
+    assert stmt.columns[1].alias == "label"
+    assert isinstance(stmt.columns[2], StarExpr)
+    assert stmt.columns[2].table == "users"
+    assert stmt.from_table is not None
+    assert stmt.from_table.name == "users"
+
+
+def test_where_expression_precedence() -> None:
+    stmt = parse("SELECT * FROM users WHERE active = true AND age >= 18 OR admin = true")
+
+    assert isinstance(stmt, SelectStmt)
+    assert stmt.where is not None
+    condition = stmt.where.condition
+    assert isinstance(condition, BinaryExpr)
+    assert condition.operator == "OR"
+    assert isinstance(condition.left, BinaryExpr)
+    assert condition.left.operator == "AND"
+
+
+def test_joins_group_having_order_limit_offset() -> None:
+    stmt = parse(
+        "SELECT u.id, count(o.id) AS orders "
+        "FROM users u LEFT JOIN orders o ON u.id = o.user_id "
+        "WHERE u.active = true GROUP BY u.id HAVING count(o.id) > 1 "
+        "ORDER BY orders DESC LIMIT 10 OFFSET 5"
+    )
+
+    assert isinstance(stmt, SelectStmt)
+    assert stmt.from_table is not None
+    assert stmt.from_table.alias == "u"
+    assert len(stmt.joins) == 1
+    join = stmt.joins[0]
+    assert isinstance(join, JoinClause)
+    assert join.join_type == "LEFT"
+    assert join.table.alias == "o"
+    assert join.condition is not None
+    assert stmt.group_by is not None
+    assert len(stmt.group_by.columns) == 1
+    assert stmt.having is not None
+    assert stmt.order_by is not None
+    assert stmt.order_by.items[0].ascending is False
+    assert stmt.limit is not None
+    assert stmt.limit.limit == 10
+    assert stmt.limit.offset == 5
+
+
+def test_aggregate_and_function_calls() -> None:
+    stmt = parse("SELECT count(*), sum(DISTINCT amount), lower(name) FROM orders")
+
+    assert isinstance(stmt, SelectStmt)
+    assert isinstance(stmt.columns[0], AggregateExpr)
+    assert stmt.columns[0].function == "COUNT"
+    assert isinstance(stmt.columns[0].arg, StarExpr)
+    assert isinstance(stmt.columns[1], AggregateExpr)
+    assert stmt.columns[1].distinct is True
+    assert isinstance(stmt.columns[2], FunctionCall)
+    assert stmt.columns[2].name == "lower"
+
+
+def test_case_between_and_like_expressions() -> None:
+    stmt = parse(
+        "SELECT CASE WHEN age BETWEEN 18 AND 64 THEN 'adult' ELSE 'other' END AS bucket "
+        "FROM users WHERE name NOT LIKE 'A%'"
+    )
+
+    assert isinstance(stmt, SelectStmt)
+    case_alias = stmt.columns[0]
+    assert isinstance(case_alias, AliasExpr)
+    assert isinstance(case_alias.expr, CaseExpr)
+    when_condition = case_alias.expr.when_clauses[0].condition
+    assert isinstance(when_condition, BetweenExpr)
+    assert stmt.where is not None
+    assert isinstance(stmt.where.condition, LikeExpr)
+    assert stmt.where.condition.negated is True
+
+
+def test_window_call() -> None:
+    stmt = parse(
+        "SELECT sum(amount) OVER (PARTITION BY user_id ORDER BY created_at "
+        "ROWS BETWEEN 1 PRECEDING AND CURRENT ROW) AS rolling FROM orders"
+    )
+
+    assert isinstance(stmt, SelectStmt)
+    alias = stmt.columns[0]
+    assert isinstance(alias, AliasExpr)
+    assert isinstance(alias.expr, WindowExpr)
+    assert isinstance(alias.expr.function, AggregateExpr)
+    assert len(alias.expr.partition_by) == 1
+    assert alias.expr.order_by is not None
+    assert alias.expr.frame is not None
+    assert alias.expr.frame.mode == "ROWS"
+    assert alias.expr.frame.start is not None
+    assert alias.expr.frame.start.offset == 1
+
+
+def test_union_and_union_all() -> None:
+    stmt = parse(
+        "SELECT id FROM users UNION ALL SELECT id FROM admins UNION SELECT id FROM guests"
+    )
+
+    assert isinstance(stmt, UnionStmt)
+    assert stmt.all is True
+    assert isinstance(stmt.left, SelectStmt)
+    assert isinstance(stmt.right, UnionStmt)
+    assert stmt.right.all is False
+
+
+def test_insert_values() -> None:
+    stmt = parse("INSERT INTO users (id, name) VALUES (1, 'Ada'), (2, 'Lin')")
+
+    assert isinstance(stmt, InsertStmt)
+    assert stmt.table.name == "users"
+    assert stmt.columns == ["id", "name"]
+    assert len(stmt.values) == 2
+    assert isinstance(stmt.values[0][0], LiteralExpr)
+    assert stmt.values[0][0].value == 1
+
+
+def test_update_statement() -> None:
+    stmt = parse("UPDATE users SET name = 'Ada', age = age + 1 WHERE id = 1")
+
+    assert isinstance(stmt, UpdateStmt)
+    assert stmt.table.name == "users"
+    assert len(stmt.assignments) == 2
+    assert stmt.assignments[0].column == "name"
+    assert stmt.where is not None
+
+
+def test_delete_statement() -> None:
+    stmt = parse("DELETE FROM users WHERE active IS NOT NULL")
+
+    assert isinstance(stmt, DeleteStmt)
+    assert stmt.table.name == "users"
+    assert stmt.where is not None
+
+
+def test_create_table_statement() -> None:
+    stmt = parse(
+        "CREATE TABLE IF NOT EXISTS users ("
+        "id INT PRIMARY KEY, name VARCHAR(255) NOT NULL, score FLOAT DEFAULT 0.0)"
+    )
+
+    assert isinstance(stmt, CreateTableStmt)
+    assert stmt.if_not_exists is True
+    assert stmt.table.name == "users"
+    assert len(stmt.columns) == 3
+    id_col = stmt.columns[0]
+    assert isinstance(id_col, ColumnDef)
+    assert id_col.primary_key is True
+    assert stmt.columns[1].data_type == "VARCHAR(255)"
+    assert stmt.columns[1].nullable is False
+    assert stmt.columns[2].default is not None
+
+
+def test_drop_table_statement() -> None:
+    stmt = parse("DROP TABLE IF EXISTS users")
+
+    assert isinstance(stmt, DropTableStmt)
+    assert stmt.if_exists is True
+    assert stmt.table.name == "users"
+
+
+@pytest.mark.parametrize(
+    "query",
+    [
+        "SELECT FROM users",
+        "SELECT id FROM users WHERE",
+        "INSERT INTO users VALUES (1,)",
+        "CREATE TABLE users (id)",
+    ],
+)
+def test_malformed_input_raises_parser_error(query: str) -> None:
+    with pytest.raises(ParserError):
+        parse(query)
