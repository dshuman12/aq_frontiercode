+from __future__ import annotations
+
+import pytest
+
+from queryweave.parser.ast_nodes import (
+    AggregateExpr,
+    AliasExpr,
+    BetweenExpr,
+    BinaryExpr,
+    CaseExpr,
+    ColumnRef,
+    CreateTableStmt,
+    DeleteStmt,
+    DropTableStmt,
+    InsertStmt,
+    IsNullExpr,
+    LikeExpr,
+    LiteralExpr,
+    SelectStmt,
+    StarExpr,
+    UnaryExpr,
+    UnionStmt,
+    UpdateStmt,
+    WindowExpr,
+)
+from queryweave.parser.parser import parse
+from queryweave.utils.errors import ParseError
+
+
+def test_parse_simple_and_aliased_select_list() -> None:
+    stmt = parse("SELECT id, name AS username, age years FROM users")
+
+    assert isinstance(stmt, SelectStmt)
+    assert isinstance(stmt.columns[0], ColumnRef)
+    assert stmt.columns[0].name == "id"
+    assert isinstance(stmt.columns[1], AliasExpr)
+    assert stmt.columns[1].alias == "username"
+    assert isinstance(stmt.columns[2], AliasExpr)
+    assert stmt.columns[2].alias == "years"
+    assert stmt.from_table is not None
+    assert stmt.from_table.name == "users"
+
+
+def test_parse_where_expression_precedence_and_predicates() -> None:
+    stmt = parse(
+        "SELECT * FROM users "
+        "WHERE NOT active OR age + 1 * 2 >= 21 AND name LIKE 'A%'"
+    )
+
+    assert isinstance(stmt, SelectStmt)
+    assert stmt.where is not None
+    condition = stmt.where.condition
+    assert isinstance(condition, BinaryExpr)
+    assert condition.operator == "OR"
+    assert isinstance(condition.left, UnaryExpr)
+    assert condition.left.operator == "NOT"
+    assert isinstance(condition.right, BinaryExpr)
+    assert condition.right.operator == "AND"
+    assert isinstance(condition.right.right, LikeExpr)
+
+    comparison = condition.right.left
+    assert isinstance(comparison, BinaryExpr)
+    assert comparison.operator == ">="
+    assert isinstance(comparison.left, BinaryExpr)
+    assert comparison.left.operator == "+"
+    assert isinstance(comparison.left.right, BinaryExpr)
+    assert comparison.left.right.operator == "*"
+
+
+def test_parse_joins() -> None:
+    stmt = parse(
+        "SELECT u.id, o.total FROM users u "
+        "LEFT JOIN orders o ON u.id = o.user_id"
+    )
+
+    assert isinstance(stmt, SelectStmt)
+    assert stmt.from_table is not None
+    assert stmt.from_table.name == "users"
+    assert stmt.from_table.alias == "u"
+    assert len(stmt.joins) == 1
+    join = stmt.joins[0]
+    assert join.join_type == "LEFT"
+    assert join.table.name == "orders"
+    assert join.table.alias == "o"
+    assert isinstance(join.condition, BinaryExpr)
+    assert join.condition.operator == "="
+
+
+def test_parse_group_by_and_having() -> None:
+    stmt = parse(
+        "SELECT user_id, COUNT(*) AS total FROM orders "
+        "GROUP BY user_id HAVING COUNT(*) > 1"
+    )
+
+    assert isinstance(stmt, SelectStmt)
+    assert stmt.group_by is not None
+    assert len(stmt.group_by.columns) == 1
+    assert stmt.having is not None
+    assert isinstance(stmt.having.condition, BinaryExpr)
+    total = stmt.columns[1]
+    assert isinstance(total, AliasExpr)
+    assert isinstance(total.expr, AggregateExpr)
+    assert total.expr.function == "COUNT"
+    assert isinstance(total.expr.arg, StarExpr)
+
+
+def test_parse_order_by_limit_and_offset() -> None:
+    stmt = parse("SELECT id FROM users ORDER BY created_at DESC, id ASC LIMIT 10 OFFSET 5")
+
+    assert isinstance(stmt, SelectStmt)
+    assert stmt.order_by is not None
+    assert len(stmt.order_by.items) == 2
+    assert stmt.order_by.items[0].ascending is False
+    assert stmt.order_by.items[1].ascending is True
+    assert stmt.limit is not None
+    assert stmt.limit.limit == 10
+    assert stmt.limit.offset == 5
+
+
+def test_parse_aggregate_calls() -> None:
+    stmt = parse("SELECT COUNT(DISTINCT user_id) AS users, SUM(amount) total FROM orders")
+
+    assert isinstance(stmt, SelectStmt)
+    count_alias = stmt.columns[0]
+    sum_alias = stmt.columns[1]
+    assert isinstance(count_alias, AliasExpr)
+    assert isinstance(count_alias.expr, AggregateExpr)
+    assert count_alias.expr.function == "COUNT"
+    assert count_alias.expr.distinct is True
+    assert isinstance(sum_alias, AliasExpr)
+    assert isinstance(sum_alias.expr, AggregateExpr)
+    assert sum_alias.expr.function == "SUM"
+
+
+def test_parse_case_expression() -> None:
+    stmt = parse(
+        "SELECT CASE WHEN score >= 90 THEN 'A' ELSE 'B' END grade FROM scores"
+    )
+
+    assert isinstance(stmt, SelectStmt)
+    grade = stmt.columns[0]
+    assert isinstance(grade, AliasExpr)
+    assert isinstance(grade.expr, CaseExpr)
+    assert len(grade.expr.when_clauses) == 1
+    assert isinstance(grade.expr.when_clauses[0].condition, BinaryExpr)
+    assert isinstance(grade.expr.else_expr, LiteralExpr)
+    assert grade.expr.else_expr.value == "B"
+
+
+def test_parse_window_call() -> None:
+    stmt = parse(
+        "SELECT SUM(amount) OVER ("
+        "PARTITION BY user_id ORDER BY created_at "
+        "ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW"
+        ") AS running FROM orders"
+    )
+
+    assert isinstance(stmt, SelectStmt)
+    running = stmt.columns[0]
+    assert isinstance(running, AliasExpr)
+    assert isinstance(running.expr, WindowExpr)
+    assert isinstance(running.expr.function, AggregateExpr)
+    assert running.expr.function.function == "SUM"
+    assert len(running.expr.partition_by) == 1
+    assert running.expr.order_by is not None
+    assert running.expr.frame is not None
+    assert running.expr.frame.mode == "ROWS"
+    assert running.expr.frame.start is not None
+    assert running.expr.frame.start.bound_type == "UNBOUNDED PRECEDING"
+    assert running.expr.frame.end is not None
+    assert running.expr.frame.end.bound_type == "CURRENT ROW"
+
+
+def test_parse_union_and_union_all() -> None:
+    stmt = parse("SELECT id FROM active_users UNION ALL SELECT id FROM archived_users")
+
+    assert isinstance(stmt, UnionStmt)
+    assert stmt.all is True
+    assert isinstance(stmt.left, SelectStmt)
+    assert isinstance(stmt.right, SelectStmt)
+
+
+def test_parse_insert_values() -> None:
+    stmt = parse("INSERT INTO users (id, name) VALUES (1, 'Ada'), (2, 'Grace')")
+
+    assert isinstance(stmt, InsertStmt)
+    assert stmt.table.name == "users"
+    assert stmt.columns == ["id", "name"]
+    assert len(stmt.values) == 2
+    assert stmt.values[0][0].value == 1
+    assert stmt.values[1][1].value == "Grace"
+
+
+def test_parse_update() -> None:
+    stmt = parse("UPDATE users SET name = 'Ada', age = age + 1 WHERE id = 1")
+
+    assert isinstance(stmt, UpdateStmt)
+    assert stmt.table.name == "users"
+    assert len(stmt.assignments) == 2
+    assert stmt.assignments[0].column == "name"
+    assert isinstance(stmt.assignments[1].value, BinaryExpr)
+    assert stmt.where is not None
+
+
+def test_parse_delete() -> None:
+    stmt = parse("DELETE FROM users WHERE deleted_at IS NULL")
+
+    assert isinstance(stmt, DeleteStmt)
+    assert stmt.table.name == "users"
+    assert stmt.where is not None
+    assert isinstance(stmt.where.condition, IsNullExpr)
+
+
+def test_parse_create_table() -> None:
+    stmt = parse(
+        "CREATE TABLE IF NOT EXISTS users ("
+        "id INTEGER PRIMARY KEY, name TEXT NOT NULL, age INTEGER DEFAULT 0"
+        ")"
+    )
+
+    assert isinstance(stmt, CreateTableStmt)
+    assert stmt.if_not_exists is True
+    assert stmt.table.name == "users"
+    assert len(stmt.columns) == 3
+    assert stmt.columns[0].primary_key is True
+    assert stmt.columns[1].nullable is False
+    assert stmt.columns[2].default is not None
+    assert stmt.columns[2].default.value == 0
+
+
+def test_parse_drop_table() -> None:
+    stmt = parse("DROP TABLE IF EXISTS users")
+
+    assert isinstance(stmt, DropTableStmt)
+    assert stmt.if_exists is True
+    assert stmt.table.name == "users"
+
+
+def test_parse_between_and_in_predicates() -> None:
+    stmt = parse("SELECT * FROM users WHERE age BETWEEN 18 AND 30 AND id NOT IN (1, 2)")
+
+    assert isinstance(stmt, SelectStmt)
+    assert stmt.where is not None
+    condition = stmt.where.condition
+    assert isinstance(condition, BinaryExpr)
+    assert condition.operator == "AND"
+    assert isinstance(condition.left, BetweenExpr)
+    assert condition.left.negated is False
+    assert condition.right.negated is True
+
+
+@pytest.mark.parametrize(
+    "query",
+    [
+        "SELECT FROM users",
+        "SELECT * FROM users LEFT JOIN orders",
+        "INSERT INTO users (id) (1)",
+    ],
+)
+def test_malformed_input_raises_parse_error(query: str) -> None:
+    with pytest.raises(ParseError):
+        parse(query)
