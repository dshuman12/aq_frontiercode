@@ -0,0 +1,213 @@
+from __future__ import annotations
+
+import pytest
+
+from queryweave.parser.ast_nodes import (
+    AggregateExpr,
+    AliasExpr,
+    BinaryExpr,
+    CaseExpr,
+    ColumnRef,
+    CreateTableStmt,
+    DeleteStmt,
+    DropTableStmt,
+    FunctionCall,
+    InsertStmt,
+    LiteralExpr,
+    SelectStmt,
+    StarExpr,
+    UnaryExpr,
+    UnionStmt,
+    UpdateStmt,
+    WindowExpr,
+)
+from queryweave.parser.lexer import Lexer, TokenStream
+from queryweave.parser.parser import Parser, ParserError, parse
+
+
+def test_parse_simple_and_aliased_select_list() -> None:
+    stmt = parse("SELECT id, name AS username, email address, users.* FROM users")
+
+    assert isinstance(stmt, SelectStmt)
+    assert stmt.from_table is not None
+    assert stmt.from_table.name == "users"
+    assert stmt.columns[0] == ColumnRef(name="id")
+    assert stmt.columns[1] == AliasExpr(expr=ColumnRef(name="name"), alias="username")
+    assert stmt.columns[2] == AliasExpr(expr=ColumnRef(name="email"), alias="address")
+    assert stmt.columns[3] == StarExpr(table="users")
+
+
+def test_parser_accepts_lexer_and_token_stream() -> None:
+    lexer_stmt = Parser(Lexer("SELECT id FROM users")).parse()
+    stream_stmt = Parser(TokenStream(Lexer("SELECT id FROM users").tokenize())).parse()
+
+    assert isinstance(lexer_stmt, SelectStmt)
+    assert isinstance(stream_stmt, SelectStmt)
+    assert lexer_stmt.from_table is not None
+    assert stream_stmt.from_table is not None
+    assert lexer_stmt.from_table.name == stream_stmt.from_table.name == "users"
+
+
+def test_where_expression_precedence() -> None:
+    stmt = parse("SELECT * FROM t WHERE NOT a = 1 OR b = 2 AND c + 3 * -d >= 10")
+
+    assert isinstance(stmt, SelectStmt)
+    assert stmt.where is not None
+    root = stmt.where.condition
+    assert isinstance(root, BinaryExpr)
+    assert root.operator == "OR"
+    assert isinstance(root.left, UnaryExpr)
+    assert root.left.operator == "NOT"
+    assert isinstance(root.right, BinaryExpr)
+    assert root.right.operator == "AND"
+    assert isinstance(root.right.right, BinaryExpr)
+    assert root.right.right.operator == ">="
+
+
+def test_joins_group_having_order_limit_offset() -> None:
+    stmt = parse(
+        "SELECT u.name, SUM(o.amount) AS total "
+        "FROM users u LEFT JOIN orders o ON u.id = o.user_id "
+        "WHERE o.amount > 0 "
+        "GROUP BY u.name "
+        "HAVING SUM(o.amount) > 100 "
+        "ORDER BY total DESC LIMIT 10 OFFSET 5"
+    )
+
+    assert isinstance(stmt, SelectStmt)
+    assert stmt.from_table is not None
+    assert stmt.from_table.alias == "u"
+    assert len(stmt.joins) == 1
+    assert stmt.joins[0].join_type == "LEFT"
+    assert stmt.joins[0].table.alias == "o"
+    assert isinstance(stmt.joins[0].condition, BinaryExpr)
+    assert stmt.group_by is not None
+    assert stmt.group_by.columns == [ColumnRef(name="name", table="u")]
+    assert stmt.having is not None
+    assert isinstance(stmt.having.condition, BinaryExpr)
+    assert stmt.order_by is not None
+    assert stmt.order_by.items[0].ascending is False
+    assert stmt.limit is not None
+    assert stmt.limit.limit == 10
+    assert stmt.limit.offset == 5
+
+
+def test_aggregate_and_function_calls() -> None:
+    stmt = parse("SELECT COUNT(*), SUM(DISTINCT amount), COALESCE(name, 'n/a') FROM orders")
+
+    assert isinstance(stmt, SelectStmt)
+    count_expr = stmt.columns[0]
+    sum_expr = stmt.columns[1]
+    coalesce_expr = stmt.columns[2]
+    assert isinstance(count_expr, AggregateExpr)
+    assert count_expr.function == "COUNT"
+    assert isinstance(count_expr.arg, StarExpr)
+    assert isinstance(sum_expr, AggregateExpr)
+    assert sum_expr.function == "SUM"
+    assert sum_expr.distinct is True
+    assert isinstance(coalesce_expr, FunctionCall)
+    assert coalesce_expr.name == "COALESCE"
+    assert coalesce_expr.args[1] == LiteralExpr(value="n/a", literal_type="string")
+
+
+def test_case_expression() -> None:
+    stmt = parse("SELECT CASE WHEN score >= 90 THEN 'A' ELSE 'B' END AS grade FROM exams")
+
+    assert isinstance(stmt, SelectStmt)
+    alias = stmt.columns[0]
+    assert isinstance(alias, AliasExpr)
+    case = alias.expr
+    assert isinstance(case, CaseExpr)
+    assert len(case.when_clauses) == 1
+    assert isinstance(case.when_clauses[0].condition, BinaryExpr)
+    assert case.else_expr == LiteralExpr(value="B", literal_type="string")
+
+
+def test_window_call() -> None:
+    stmt = parse(
+        "SELECT SUM(amount) OVER ("
+        "PARTITION BY user_id "
+        "ORDER BY created_at "
+        "ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW"
+        ") AS running FROM orders"
+    )
+
+    assert isinstance(stmt, SelectStmt)
+    alias = stmt.columns[0]
+    assert isinstance(alias, AliasExpr)
+    window = alias.expr
+    assert isinstance(window, WindowExpr)
+    assert isinstance(window.function, AggregateExpr)
+    assert window.partition_by == [ColumnRef(name="user_id")]
+    assert window.order_by is not None
+    assert window.order_by[0].expr == ColumnRef(name="created_at")
+    assert window.frame is not None
+    assert window.frame.mode == "ROWS"
+    assert window.frame.start is not None
+    assert window.frame.start.bound_type == "UNBOUNDED PRECEDING"
+    assert window.frame.end is not None
+    assert window.frame.end.bound_type == "CURRENT ROW"
+
+
+def test_union_and_union_all() -> None:
+    stmt = parse("SELECT id FROM a UNION ALL SELECT id FROM b UNION SELECT id FROM c")
+
+    assert isinstance(stmt, UnionStmt)
+    assert stmt.all is True
+    assert stmt.left.from_table is not None
+    assert stmt.left.from_table.name == "a"
+    assert isinstance(stmt.right, UnionStmt)
+    assert stmt.right.all is False
+    assert stmt.right.left.from_table is not None
+    assert stmt.right.left.from_table.name == "b"
+
+
+def test_insert_update_delete() -> None:
+    insert = parse("INSERT INTO users (id, name) VALUES (1, 'Ada'), (2, 'Lin')")
+    update = parse("UPDATE users SET name = 'Ada', age = age + 1 WHERE id = 1")
+    delete = parse("DELETE FROM users WHERE id IN (1, 2)")
+
+    assert isinstance(insert, InsertStmt)
+    assert insert.table.name == "users"
+    assert insert.columns == ["id", "name"]
+    assert len(insert.values) == 2
+    assert isinstance(update, UpdateStmt)
+    assert [assignment.column for assignment in update.assignments] == ["name", "age"]
+    assert update.where is not None
+    assert isinstance(delete, DeleteStmt)
+    assert delete.where is not None
+
+
+def test_create_and_drop_table() -> None:
+    create = parse(
+        "CREATE TABLE IF NOT EXISTS users ("
+        "id INTEGER PRIMARY KEY, "
+        "name TEXT NOT NULL, "
+        "age INTEGER DEFAULT 0"
+        ")"
+    )
+    drop = parse("DROP TABLE IF EXISTS users")
+
+    assert isinstance(create, CreateTableStmt)
+    assert create.if_not_exists is True
+    assert create.table.name == "users"
+    assert create.columns[0].primary_key is True
+    assert create.columns[1].nullable is False
+    assert create.columns[2].default == LiteralExpr(value=0, literal_type="integer")
+    assert isinstance(drop, DropTableStmt)
+    assert drop.if_exists is True
+    assert drop.table.name == "users"
+
+
+@pytest.mark.parametrize(
+    "query",
+    [
+        "SELECT FROM users",
+        "SELECT * FROM users LEFT JOIN orders",
+        "INSERT INTO users VALUES (1, 'Ada'",
+        "CREATE TABLE broken (id)",
+    ],
+)
+def test_malformed_input_raises_parser_error(query: str) -> None:
+    with pytest.raises(ParserError):
+        parse(query)
