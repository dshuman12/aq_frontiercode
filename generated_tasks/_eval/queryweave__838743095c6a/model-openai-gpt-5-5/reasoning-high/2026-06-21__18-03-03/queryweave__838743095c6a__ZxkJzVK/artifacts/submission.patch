@@ -0,0 +1,246 @@
+from __future__ import annotations
+
+import pytest
+
+from queryweave.parser.ast_nodes import (
+    AggregateExpr,
+    AliasExpr,
+    BetweenExpr,
+    BinaryExpr,
+    CaseExpr,
+    ColumnRef,
+    CreateTableStmt,
+    DeleteStmt,
+    DropTableStmt,
+    FunctionCall,
+    InsertStmt,
+    JoinClause,
+    LikeExpr,
+    LiteralExpr,
+    SelectStmt,
+    StarExpr,
+    UnaryExpr,
+    UnionStmt,
+    UpdateStmt,
+    WindowExpr,
+)
+from queryweave.parser.lexer import Lexer
+from queryweave.parser.parser import Parser, parse
+from queryweave.utils.errors import ParseError
+
+
+def test_parse_simple_and_aliased_select_list() -> None:
+    stmt = parse("SELECT id, name AS username, age years FROM users")
+
+    assert isinstance(stmt, SelectStmt)
+    assert isinstance(stmt.columns[0], ColumnRef)
+    assert stmt.columns[0].name == "id"
+    assert isinstance(stmt.columns[1], AliasExpr)
+    assert stmt.columns[1].alias == "username"
+    assert isinstance(stmt.columns[2], AliasExpr)
+    assert stmt.columns[2].alias == "years"
+    assert stmt.from_table is not None
+    assert stmt.from_table.name == "users"
+
+
+def test_parser_accepts_lexer_instance() -> None:
+    stmt = Parser(Lexer("SELECT * FROM users")).parse()
+
+    assert isinstance(stmt, SelectStmt)
+    assert isinstance(stmt.columns[0], StarExpr)
+
+
+def test_parse_where_expression_precedence() -> None:
+    stmt = parse("SELECT * FROM users WHERE NOT active OR age + 1 * 2 >= 21 AND name LIKE 'A%'")
+
+    assert isinstance(stmt, SelectStmt)
+    assert stmt.where is not None
+    condition = stmt.where.condition
+    assert isinstance(condition, BinaryExpr)
+    assert condition.operator == "OR"
+    assert isinstance(condition.left, UnaryExpr)
+    assert isinstance(condition.right, BinaryExpr)
+    assert condition.right.operator == "AND"
+    assert isinstance(condition.right.right, LikeExpr)
+
+
+def test_parse_join_group_having_order_limit_offset() -> None:
+    stmt = parse(
+        "SELECT u.name, COUNT(o.id) AS orders "
+        "FROM users u LEFT JOIN orders o ON u.id = o.user_id "
+        "WHERE u.active = TRUE "
+        "GROUP BY u.name HAVING COUNT(o.id) > 1 "
+        "ORDER BY orders DESC LIMIT 10 OFFSET 5"
+    )
+
+    assert isinstance(stmt, SelectStmt)
+    assert stmt.from_table is not None
+    assert stmt.from_table.alias == "u"
+    assert len(stmt.joins) == 1
+    join = stmt.joins[0]
+    assert isinstance(join, JoinClause)
+    assert join.join_type == "LEFT"
+    assert join.table.alias == "o"
+    assert join.condition is not None
+    assert stmt.group_by is not None
+    assert len(stmt.group_by.columns) == 1
+    assert stmt.having is not None
+    assert stmt.order_by is not None
+    assert stmt.order_by.items[0].ascending is False
+    assert stmt.limit is not None
+    assert stmt.limit.limit == 10
+    assert stmt.limit.offset == 5
+
+
+def test_parse_aggregate_calls() -> None:
+    stmt = parse("SELECT COUNT(*), SUM(DISTINCT amount), AVG(score) FROM metrics")
+
+    assert isinstance(stmt, SelectStmt)
+    count = stmt.columns[0]
+    total = stmt.columns[1]
+    average = stmt.columns[2]
+    assert isinstance(count, AggregateExpr)
+    assert count.function == "COUNT"
+    assert isinstance(count.arg, StarExpr)
+    assert isinstance(total, AggregateExpr)
+    assert total.distinct is True
+    assert isinstance(average, AggregateExpr)
+
+
+def test_parse_case_expression() -> None:
+    stmt = parse("SELECT CASE WHEN age >= 18 THEN 'adult' ELSE 'minor' END AS bucket FROM users")
+
+    assert isinstance(stmt, SelectStmt)
+    assert isinstance(stmt.columns[0], AliasExpr)
+    case = stmt.columns[0].expr
+    assert isinstance(case, CaseExpr)
+    assert len(case.when_clauses) == 1
+    assert isinstance(case.else_expr, LiteralExpr)
+    assert case.else_expr.value == "minor"
+
+
+def test_parse_window_call() -> None:
+    stmt = parse(
+        "SELECT SUM(amount) OVER ("
+        "PARTITION BY account_id ORDER BY created_at "
+        "ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW"
+        ") AS running_total FROM payments"
+    )
+
+    assert isinstance(stmt, SelectStmt)
+    assert isinstance(stmt.columns[0], AliasExpr)
+    window = stmt.columns[0].expr
+    assert isinstance(window, WindowExpr)
+    assert isinstance(window.function, AggregateExpr)
+    assert len(window.partition_by) == 1
+    assert window.order_by is not None
+    assert window.frame is not None
+    assert window.frame.mode == "ROWS"
+    assert window.frame.start is not None
+    assert window.frame.start.bound_type == "UNBOUNDED PRECEDING"
+    assert window.frame.end is not None
+    assert window.frame.end.bound_type == "CURRENT ROW"
+
+
+def test_parse_union_and_union_all() -> None:
+    stmt = parse("SELECT id FROM a UNION ALL SELECT id FROM b UNION SELECT id FROM c")
+
+    assert isinstance(stmt, UnionStmt)
+    assert stmt.all is True
+    assert isinstance(stmt.left, SelectStmt)
+    assert isinstance(stmt.right, UnionStmt)
+    assert stmt.right.all is False
+
+
+def test_parse_insert_values() -> None:
+    stmt = parse("INSERT INTO users (id, name) VALUES (1, 'Ada'), (2, 'Linus')")
+
+    assert isinstance(stmt, InsertStmt)
+    assert stmt.table.name == "users"
+    assert stmt.columns == ["id", "name"]
+    assert len(stmt.values) == 2
+    assert stmt.select is None
+
+
+def test_parse_update() -> None:
+    stmt = parse("UPDATE users SET name = 'Ada', age = age + 1 WHERE id = 1")
+
+    assert isinstance(stmt, UpdateStmt)
+    assert stmt.table.name == "users"
+    assert len(stmt.assignments) == 2
+    assert isinstance(stmt.assignments[1].value, BinaryExpr)
+    assert stmt.where is not None
+
+
+def test_parse_delete() -> None:
+    stmt = parse("DELETE FROM users WHERE id IN (1, 2, 3)")
+
+    assert isinstance(stmt, DeleteStmt)
+    assert stmt.table.name == "users"
+    assert stmt.where is not None
+
+
+def test_parse_create_table() -> None:
+    stmt = parse(
+        "CREATE TABLE IF NOT EXISTS users ("
+        "id INTEGER PRIMARY KEY, "
+        "name TEXT NOT NULL, "
+        "score DECIMAL(10,2) DEFAULT 0"
+        ")"
+    )
+
+    assert isinstance(stmt, CreateTableStmt)
+    assert stmt.if_not_exists is True
+    assert stmt.table.name == "users"
+    assert stmt.columns[0].primary_key is True
+    assert stmt.columns[1].nullable is False
+    assert stmt.columns[2].data_type == "DECIMAL(10,2)"
+    assert isinstance(stmt.columns[2].default, LiteralExpr)
+
+
+def test_parse_drop_table() -> None:
+    stmt = parse("DROP TABLE IF EXISTS users")
+
+    assert isinstance(stmt, DropTableStmt)
+    assert stmt.if_exists is True
+    assert stmt.table.name == "users"
+
+
+def test_parse_comparison_predicates() -> None:
+    stmt = parse(
+        "SELECT * FROM users WHERE age BETWEEN 18 AND 30 "
+        "AND name NOT LIKE 'x%' AND deleted_at IS NOT NULL"
+    )
+
+    assert isinstance(stmt, SelectStmt)
+    assert stmt.where is not None
+    condition = stmt.where.condition
+    assert isinstance(condition, BinaryExpr)
+    assert isinstance(condition.left, BinaryExpr)
+    assert isinstance(condition.left.left, BetweenExpr)
+    assert isinstance(condition.left.right, LikeExpr)
+    assert condition.left.right.negated is True
+
+
+def test_parse_general_function_call() -> None:
+    stmt = parse("SELECT LOWER(name) AS lowered FROM users")
+
+    assert isinstance(stmt, SelectStmt)
+    assert isinstance(stmt.columns[0], AliasExpr)
+    call = stmt.columns[0].expr
+    assert isinstance(call, FunctionCall)
+    assert call.name == "LOWER"
+
+
+@pytest.mark.parametrize(
+    "sql",
+    [
+        "SELECT FROM users",
+        "SELECT * FROM users WHERE",
+        "INSERT INTO users VALUES (1,)",
+        "CREATE TABLE users (id)",
+    ],
+)
+def test_malformed_input_raises_parse_error(sql: str) -> None:
+    with pytest.raises(ParseError):
+        parse(sql)
