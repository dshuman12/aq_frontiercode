+from __future__ import annotations
+
+import pytest
+
+from queryweave.parser.ast_nodes import (
+    AggregateExpr,
+    AliasExpr,
+    BetweenExpr,
+    BinaryExpr,
+    CaseExpr,
+    ColumnRef,
+    CreateTableStmt,
+    DeleteStmt,
+    DropTableStmt,
+    FunctionCall,
+    InsertStmt,
+    IsNullExpr,
+    JoinClause,
+    LikeExpr,
+    LiteralExpr,
+    SelectStmt,
+    StarExpr,
+    UnaryExpr,
+    UnionStmt,
+    UpdateStmt,
+    WindowExpr,
+)
+from queryweave.parser.parser import ParserError, parse
+
+
+def test_parse_simple_and_aliased_select_list() -> None:
+    stmt = parse("SELECT id, name AS username, age years FROM users")
+
+    assert isinstance(stmt, SelectStmt)
+    assert stmt.from_table is not None
+    assert stmt.from_table.name == "users"
+    assert stmt.columns[0] == ColumnRef(name="id")
+    assert stmt.columns[1] == AliasExpr(expr=ColumnRef(name="name"), alias="username")
+    assert stmt.columns[2] == AliasExpr(expr=ColumnRef(name="age"), alias="years")
+
+
+def test_parse_where_expression_precedence_and_predicates() -> None:
+    stmt = parse(
+        "SELECT * FROM users "
+        "WHERE age BETWEEN 18 AND 65 AND NOT deleted IS NULL OR name NOT LIKE 'x%'"
+    )
+
+    assert isinstance(stmt, SelectStmt)
+    assert stmt.where is not None
+    condition = stmt.where.condition
+    assert isinstance(condition, BinaryExpr)
+    assert condition.operator == "OR"
+    assert isinstance(condition.left, BinaryExpr)
+    assert condition.left.operator == "AND"
+    assert isinstance(condition.left.left, BetweenExpr)
+    assert isinstance(condition.left.right, UnaryExpr)
+    assert condition.left.right.operator == "NOT"
+    assert isinstance(condition.left.right.operand, IsNullExpr)
+    assert isinstance(condition.right, LikeExpr)
+    assert condition.right.negated is True
+
+
+def test_parse_joins_group_having_order_limit_offset() -> None:
+    stmt = parse(
+        "SELECT u.id, count(o.id) AS order_count "
+        "FROM users u LEFT JOIN orders o ON u.id = o.user_id "
+        "GROUP BY u.id HAVING count(o.id) > 1 "
+        "ORDER BY order_count DESC LIMIT 10 OFFSET 5"
+    )
+
+    assert isinstance(stmt, SelectStmt)
+    assert stmt.from_table is not None
+    assert stmt.from_table.alias == "u"
+    assert stmt.joins == [
+        JoinClause(
+            join_type="LEFT",
+            table=stmt.joins[0].table,
+            condition=stmt.joins[0].condition,
+        )
+    ]
+    assert stmt.joins[0].table.name == "orders"
+    assert stmt.joins[0].table.alias == "o"
+    assert isinstance(stmt.columns[1], AliasExpr)
+    assert isinstance(stmt.columns[1].expr, AggregateExpr)
+    assert stmt.group_by is not None
+    assert stmt.having is not None
+    assert stmt.order_by is not None
+    assert stmt.order_by.items[0].ascending is False
+    assert stmt.limit is not None
+    assert stmt.limit.limit == 10
+    assert stmt.limit.offset == 5
+
+
+def test_parse_case_expression() -> None:
+    stmt = parse(
+        "SELECT CASE WHEN score >= 90 THEN 'A' WHEN score >= 80 THEN 'B' ELSE 'C' END grade "
+        "FROM exams"
+    )
+
+    assert isinstance(stmt, SelectStmt)
+    assert isinstance(stmt.columns[0], AliasExpr)
+    case_expr = stmt.columns[0].expr
+    assert isinstance(case_expr, CaseExpr)
+    assert len(case_expr.when_clauses) == 2
+    assert case_expr.else_expr == LiteralExpr(value="C", literal_type="string")
+
+
+def test_parse_window_call() -> None:
+    stmt = parse(
+        "SELECT row_number() OVER ("
+        "PARTITION BY department ORDER BY salary DESC "
+        "ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW"
+        ") AS rank FROM employees"
+    )
+
+    assert isinstance(stmt, SelectStmt)
+    assert isinstance(stmt.columns[0], AliasExpr)
+    window = stmt.columns[0].expr
+    assert isinstance(window, WindowExpr)
+    assert isinstance(window.function, FunctionCall)
+    assert window.function.name == "row_number"
+    assert len(window.partition_by) == 1
+    assert window.order_by is not None
+    assert window.order_by[0].ascending is False
+    assert window.frame is not None
+    assert window.frame.mode == "ROWS"
+    assert window.frame.start is not None
+    assert window.frame.start.bound_type == "UNBOUNDED PRECEDING"
+
+
+def test_parse_union_all() -> None:
+    stmt = parse("SELECT id FROM active_users UNION ALL SELECT id FROM archived_users")
+
+    assert isinstance(stmt, UnionStmt)
+    assert stmt.all is True
+    assert stmt.left.from_table is not None
+    assert stmt.left.from_table.name == "active_users"
+    assert isinstance(stmt.right, SelectStmt)
+    assert stmt.right.from_table is not None
+    assert stmt.right.from_table.name == "archived_users"
+
+
+def test_parse_insert_update_delete() -> None:
+    insert = parse("INSERT INTO users (id, name) VALUES (1, 'Ada'), (2, 'Linus')")
+    update = parse("UPDATE users SET name = 'Grace', visits = visits + 1 WHERE id = 1")
+    delete = parse("DELETE FROM users WHERE id IN (1, 2, 3)")
+
+    assert isinstance(insert, InsertStmt)
+    assert insert.table.name == "users"
+    assert insert.columns == ["id", "name"]
+    assert len(insert.values) == 2
+    assert isinstance(update, UpdateStmt)
+    assert [assignment.column for assignment in update.assignments] == ["name", "visits"]
+    assert update.where is not None
+    assert isinstance(delete, DeleteStmt)
+    assert delete.where is not None
+
+
+def test_parse_create_and_drop_table() -> None:
+    create = parse(
+        "CREATE TABLE IF NOT EXISTS users ("
+        "id INT PRIMARY KEY, name TEXT NOT NULL, score REAL DEFAULT 0"
+        ")"
+    )
+    drop = parse("DROP TABLE IF EXISTS users")
+
+    assert isinstance(create, CreateTableStmt)
+    assert create.if_not_exists is True
+    assert create.table.name == "users"
+    assert create.columns[0].primary_key is True
+    assert create.columns[1].nullable is False
+    assert create.columns[2].data_type == "REAL"
+    assert create.columns[2].default == LiteralExpr(value=0, literal_type="integer")
+    assert isinstance(drop, DropTableStmt)
+    assert drop.if_exists is True
+    assert drop.table.name == "users"
+
+
+def test_parse_aggregate_distinct_and_star() -> None:
+    stmt = parse("SELECT count(*), sum(DISTINCT amount) FROM payments")
+
+    assert isinstance(stmt, SelectStmt)
+    count_expr = stmt.columns[0]
+    sum_expr = stmt.columns[1]
+    assert isinstance(count_expr, AggregateExpr)
+    assert count_expr.function == "COUNT"
+    assert isinstance(count_expr.arg, StarExpr)
+    assert isinstance(sum_expr, AggregateExpr)
+    assert sum_expr.distinct is True
+    assert sum_expr.arg == ColumnRef(name="amount")
+
+
+def test_malformed_input_raises_parser_error() -> None:
+    with pytest.raises(ParserError, match="SELECT requires at least one expression"):
+        parse("SELECT FROM users")
+
+    with pytest.raises(ParserError, match="Expected RPAREN"):
+        parse("SELECT (1 + 2 FROM users")
