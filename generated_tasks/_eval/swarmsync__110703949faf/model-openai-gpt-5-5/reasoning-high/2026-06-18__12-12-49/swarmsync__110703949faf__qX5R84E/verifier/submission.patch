+func TestDeque_ConcurrentPushPopSteal_NoLostOrDuplicated(t *testing.T) {
+	d := NewDeque()
+	const total = 2000
+	const thiefCount = 8
+
+	results := make(chan int, total)
+	stop := make(chan struct{})
+	var consumed atomic.Int64
+	var wg sync.WaitGroup
+
+	stopped := func() bool {
+		select {
+		case <-stop:
+			return true
+		default:
+			return false
+		}
+	}
+	record := func(item interface{}) {
+		results <- item.(int)
+		consumed.Add(1)
+	}
+
+	wg.Add(1)
+	go func() {
+		defer wg.Done()
+		for i := 0; i < total; i++ {
+			if stopped() {
+				return
+			}
+			d.PushBottom(i)
+			if i%3 == 0 {
+				if item, ok := d.PopBottom(); ok {
+					record(item)
+				}
+			}
+			runtime.Gosched()
+		}
+		for consumed.Load() < total && !stopped() {
+			item, ok := d.PopBottom()
+			if !ok {
+				runtime.Gosched()
+				continue
+			}
+			record(item)
+		}
+	}()
+
+	for i := 0; i < thiefCount; i++ {
+		wg.Add(1)
+		go func() {
+			defer wg.Done()
+			for consumed.Load() < total && !stopped() {
+				item, ok := d.StealTop()
+				if !ok {
+					runtime.Gosched()
+					continue
+				}
+				record(item)
+			}
+		}()
+	}
+
+	done := make(chan struct{})
+	go func() {
+		wg.Wait()
+		close(done)
+	}()
+
+	timedOut := false
+	select {
+	case <-done:
+	case <-time.After(5 * time.Second):
+		close(stop)
+		<-done
+		timedOut = true
+	}
+	close(results)
+
+	if timedOut {
