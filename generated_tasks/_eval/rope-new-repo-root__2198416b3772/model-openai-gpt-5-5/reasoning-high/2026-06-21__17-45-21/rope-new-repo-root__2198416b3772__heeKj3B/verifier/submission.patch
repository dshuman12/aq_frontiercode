diff --git a/base/rope/base/libutils.py b/repo/rope/base/libutils.py
index aafe443..2f947b6 100644
--- a/base/rope/base/libutils.py
+++ b/repo/rope/base/libutils.py
@@ -31,6 +31,53 @@ def path_to_resource(project, path, type=None):
     return None
 
 
+def modname_to_path(project, modname, folder=None):
+    """Return the canonical path for a module name if it can be found."""
+    return project.find_module_path(modname, folder)
+
+
+def pyname_to_path(project, pyname, folder=None):
+    """Return the canonical path for a module name or a `PyName`.
+
+    `pyname` can be a dotted module name or a Rope `PyName` instance.
+    Unknown names and objects without a source resource return `None`.
+    """
+    if pyname is None:
+        return None
+    if isinstance(pyname, basestring):
+        return modname_to_path(project, pyname, folder)
+    if not hasattr(pyname, 'get_object'):
+        return None
+
+    resource = _pyname_to_resource(pyname)
+    if resource is not None:
+        return rope.base.project._canonical_path(resource.real_path)
+
+
+def get_canonical_path(project, pyname, folder=None):
+    return pyname_to_path(project, pyname, folder)
+
+
+def _pyname_to_resource(pyname):
+    resource = _pyobject_to_resource(pyname.get_object())
+    if resource is not None:
+        return resource
+    if not hasattr(pyname, 'get_definition_location'):
+        return None
+    module, lineno = pyname.get_definition_location()
+    if module is not None:
+        return _pyobject_to_resource(module)
+
+
+def _pyobject_to_resource(pyobject):
+    if hasattr(pyobject, 'get_resource'):
+        return pyobject.get_resource()
+    if hasattr(pyobject, 'get_module'):
+        module = pyobject.get_module()
+        if hasattr(module, 'get_resource'):
+            return module.get_resource()
+
+
 def relative(root, path):
