+def get_canonical_path(project, resource, offset):
+    """Get the canonical path to an object.
+
+    Given the offset of the object, this returns a list of
+    (name, name_type) tuples representing the canonical path to the
+    object. For example, the 'x' in the following code:
+
+        class Foo(object):
+            def bar(self):
+                class Qux(object):
+                    def mux(self, x):
+                        pass
+
+    we will return:
+
+        [('Foo', 'CLASS'), ('bar', 'FUNCTION'), ('Qux', 'CLASS'),
+         ('mux', 'FUNCTION'), ('x', 'PARAMETER')]
+
+    `resource` is a `rope.base.resources.Resource` object.
+
+    `offset` is the offset of the pyname you want the path to.
+
+    """
+    pymod = project.get_pymodule(resource)
+    pyname = rope.base.evaluate.eval_location(pymod, offset)
+    if pyname is None:
+        return None
+
+    pyname = _resolve_imported_pyname(pyname)
+    defmod, lineno = pyname.get_definition_location()
+    if defmod is None or lineno is None or defmod.get_resource() is None:
+        return None
+
+    scope = defmod.get_scope().get_inner_scope_for_line(lineno)
+
+    names = []
+    if isinstance(pyname, pynamesdef.ParameterName):
+        name = _get_pyname_name(pyname, scope, resource, offset)
+        if name is not None:
+            names.append((name, 'PARAMETER'))
+    elif isinstance(pyname, pynamesdef.AssignedName):
+        name = _get_pyname_name(pyname, scope, resource, offset)
+        if name is not None:
+            names.append((name, 'VARIABLE'))
+
+    while scope.parent:
+        if isinstance(scope, pyscopes.FunctionScope):
+            scope_type = 'FUNCTION'
+        elif isinstance(scope, pyscopes.ClassScope):
+            scope_type = 'CLASS'
+        else:
+            scope_type = None
+        names.append((scope.pyobject.get_name(), scope_type))
+        scope = scope.parent
+
+    module_path = libutils._get_resource_canonical_path(defmod.get_resource())
+    names.append((module_path, 'MODULE'))
+    names.reverse()
+    return names
+
+
+def _resolve_imported_pyname(pyname):
+    while isinstance(pyname, pynames.ImportedName):
+        imported = pyname._get_imported_pyname()
+        if imported is pyname:
+            break
+        pyname = imported
+    return pyname
+
+
+def _get_pyname_name(pyname, scope, resource, offset):
+    for name, defined_pyname in scope.get_names().items():
+        if defined_pyname is pyname:
+            return name
+    if resource is not None:
+        return worder.get_name_at(resource, offset)
+
+
