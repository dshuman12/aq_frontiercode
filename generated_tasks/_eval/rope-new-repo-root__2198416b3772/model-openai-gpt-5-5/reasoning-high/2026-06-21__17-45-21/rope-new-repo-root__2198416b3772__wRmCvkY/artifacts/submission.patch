+    def _custom_canonical_path(self, pyname, folder):
+        resolver = self.prefs.get('pyname_to_path', None)
+        if resolver is None:
+            return None
+        path = resolver(self, pyname, folder)
+        if hasattr(path, 'real_path'):
+            path = path.real_path
+        elif path is not None and not os.path.isabs(path) and \
+                hasattr(self, 'address'):
+            path = os.path.join(self.address, path)
+        return path
+
+    def _resource_for_pyname(self, pyname, folder=None):
+        if isinstance(pyname, str):
+            return self.find_module(pyname, folder=folder)
+        try:
+            pyobject = pyname.get_object()
+        except AttributeError:
+            return None
+        if hasattr(pyobject, 'get_resource'):
+            resource = pyobject.get_resource()
+            if resource is not None:
+                return resource
+        try:
+            pymodule = pyname.get_definition_location()[0]
+        except AttributeError:
+            return None
+        if pymodule is not None and hasattr(pymodule, 'get_resource'):
+            return pymodule.get_resource()
