+def get_canonical_path(project, resource, offset):
+    """Get the canonical path to an object.
+
+    Given the offset of the object, this returns a list of
+    (name, name_type) tuples representing the canonical path to the
+    object.  The first item is the canonical filesystem path to the
+    module that defines the object.
+
+    `resource` is a `rope.base.resources.Resource` object.
+
+    `offset` is the offset of the pyname you want the path to.
+    """
+    pymod = project.get_pymodule(resource)
+    pyname = rope.base.evaluate.eval_location(pymod, offset)
+    if pyname is None:
+        return None
+
+    original_pyname = pyname
+    pyname = _follow_imported_pyname(pyname)
+    defmod, lineno = pyname.get_definition_location()
+    if defmod is None or lineno is None:
+        return None
+
+    module = defmod.get_module()
+    module_resource = module.get_resource()
+    if module_resource is None:
+        return None
+
+    scope = module.get_scope().get_inner_scope_for_line(lineno)
+
+    names = []
+    terminal = _get_canonical_terminal_name(
+        original_pyname, pyname, resource, offset)
+    if terminal is not None:
+        names.append(terminal)
+
+    while scope.parent:
+        names.append((scope.pyobject.get_name(), _scope_type(scope)))
+        scope = scope.parent
+
+    names.append((libutils.canonical_path(module_resource), 'MODULE'))
+    names.reverse()
+    return names
+
+
+def _follow_imported_pyname(pyname):
+    if isinstance(pyname, pynames.ImportedName):
+        return pyname._get_imported_pyname()
+    return pyname
+
+
+def _get_canonical_terminal_name(original_pyname, pyname, resource, offset):
+    if isinstance(pyname, pynames.ParameterName):
+        return (worder.get_name_at(resource, offset), 'PARAMETER')
+    if isinstance(pyname, pynames.AssignedName):
+        if isinstance(original_pyname, pynames.ImportedName):
+            return (original_pyname.imported_name, 'VARIABLE')
+        return (worder.get_name_at(resource, offset), 'VARIABLE')
+
+
+def _scope_type(scope):
+    if isinstance(scope, pyscopes.FunctionScope):
+        return 'FUNCTION'
+    if isinstance(scope, pyscopes.ClassScope):
+        return 'CLASS'
+
+
