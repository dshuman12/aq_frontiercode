index aafe443..829bfe8 100644
--- a/base/rope/base/libutils.py
+++ b/repo/rope/base/libutils.py
@@ -31,6 +31,26 @@ def path_to_resource(project, path, type=None):
     return None
 
 
+def resource_to_path(resource):
+    """Return the canonical file-system path for a resource."""
+    return rope.base.project._realpath(resource.real_path)
+
+
+def pyname_to_path(pyname):
+    """Return the canonical file-system path for a `PyName`.
+
+    `None` is returned when rope cannot associate the pyname with a
+    source resource, such as unbound or builtin names.
+    """
+    module, lineno = pyname.get_definition_location()
+    if module is None:
+        return None
+    resource = module.get_resource()
+    if resource is None:
+        return None
+    return resource_to_path(resource)
+
+
 def relative(root, path):
     root = rope.base.project._realpath(root).replace(os.path.sep, '/')
     path = rope.base.project._realpath(path).replace(os.path.sep, '/')
