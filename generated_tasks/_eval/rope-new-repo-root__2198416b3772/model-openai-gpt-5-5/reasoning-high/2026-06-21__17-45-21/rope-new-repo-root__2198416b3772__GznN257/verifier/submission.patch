+def get_canonical_module_path(project, modname, folder=None):
+    """Return the canonical filesystem path for `modname`.
+
+    The result is absolute, normalized and has symlinks resolved.  If the
+    module cannot be found, ``None`` is returned.
+    """
+    if hasattr(project, 'get_canonical_module_path'):
+        return project.get_canonical_module_path(modname, folder)
+    module = project.find_module(modname, folder)
+    if module is None:
+        return None
+    return rope.base.project._realpath(module.real_path)
+
+
+def get_canonical_path(project, resource, offset=None, folder=None):
+    """Get the canonical path to a Python object or module.
+
+    When `resource` is a module name and `offset` is ``None``, this returns
+    the canonical filesystem path for that module.  Otherwise `resource`
+    should be a `Resource` and `offset` should point at a name in that file;
+    the result is a list of ``(name, kind)`` tuples from module to object.
+    """
+    try:
+        string_type = basestring
+    except NameError:
+        string_type = str
+    if offset is None and isinstance(resource, string_type):
+        return get_canonical_module_path(project, resource, folder)
+    if offset is None:
+        raise TypeError('offset is required when resource is not a module name')
+
+    import rope.base.evaluate
+    from rope.base import pynamesdef, pyscopes, worder
+
+    pymod = project.get_pymodule(resource)
+    pyname = rope.base.evaluate.eval_location(pymod, offset)
+    if pyname is None:
+        return None
+
+    defmod, lineno = pyname.get_definition_location()
+    if defmod is None or lineno is None:
+        return None
+    scope = defmod.get_scope().get_inner_scope_for_line(lineno)
+
+    names = []
+    if isinstance(pyname, pynamesdef.ParameterName):
+        names = [(worder.get_name_at(pymod.get_resource(), offset),
+                  'PARAMETER')]
+    elif isinstance(pyname, pynamesdef.AssignedName):
+        names = [(worder.get_name_at(pymod.get_resource(), offset),
+                  'VARIABLE')]
+
+    while scope.parent:
+        scope_type = None
+        if isinstance(scope, pyscopes.FunctionScope):
+            scope_type = 'FUNCTION'
+        elif isinstance(scope, pyscopes.ClassScope):
+            scope_type = 'CLASS'
+        names.append((scope.pyobject.get_name(), scope_type))
+        scope = scope.parent
+
+    module = defmod.get_resource()
+    names.append((rope.base.project._realpath(module.real_path), 'MODULE'))
+    names.reverse()
+    return names
+
+
