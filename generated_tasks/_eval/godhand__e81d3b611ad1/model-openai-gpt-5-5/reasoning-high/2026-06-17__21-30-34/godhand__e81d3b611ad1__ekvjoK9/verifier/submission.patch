+def _set_cookie_headers(response):
+    return [
+        value.decode("latin-1")
+        for key, value in response.headers.raw
+        if key.lower() == b"set-cookie"
+    ]
+
+
+def _set_cookie_header(response, name: str) -> str:
+    for header in _set_cookie_headers(response):
+        if header.startswith(f"{name}="):
+            return header
+    raise AssertionError(f"Missing Set-Cookie header for {name}")
+
+
+def _assert_cookie_domain(response, name: str, expected_domain: str | None) -> None:
+    header = _set_cookie_header(response, name)
+    if expected_domain is None:
+        assert "domain=" not in header.lower()
+        return
+    assert f"domain={expected_domain}" in header.lower()
+
