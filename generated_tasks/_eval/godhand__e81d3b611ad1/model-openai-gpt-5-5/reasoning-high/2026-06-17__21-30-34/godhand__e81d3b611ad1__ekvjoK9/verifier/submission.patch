+    @staticmethod
+    def _to_optional_cookie_domain(value: str | None) -> str | None:
+        if value is None:
+            return None
+
+        domain = value.strip().lower()
+        if not domain:
+            return None
+
+        if (
+            "://" in domain
+            or "/" in domain
+            or ":" in domain
+            or "," in domain
+            or ";" in domain
+            or any(char.isspace() for char in domain)
+        ):
+            raise ValueError("JWT_COOKIE_DOMAIN must be a cookie domain, not a URL or path")
+
+        hostname = domain[1:] if domain.startswith(".") else domain
+        if not hostname or hostname.endswith("."):
+            raise ValueError("JWT_COOKIE_DOMAIN must be a valid cookie domain")
+
+        for label in hostname.split("."):
+            if (
+                not label
+                or label.startswith("-")
+                or label.endswith("-")
+                or any(not (char.isalnum() or char == "-") for char in label)
+            ):
+                raise ValueError("JWT_COOKIE_DOMAIN must be a valid cookie domain")
+
+        return domain
+
