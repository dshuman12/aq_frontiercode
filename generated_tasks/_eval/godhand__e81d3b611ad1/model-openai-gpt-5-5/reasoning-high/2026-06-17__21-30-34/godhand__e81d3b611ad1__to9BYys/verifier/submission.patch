+    @staticmethod
+    def _to_optional_cookie_domain(value: str | None) -> str | None:
+        if value is None:
+            return None
+
+        domain = value.strip().lower()
+        if not domain:
+            return None
+
+        if "://" in domain or "/" in domain or ":" in domain or any(char.isspace() for char in domain):
+            raise ValueError(
+                "Environment variable 'JWT_COOKIE_DOMAIN' must be a bare domain, "
+                "for example '.example.com'"
+            )
+
+        hostname = domain[1:] if domain.startswith(".") else domain
+        if domain.startswith("..") or not hostname or hostname.endswith(".") or "." not in hostname:
+            raise ValueError(
+                "Environment variable 'JWT_COOKIE_DOMAIN' must be a parent domain, "
+                "for example '.example.com'"
+            )
+
+        labels = hostname.split(".")
+        if any(not _COOKIE_DOMAIN_LABEL_RE.match(label) for label in labels):
+            raise ValueError(
+                "Environment variable 'JWT_COOKIE_DOMAIN' contains an invalid domain label"
+            )
+
+        return f".{hostname}" if domain.startswith(".") else hostname
+
