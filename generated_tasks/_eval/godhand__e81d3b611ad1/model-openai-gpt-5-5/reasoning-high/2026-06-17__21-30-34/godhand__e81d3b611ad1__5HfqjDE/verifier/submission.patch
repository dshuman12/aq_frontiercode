+    @staticmethod
+    def _to_optional_cookie_domain(value: str | None) -> str | None:
+        if value is None:
+            return None
+
+        cookie_domain = value.strip().lower()
+        if not cookie_domain:
+            return None
+
+        normalized_domain = cookie_domain[1:] if cookie_domain.startswith(".") else cookie_domain
+        if (
+            any(char.isspace() for char in cookie_domain)
+            or "/" in cookie_domain
+            or ":" in cookie_domain
+            or "@" in cookie_domain
+            or normalized_domain == "localhost"
+            or "." not in normalized_domain
+        ):
+            raise ValueError(
+                "JWT_COOKIE_DOMAIN must be a shared parent domain such as '.example.com'"
+            )
+
+        labels = normalized_domain.split(".")
+        if any(
+            not label
+            or len(label) > 63
+            or label.startswith("-")
+            or label.endswith("-")
+            or not all(char.isalnum() or char == "-" for char in label)
+            for label in labels
+        ):
+            raise ValueError(
+                "JWT_COOKIE_DOMAIN must be a shared parent domain such as '.example.com'"
+            )
+
+        return cookie_domain
