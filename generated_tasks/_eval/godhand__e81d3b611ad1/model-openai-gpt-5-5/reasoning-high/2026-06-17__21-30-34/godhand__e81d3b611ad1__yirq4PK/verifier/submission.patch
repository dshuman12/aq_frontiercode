+            "/api/v1/auth/login",
+            json={"identifier": "nodomain@example.com", "password": "StrongPass123"},
+            headers={"X-CSRF-TOKEN": anon_csrf},
+        )
+
+        assert response.status_code == 200
+        _assert_no_cookie_domain(response)
+
+        csrf = get_auth_csrf(test_client)
