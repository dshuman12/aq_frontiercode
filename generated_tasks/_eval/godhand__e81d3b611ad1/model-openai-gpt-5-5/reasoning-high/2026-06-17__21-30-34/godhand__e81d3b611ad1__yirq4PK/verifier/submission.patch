+    @staticmethod
+    def _to_cookie_domain(value: str | None) -> str | None:
+        if value is None:
+            return None
+
+        domain = value.strip().lower()
+        if not domain:
+            return None
+
+        if "://" in domain or "/" in domain or ":" in domain or any(char.isspace() for char in domain):
+            raise ValueError("JWT_COOKIE_DOMAIN must be a domain name, not a URL")
+
+        domain_without_dot = domain[1:] if domain.startswith(".") else domain
+        if (
+            not domain_without_dot
+            or ".." in domain_without_dot
+            or "." not in domain_without_dot
+        ):
+            raise ValueError("JWT_COOKIE_DOMAIN must be a parent domain like '.example.com'")
+
+        label_pattern = re.compile(r"^[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?$")
+        if any(not label_pattern.match(label) for label in domain_without_dot.split(".")):
+            raise ValueError("JWT_COOKIE_DOMAIN contains invalid domain label characters")
+
+        return domain
