+        assert me_response.status_code == 200
+
+
+def test_auth_cookies_use_configured_shared_domain(monkeypatch):
+    cookie_domain = ".example.com"
+    monkeypatch.setenv("JWT_COOKIE_DOMAIN", cookie_domain)
+    reset_settings_cache()
+
+    app = create_app()
+    with TestClient(app, base_url="https://api.example.com") as test_client:
+        csrf_response = test_client.get("/api/v1/auth/csrf-token")
+        assert csrf_response.status_code == 200
+        _assert_cookie_domain(csrf_response, "anon_csrf", cookie_domain)
+
+        anon_csrf = csrf_response.json()["csrf_token"]
+        register_response = test_client.post(
+            "/api/v1/auth/register",
+            json={
+                "username": "domainuser",
+                "email": "domain@example.com",
+                "password": "StrongPass123",
+            },
+            headers={"X-CSRF-TOKEN": anon_csrf},
+        )
+        assert register_response.status_code == 201, register_response.text
+
+        anon_csrf = get_anon_csrf(test_client)
+        login_response = test_client.post(
+            "/api/v1/auth/login",
+            json={"identifier": "domain@example.com", "password": "StrongPass123"},
+            headers={"X-CSRF-TOKEN": anon_csrf},
+        )
+        assert login_response.status_code == 200, login_response.text
+        for cookie_name in _AUTH_COOKIE_NAMES:
+            _assert_cookie_domain(login_response, cookie_name, cookie_domain)
+        _assert_cookie_domain(login_response, "anon_csrf", cookie_domain)
+
+        access_csrf = get_auth_csrf(test_client)
+        me_response = test_client.get("/api/v1/auth/me", headers={"X-CSRF-TOKEN": access_csrf})
+        assert me_response.status_code == 200
+
+        refresh_csrf = get_refresh_csrf(test_client)
+        refresh_response = test_client.post(
+            "/api/v1/auth/refresh",
+            headers={"X-CSRF-TOKEN": refresh_csrf},
+        )
+        assert refresh_response.status_code == 200
+        _assert_cookie_domain(refresh_response, "access_token_cookie", cookie_domain)
+        _assert_cookie_domain(refresh_response, "csrf_access_token", cookie_domain)
+
+        access_csrf = get_auth_csrf(test_client)
+        logout_response = test_client.post(
+            "/api/v1/auth/logout",
+            headers={"X-CSRF-TOKEN": access_csrf},
+        )
+        assert logout_response.status_code == 200
+        for cookie_name in _AUTH_COOKIE_NAMES:
+            _assert_cookie_domain(logout_response, cookie_name, cookie_domain)
+
