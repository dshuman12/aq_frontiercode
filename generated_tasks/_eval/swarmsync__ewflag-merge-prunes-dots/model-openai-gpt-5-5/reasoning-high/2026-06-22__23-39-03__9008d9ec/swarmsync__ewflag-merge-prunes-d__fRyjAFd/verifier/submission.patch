diff --git a/repo/pkg/crdt/ewflag_test.go b/repo/pkg/crdt/ewflag_test.go
new file mode 100644
index 0000000..8ac6e0f
--- /dev/null
+++ b/repo/pkg/crdt/ewflag_test.go
@@ -0,0 +1,198 @@
+package crdt
+
+import (
+	"reflect"
+	"testing"
+)
+
+type ewFlagSnapshot struct {
+	dots     map[string]uint64
+	counters map[string]uint64
+	enabled  bool
+}
+
+func snapshotEWFlag(f *EWFlag) ewFlagSnapshot {
+	f.mu.RLock()
+	defer f.mu.RUnlock()
+
+	dots := make(map[string]uint64, len(f.dots))
+	for nodeID, counter := range f.dots {
+		dots[nodeID] = counter
+	}
+	counters := make(map[string]uint64, len(f.counters))
+	for nodeID, counter := range f.counters {
+		counters[nodeID] = counter
+	}
+	return ewFlagSnapshot{
+		dots:     dots,
+		counters: counters,
+		enabled:  len(dots) > 0,
+	}
+}
+
+func concurrentEnableAndEmptyDisable() (*EWFlag, *EWFlag) {
+	enabled := NewEWFlag()
+	enabled.Enable("node-a")
+
+	disabled := NewEWFlag()
+	disabled.Disable()
+
+	return enabled, disabled
+}
+
+func observedDisableAndStaleEnable() (*EWFlag, *EWFlag) {
+	enabled := NewEWFlag()
+	enabled.Enable("node-a")
+
+	disabled := NewEWFlag()
+	disabled.Merge(enabled)
+	disabled.Disable()
+
+	return enabled, disabled
+}
+
+func TestEWFlagMergeConcurrentEnableWins(t *testing.T) {
+	tests := []struct {
+		name       string
+		local      func() *EWFlag
+		other      func() *EWFlag
+		wantDots   int
+		wantEnable bool
+	}{
+		{
+			name: "enabled replica merges concurrent empty disable",
+			local: func() *EWFlag {
+				enabled, _ := concurrentEnableAndEmptyDisable()
+				return enabled
+			},
+			other: func() *EWFlag {
+				_, disabled := concurrentEnableAndEmptyDisable()
+				return disabled
+			},
+			wantDots:   1,
+			wantEnable: true,
+		},
+		{
+			name: "empty disable replica merges concurrent enable",
+			local: func() *EWFlag {
+				_, disabled := concurrentEnableAndEmptyDisable()
+				return disabled
+			},
+			other: func() *EWFlag {
+				enabled, _ := concurrentEnableAndEmptyDisable()
+				return enabled
+			},
+			wantDots:   1,
+			wantEnable: true,
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			local := tt.local()
+			local.Merge(tt.other())
+
+			if got := local.Value(); got != tt.wantEnable {
+				t.Fatalf("Value() = %v, want %v", got, tt.wantEnable)
+			}
+			if got := local.DotCount(); got != tt.wantDots {
+				t.Fatalf("DotCount() = %d, want %d", got, tt.wantDots)
+			}
+		})
+	}
+}
+
+func TestEWFlagMergeObservedDisableClearsEnable(t *testing.T) {
+	tests := []struct {
+		name  string
+		local func() *EWFlag
+		other func() *EWFlag
+	}{
+		{
+			name: "enabled replica merges observed disable",
+			local: func() *EWFlag {
+				enabled, _ := observedDisableAndStaleEnable()
+				return enabled
+			},
+			other: func() *EWFlag {
+				_, disabled := observedDisableAndStaleEnable()
+				return disabled
+			},
+		},
+		{
+			name: "observed disable replica merges stale enable",
+			local: func() *EWFlag {
+				_, disabled := observedDisableAndStaleEnable()
+				return disabled
+			},
+			other: func() *EWFlag {
+				enabled, _ := observedDisableAndStaleEnable()
+				return enabled
+			},
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			local := tt.local()
+			local.Merge(tt.other())
+
+			if local.Value() {
+				t.Fatal("Value() = true, want false")
+			}
+			if got := local.DotCount(); got != 0 {
+				t.Fatalf("DotCount() = %d, want 0", got)
+			}
+		})
+	}
+}
+
+func TestEWFlagMergeIdempotentAndCommutative(t *testing.T) {
+	tests := []struct {
+		name        string
+		replicas    func() (*EWFlag, *EWFlag)
+		wantEnabled bool
+	}{
+		{
+			name:        "concurrent enable and empty disable",
+			replicas:    concurrentEnableAndEmptyDisable,
+			wantEnabled: true,
+		},
+		{
+			name:        "observed disable and stale enable",
+			replicas:    observedDisableAndStaleEnable,
+			wantEnabled: false,
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			left, right := tt.replicas()
+			left.Merge(right)
+			leftOnce := snapshotEWFlag(left)
+			left.Merge(right)
+			leftTwice := snapshotEWFlag(left)
+
+			if !reflect.DeepEqual(leftTwice, leftOnce) {
+				t.Fatalf("left merge is not idempotent: once=%+v twice=%+v", leftOnce, leftTwice)
+			}
+
+			left, right = tt.replicas()
+			right.Merge(left)
+			rightOnce := snapshotEWFlag(right)
+			right.Merge(left)
+			rightTwice := snapshotEWFlag(right)
+
+			if !reflect.DeepEqual(rightTwice, rightOnce) {
+				t.Fatalf("right merge is not idempotent: once=%+v twice=%+v", rightOnce, rightTwice)
+			}
+
+			if !reflect.DeepEqual(leftOnce, rightOnce) {
+				t.Fatalf("merge is not commutative: left=%+v right=%+v", leftOnce, rightOnce)
+			}
+			if leftOnce.enabled != tt.wantEnabled {
+				t.Fatalf("enabled = %v, want %v", leftOnce.enabled, tt.wantEnabled)
+			}
+		})
+	}
+}
