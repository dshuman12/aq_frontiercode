diff --git a/repo/pkg/crdt/ewflag_test.go b/repo/pkg/crdt/ewflag_test.go
new file mode 100644
index 0000000..51af7dc
--- /dev/null
+++ b/repo/pkg/crdt/ewflag_test.go
@@ -0,0 +1,175 @@
+package crdt
+
+import (
+	"reflect"
+	"testing"
+)
+
+type ewflagSnapshot struct {
+	enabled  bool
+	dots     map[string]uint64
+	counters map[string]uint64
+}
+
+func TestEWFlagMergeConcurrentEnableWinsOverDisable(t *testing.T) {
+	tests := []struct {
+		name  string
+		merge func(enabled *EWFlag, disabled *EWFlag) *EWFlag
+	}{
+		{
+			name: "enable replica merges concurrent disable",
+			merge: func(enabled *EWFlag, disabled *EWFlag) *EWFlag {
+				enabled.Merge(disabled)
+				return enabled
+			},
+		},
+		{
+			name: "disable replica merges concurrent enable",
+			merge: func(enabled *EWFlag, disabled *EWFlag) *EWFlag {
+				disabled.Merge(enabled)
+				return disabled
+			},
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			enabled, disabled := concurrentEnableAndDisable()
+
+			merged := tt.merge(enabled, disabled)
+
+			if !merged.Value() {
+				t.Fatalf("merged flag is disabled, want enabled")
+			}
+			if got := merged.DotCount(); got != 1 {
+				t.Fatalf("merged flag has %d active dots, want 1", got)
+			}
+		})
+	}
+}
+
+func TestEWFlagMergeObservedDisableClearsEnable(t *testing.T) {
+	tests := []struct {
+		name  string
+		merge func(enabled *EWFlag, disabled *EWFlag) *EWFlag
+	}{
+		{
+			name: "enabled replica merges observed disable",
+			merge: func(enabled *EWFlag, disabled *EWFlag) *EWFlag {
+				enabled.Merge(disabled)
+				return enabled
+			},
+		},
+		{
+			name: "disabled replica merges stale enable",
+			merge: func(enabled *EWFlag, disabled *EWFlag) *EWFlag {
+				disabled.Merge(enabled)
+				return disabled
+			},
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			enabled, disabled := observedDisable()
+
+			merged := tt.merge(enabled, disabled)
+
+			if merged.Value() {
+				t.Fatalf("merged flag is enabled, want disabled")
+			}
+			if got := merged.DotCount(); got != 0 {
+				t.Fatalf("merged flag has %d active dots, want 0", got)
+			}
+		})
+	}
+}
+
+func TestEWFlagMergeRepeatedMergesConverge(t *testing.T) {
+	tests := []struct {
+		name  string
+		setup func() (*EWFlag, *EWFlag)
+	}{
+		{
+			name:  "concurrent enable and disable",
+			setup: concurrentEnableAndDisable,
+		},
+		{
+			name:  "observed disable",
+			setup: observedDisable,
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			leftFirstA, leftFirstB := tt.setup()
+			leftFirstA.Merge(leftFirstB)
+			leftFirstB.Merge(leftFirstA)
+			leftFirst := snapshotEWFlag(leftFirstA)
+			assertEWFlagSnapshot(t, leftFirst, snapshotEWFlag(leftFirstB))
+
+			rightFirstA, rightFirstB := tt.setup()
+			rightFirstB.Merge(rightFirstA)
+			rightFirstA.Merge(rightFirstB)
+			rightFirst := snapshotEWFlag(rightFirstA)
+			assertEWFlagSnapshot(t, rightFirst, snapshotEWFlag(rightFirstB))
+			assertEWFlagSnapshot(t, leftFirst, rightFirst)
+
+			leftFirstA.Merge(leftFirstB)
+			leftFirstB.Merge(leftFirstA)
+			assertEWFlagSnapshot(t, leftFirst, snapshotEWFlag(leftFirstA))
+			assertEWFlagSnapshot(t, leftFirst, snapshotEWFlag(leftFirstB))
+
+			leftFirstA.Merge(leftFirstA)
+			assertEWFlagSnapshot(t, leftFirst, snapshotEWFlag(leftFirstA))
+		})
+	}
+}
+
+func concurrentEnableAndDisable() (*EWFlag, *EWFlag) {
+	enabled := NewEWFlag()
+	enabled.Enable("node-a")
+
+	disabled := NewEWFlag()
+	disabled.Disable()
+
+	return enabled, disabled
+}
+
+func observedDisable() (*EWFlag, *EWFlag) {
+	enabled := NewEWFlag()
+	enabled.Enable("node-a")
+
+	disabled := NewEWFlag()
+	disabled.Merge(enabled)
+	disabled.Disable()
+
+	return enabled, disabled
+}
+
+func snapshotEWFlag(f *EWFlag) ewflagSnapshot {
+	f.mu.RLock()
+	defer f.mu.RUnlock()
+
+	return ewflagSnapshot{
+		enabled:  len(f.dots) > 0,
+		dots:     cloneCounters(f.dots),
+		counters: cloneCounters(f.counters),
+	}
+}
+
+func cloneCounters(counters map[string]uint64) map[string]uint64 {
+	clone := make(map[string]uint64, len(counters))
+	for nodeID, counter := range counters {
+		clone[nodeID] = counter
+	}
+	return clone
+}
+
+func assertEWFlagSnapshot(t *testing.T, want ewflagSnapshot, got ewflagSnapshot) {
+	t.Helper()
+
+	if !reflect.DeepEqual(got, want) {
+		t.Fatalf("snapshot mismatch\ngot:  %#v\nwant: %#v", got, want)
+	}
+}
