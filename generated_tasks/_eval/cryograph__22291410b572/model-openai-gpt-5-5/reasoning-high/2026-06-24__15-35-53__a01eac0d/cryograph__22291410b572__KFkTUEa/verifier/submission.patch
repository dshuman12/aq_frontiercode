+CRYO_TEST(FloydWarshall, MatchesDijkstraWeightedDirected) {
+    Graph g(GraphType::Directed);
+    g.add_node_with_id(10); g.add_node_with_id(20); g.add_node_with_id(30);
+    g.add_node_with_id(40); g.add_node_with_id(50);
+    g.add_edge(10, 20, 4.0); g.add_edge(10, 30, 2.0);
+    g.add_edge(30, 20, 1.0); g.add_edge(20, 40, 5.0);
+    g.add_edge(30, 40, 8.0); g.add_edge(40, 50, 3.0);
+    g.add_edge(30, 50, 10.0);
+
+    auto apsp = floyd_warshall(g);
+    for (auto src : g.node_ids()) {
+        auto single = dijkstra(g, src);
+        for (auto dst : g.node_ids()) {
+            assert_eq(apsp.reachable(src, dst), single.reachable(dst));
+            if (!single.reachable(dst)) continue;
+
+            assert_near(apsp.dist[src][dst], single.dist[dst]);
+            auto path = apsp.path(src, dst);
+            assert_false(path.empty());
+            assert_eq(path.front(), src);
+            assert_eq(path.back(), dst);
+            assert_near(path_weight(g, path), single.dist[dst]);
+        }
+    }
+}
