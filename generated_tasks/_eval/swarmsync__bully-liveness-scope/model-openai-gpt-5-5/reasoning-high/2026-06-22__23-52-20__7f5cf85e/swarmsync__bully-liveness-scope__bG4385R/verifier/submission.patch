+++ b/repo/pkg/election/election_test.go
@@ -0,0 +1,81 @@
+package election
+
+import "testing"
+
+func TestBullyElectionSkipsDeadHighestPeer(t *testing.T) {
+	be := NewBullyElection("node1")
+	be.AddPeer("node2")
+	be.AddPeer("node3")
+	be.MarkDead("node3")
+
+	if got := be.RunElection(); got != "node2" {
+		t.Fatalf("RunElection() = %q, want %q", got, "node2")
+	}
+	if got := be.Leader(); got != "node2" {
+		t.Fatalf("Leader() = %q, want %q", got, "node2")
+	}
+}
+
+func TestBullyElectionReelectsNextLivePeerAfterLeaderDies(t *testing.T) {
+	be := NewBullyElection("node1")
+	be.AddPeer("node2")
+	be.AddPeer("node3")
+	be.AddPeer("node4")
+
+	if got := be.RunElection(); got != "node4" {
+		t.Fatalf("initial RunElection() = %q, want %q", got, "node4")
+	}
+
+	be.MarkDead("node4")
+
+	if got := be.RunElection(); got != "node3" {
+		t.Fatalf("reelection RunElection() = %q, want %q", got, "node3")
+	}
+	if got := be.Leader(); got != "node3" {
+		t.Fatalf("Leader() = %q, want %q", got, "node3")
+	}
+}
+
+func TestBullyElectionAllAliveUnchanged(t *testing.T) {
+	be := NewBullyElection("node1")
+	be.AddPeer("node2")
+	be.AddPeer("node3")
+
+	if got := be.RunElection(); got != "node3" {
+		t.Fatalf("RunElection() = %q, want %q", got, "node3")
+	}
+}
+
+func TestBullyElectionAllAliveSelfCanStillWin(t *testing.T) {
+	be := NewBullyElection("node3")
+	be.AddPeer("node1")
+	be.AddPeer("node2")
+
+	if got := be.RunElection(); got != "node3" {
+		t.Fatalf("RunElection() = %q, want %q", got, "node3")
+	}
+	if !be.IsLeader() {
+		t.Fatal("IsLeader() = false, want true")
+	}
+}
+
+func TestBullyElectionNoLivePeersHasNoLeader(t *testing.T) {
+	be := NewBullyElection("node1")
+	be.AddPeer("node2")
+	be.AddPeer("node3")
+	be.MarkDead("node2")
+	be.MarkDead("node3")
+
+	if got := be.RunElection(); got != "" {
+		t.Fatalf("RunElection() = %q, want no leader", got)
+	}
+	if got := be.Leader(); got != "" {
+		t.Fatalf("Leader() = %q, want no leader", got)
+	}
+	if be.IsLeader() {
+		t.Fatal("IsLeader() = true, want false")
+	}
+	if got := be.CurrentState(); got != StateFollower {
+		t.Fatalf("CurrentState() = %s, want %s", got, StateFollower)
+	}
+}
