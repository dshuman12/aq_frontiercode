+++ b/repo/server/api/routers/health.py
@@ -1,5 +1,9 @@
 from fastapi import APIRouter, Request
+from fastapi.responses import JSONResponse
 
+from server.config import get_app_config
+from server.external.db.mongo import MongoDBClient
+from server.utils.constants import HttpStatus
 from server.utils.logging import get_app_logger
 
 app_logger = get_app_logger()
@@ -12,3 +16,64 @@ def health_check(request: Request):
     client_host = request.client.host if request.client else "unknown"
     app_logger.info(f"Health check received from {client_host}")
     return {"status": "ok"}
+
+
+def _ok_check() -> dict[str, str]:
+    return {"status": "ok"}
+
+
+def _failed_check(message: str) -> dict[str, str]:
+    return {"status": "failed", "message": message}
+
+
+def _check_configuration() -> dict[str, str]:
+    try:
+        cfg = get_app_config()
+    except Exception as exc:
+        return _failed_check(f"Application configuration failed to load: {exc}")
+
+    missing_or_weak = []
+    if len(str(cfg.SECRET_KEY or "").encode("utf-8")) < 32:
+        missing_or_weak.append("SECRET_KEY")
+    if len(str(cfg.JWT_SECRET_KEY or "").encode("utf-8")) < 32:
+        missing_or_weak.append("JWT_SECRET_KEY")
+
+    if missing_or_weak:
+        return _failed_check(
+            "Required secret configuration is missing or shorter than 32 bytes: "
+            + ", ".join(missing_or_weak)
+        )
+
+    return _ok_check()
+
+
+def _check_mongodb() -> dict[str, str]:
+    try:
+        client = MongoDBClient.get_client()
+        MongoDBClient.get_db_name()
+        client.admin.command("ping")
+    except Exception as exc:
+        return _failed_check(f"MongoDB is unavailable: {exc}")
+
+    return _ok_check()
+
+
+def get_readiness_report() -> dict[str, object]:
+    checks = {
+        "configuration": _check_configuration(),
+        "mongodb": _check_mongodb(),
+    }
+    ready = all(check["status"] == "ok" for check in checks.values())
+    return {
+        "status": "ready" if ready else "not_ready",
+        "ready": ready,
+        "checks": checks,
+    }
+
+
+@health_routes.get("/ready", include_in_schema=False)
+@health_routes.get("/health/ready")
+def readiness_check():
+    report = get_readiness_report()
+    status_code = HttpStatus.OK if report["ready"] else HttpStatus.SERVICE_UNAVAILABLE
+    return JSONResponse(status_code=status_code, content=report)
