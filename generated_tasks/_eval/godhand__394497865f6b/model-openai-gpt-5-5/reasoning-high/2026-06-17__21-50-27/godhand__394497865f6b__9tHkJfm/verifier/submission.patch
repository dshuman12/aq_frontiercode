@@ -1,5 +1,10 @@
+from typing import Any
+
 from fastapi import APIRouter, Request
+from fastapi.responses import JSONResponse
 
+from server.config import get_app_config
+from server.external.db.mongo import MongoDBClient
 from server.utils.logging import get_app_logger
 
 app_logger = get_app_logger()
@@ -12,3 +17,60 @@ def health_check(request: Request):
     client_host = request.client.host if request.client else "unknown"
     app_logger.info(f"Health check received from {client_host}")
     return {"status": "ok"}
+
+
+def _ready_check(name: str, *, ok: bool, detail: str | None = None) -> dict[str, Any]:
+    check: dict[str, Any] = {
+        "name": name,
+        "status": "ok" if ok else "failed",
+    }
+    if detail:
+        check["detail"] = detail
+    return check
+
+
+def _evaluate_readiness() -> dict[str, Any]:
+    checks: list[dict[str, Any]] = []
+
+    try:
+        cfg = get_app_config()
+        missing_config = [
+            name
+            for name in ("SECRET_KEY", "JWT_SECRET_KEY")
+            if not str(getattr(cfg, name, "") or "").strip()
+        ]
+        if missing_config:
+            checks.append(
+                _ready_check(
+                    "configuration",
+                    ok=False,
+                    detail=f"Missing required configuration: {', '.join(missing_config)}",
+                )
+            )
+        else:
+            checks.append(_ready_check("configuration", ok=True))
+    except Exception as exc:
+        checks.append(_ready_check("configuration", ok=False, detail=str(exc)))
+
+    try:
+        MongoDBClient.get_client().admin.command("ping")
+        MongoDBClient.get_db_name()
+        checks.append(_ready_check("mongodb", ok=True))
+    except Exception as exc:
+        checks.append(_ready_check("mongodb", ok=False, detail=str(exc)))
+
+    is_ready = all(check["status"] == "ok" for check in checks)
+    return {
+        "status": "ready" if is_ready else "not_ready",
+        "checks": checks,
+    }
+
+
+@health_routes.get("/health/ready")
+@health_routes.get("/ready")
+def readiness_check(request: Request):
+    client_host = request.client.host if request.client else "unknown"
+    app_logger.info(f"Readiness check received from {client_host}")
+    payload = _evaluate_readiness()
+    status_code = 200 if payload["status"] == "ready" else 503
+    return JSONResponse(status_code=status_code, content=payload)
