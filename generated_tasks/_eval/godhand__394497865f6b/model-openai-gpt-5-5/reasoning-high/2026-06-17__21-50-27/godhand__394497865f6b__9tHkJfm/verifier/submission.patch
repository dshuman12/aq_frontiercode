@@ -0,0 +1,63 @@
+from __future__ import annotations
+
+from server.external.db.mongo import MongoDBClient
+
+
+def test_health_liveness_response_stays_unchanged(client):
+    response = client.get("/health")
+
+    assert response.status_code == 200
+    assert response.json() == {"status": "ok"}
+
+
+def test_readiness_reports_ready_when_config_and_mongo_are_available(client):
+    response = client.get("/ready")
+
+    assert response.status_code == 200
+    assert response.json()["status"] == "ready"
+    checks = {check["name"]: check["status"] for check in response.json()["checks"]}
+    assert checks == {
+        "configuration": "ok",
+        "mongodb": "ok",
+    }
+
+
+def test_health_ready_alias_reports_ready(client):
+    response = client.get("/health/ready")
+
+    assert response.status_code == 200
+    assert response.json()["status"] == "ready"
+
+
+def test_readiness_reports_not_ready_when_mongo_is_not_initialized(client):
+    MongoDBClient.close()
+
+    response = client.get("/ready")
+
+    assert response.status_code == 503
+    payload = response.json()
+    assert payload["status"] == "not_ready"
+    checks = {check["name"]: check for check in payload["checks"]}
+    assert checks["configuration"]["status"] == "ok"
+    assert checks["mongodb"]["status"] == "failed"
+    assert "not initialized" in checks["mongodb"]["detail"]
+
+
+def test_readiness_reports_not_ready_when_config_cannot_load(client, monkeypatch):
+    def _raise_config_error():
+        raise ValueError("bad runtime config")
+
+    monkeypatch.setattr("server.api.routers.health.get_app_config", _raise_config_error)
+
+    response = client.get("/ready")
+
+    assert response.status_code == 503
+    payload = response.json()
+    assert payload["status"] == "not_ready"
+    checks = {check["name"]: check for check in payload["checks"]}
+    assert checks["configuration"] == {
+        "name": "configuration",
+        "status": "failed",
+        "detail": "bad runtime config",
+    }
+    assert checks["mongodb"]["status"] == "ok"
diff --git a/repo/server/tests/test_startup_alerts.py b/repo/server/tests/test_startup_alerts.py
