@@ -12,3 +17,51 @@ def health_check(request: Request):
     client_host = request.client.host if request.client else "unknown"
     app_logger.info(f"Health check received from {client_host}")
     return {"status": "ok"}
+
+
+def _readiness_checks() -> dict[str, dict[str, str]]:
+    checks: dict[str, dict[str, str]] = {}
+
+    try:
+        cfg = get_app_config()
+        missing_settings = [
+            name
+            for name in ("SECRET_KEY", "JWT_SECRET_KEY")
+            if len(str(getattr(cfg, name, "") or "").encode("utf-8")) < 32
+        ]
+        if missing_settings:
+            checks["configuration"] = {
+                "status": "error",
+                "message": f"Missing or weak settings: {', '.join(missing_settings)}",
+            }
+        else:
+            checks["configuration"] = {"status": "ok"}
+    except Exception as exc:
+        checks["configuration"] = {"status": "error", "message": str(exc)}
+
+    try:
+        client = MongoDBClient.get_client()
+        client.admin.command("ping")
+        MongoDBClient.get_db_name()
+        checks["mongodb"] = {"status": "ok"}
+    except (PyMongoError, Exception) as exc:
+        checks["mongodb"] = {"status": "error", "message": str(exc)}
+
+    return checks
+
+
+@health_routes.get("/health/ready")
+def readiness_check(request: Request):
+    client_host = request.client.host if request.client else "unknown"
+    checks = _readiness_checks()
+    ready = all(check["status"] == "ok" for check in checks.values())
+    app_logger.info(f"Readiness check received from {client_host}: ready={ready}")
+
+    status_code = HttpStatus.OK if ready else HttpStatus.SERVICE_UNAVAILABLE
+    return JSONResponse(
+        status_code=status_code,
+        content={
+            "status": "ready" if ready else "not_ready",
+            "checks": checks,
+        },
+    )
