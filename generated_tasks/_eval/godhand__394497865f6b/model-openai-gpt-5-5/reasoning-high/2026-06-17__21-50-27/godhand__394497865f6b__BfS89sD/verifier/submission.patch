@@ -0,0 +1,152 @@
+from __future__ import annotations
+
+import importlib
+import warnings
+
+from fastapi.testclient import TestClient
+
+from server.app import create_app
+from server.config import ProductionConfig
+from server.external.db.mongo import MongoDBClient
+from server.utils import startup_alerts
+
+
+def _safe_production_config() -> ProductionConfig:
+    return ProductionConfig(
+        BACKEND_PUBLIC_BASE_URL="https://api.example.com",
+        FRONTEND_PUBLIC_BASE_URL="https://app.example.com",
+        GAME_WS_PUBLIC_BASE_URL="wss://game.example.com",
+        CHAT_WS_PUBLIC_BASE_URL="wss://chat.example.com",
+        CORS_ALLOWED_ORIGINS=["https://app.example.com"],
+        SECRET_KEY="s" * 32,
+        JWT_SECRET_KEY="j" * 32,
+        JWT_COOKIE_SECURE=True,
+        GAME_SERVER_CREDENTIALS_JSON='{"game-a":{"signing_secret":"secret"}}',
+    )
+
+
+def test_liveness_endpoint_stays_unchanged(client: TestClient):
+    response = client.get("/health")
+
+    assert response.status_code == 200
+    assert response.json() == {"status": "ok"}
+
+
+def test_readiness_endpoint_reports_ready(client: TestClient):
+    response = client.get("/health/ready")
+
+    assert response.status_code == 200
+    payload = response.json()
+    assert payload["status"] == "ready"
+    assert payload["checks"]["configuration"]["status"] == "ok"
+    assert payload["checks"]["mongodb"]["status"] == "ok"
+
+
+def test_readiness_endpoint_reports_not_ready_when_mongo_is_unavailable(client: TestClient):
+    MongoDBClient.close()
+
+    response = client.get("/health/ready")
+
+    assert response.status_code == 503
+    payload = response.json()
+    assert payload["status"] == "not_ready"
+    assert payload["checks"]["configuration"]["status"] == "ok"
+    assert payload["checks"]["mongodb"]["status"] == "error"
+
+    liveness_response = client.get("/health")
+    assert liveness_response.status_code == 200
+    assert liveness_response.json() == {"status": "ok"}
+
+
+def test_startup_safety_alerts_pass_cleanly_for_safe_production_config():
+    alerts = startup_alerts.collect_startup_safety_alerts(
+        _safe_production_config(),
+        role="main",
+        environ={"FASTAPI_ENV": "production"},
+    )
+
+    assert alerts == []
+
+
+def test_startup_safety_alerts_detect_risky_production_config():
+    config = ProductionConfig(
+        SECRET_KEY="short",
+        JWT_SECRET_KEY="also-short",
+        JWT_COOKIE_SECURE=False,
+        CORS_ALLOWED_ORIGINS=["*"],
+        DEV_ADMIN_TOKEN="dev-token",
+    )
+
+    alerts = startup_alerts.collect_startup_safety_alerts(
+        config,
+        role="main",
+        environ={"FASTAPI_ENV": "production"},
+    )
+    codes = {alert.code for alert in alerts}
+
+    assert "secret_key.weak" in codes
+    assert "jwt_secret_key.weak" in codes
+    assert "jwt_cookie.insecure" in codes
+    assert "cors.wildcard" in codes
+    assert "dev_admin_token.enabled" in codes
+    assert "game_server.credentials_missing" in codes
+
+
+def test_emit_startup_safety_alerts_logs_warnings_without_raising(monkeypatch):
+    messages: list[str] = []
+    config = ProductionConfig(
+        SECRET_KEY="short",
+        JWT_SECRET_KEY="also-short",
+        JWT_COOKIE_SECURE=False,
+    )
+
+    monkeypatch.setattr(startup_alerts, "get_app_config", lambda: config)
+    monkeypatch.setattr(
+        startup_alerts.app_logger,
+        "warning",
+        lambda message, *args: messages.append(message % args),
+    )
+
+    alerts = startup_alerts.emit_startup_safety_alerts(role="main")
+
+    assert alerts
+    assert any("jwt_cookie.insecure" in message for message in messages)
+
+
+def test_emit_startup_safety_alerts_passes_cleanly_without_warning(monkeypatch):
+    messages: list[str] = []
+
+    monkeypatch.setattr(startup_alerts, "get_app_config", _safe_production_config)
+    monkeypatch.setattr(
+        startup_alerts.app_logger,
+        "warning",
+        lambda message, *args: messages.append(message % args),
+    )
+
+    alerts = startup_alerts.emit_startup_safety_alerts(role="main")
+
+    assert alerts == []
+    assert messages == []
+
+
+def test_server_entrypoints_emit_shared_startup_safety_alerts(monkeypatch):
+    calls: list[str] = []
+
+    monkeypatch.setattr(
+        "server.app.emit_startup_safety_alerts",
+        lambda *, role: calls.append(role) or [],
+    )
+
+    with warnings.catch_warnings():
+        warnings.simplefilter("ignore", DeprecationWarning)
+        game_server = importlib.import_module("server.game_server")
+
+    monkeypatch.setattr(game_server, "emit_startup_safety_alerts", lambda *, role: calls.append(role) or [])
+
+    create_app()
+    with warnings.catch_warnings():
+        warnings.simplefilter("ignore", DeprecationWarning)
+        game_server.create_game_server_app()
+
+    assert "main" in calls
+    assert "game_server" in calls
