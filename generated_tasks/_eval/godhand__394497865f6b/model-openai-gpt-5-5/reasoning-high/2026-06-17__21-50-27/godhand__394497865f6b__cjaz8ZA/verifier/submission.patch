+++ b/repo/server/tests/test_health.py
@@ -0,0 +1,58 @@
+from __future__ import annotations
+
+from fastapi.testclient import TestClient
+
+from server.app import create_app
+from server.config import reset_settings_cache
+from server.external.db.mongo import MongoDBClient
+
+
+def test_liveness_response_stays_unchanged(client):
+    response = client.get("/health")
+
+    assert response.status_code == 200
+    assert response.json() == {"status": "ok"}
+
+
+def test_readiness_returns_ready_when_dependencies_are_available(client):
+    response = client.get("/health/ready")
+
+    assert response.status_code == 200
+    assert response.json() == {
+        "status": "ready",
+        "checks": {
+            "configuration": {"status": "ok"},
+            "mongodb": {"status": "ok"},
+        },
+    }
+
+
+def test_readiness_returns_not_ready_when_mongodb_is_unavailable(client):
+    MongoDBClient.close()
+
+    response = client.get("/health/ready")
+
+    assert response.status_code == 503
+    payload = response.json()
+    assert payload["status"] == "not_ready"
+    assert payload["checks"]["configuration"] == {"status": "ok"}
+    assert payload["checks"]["mongodb"]["status"] == "fail"
+
+
+def test_readiness_returns_not_ready_when_critical_config_is_missing(monkeypatch):
+    monkeypatch.delenv("SECRET_KEY", raising=False)
+    monkeypatch.setenv("JWT_SECRET_KEY", "short")
+    reset_settings_cache()
+
+    app = create_app()
+    with TestClient(app) as test_client:
+        live_response = test_client.get("/health")
+        ready_response = test_client.get("/health/ready")
+
+    assert live_response.status_code == 200
+    assert live_response.json() == {"status": "ok"}
+    assert ready_response.status_code == 503
+    payload = ready_response.json()
+    assert payload["status"] == "not_ready"
+    assert payload["checks"]["configuration"]["status"] == "fail"
+
