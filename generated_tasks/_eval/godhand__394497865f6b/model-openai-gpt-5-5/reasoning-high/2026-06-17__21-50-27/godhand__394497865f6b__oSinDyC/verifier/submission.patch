 from fastapi import APIRouter, Request
+from fastapi.responses import JSONResponse
 
+from server.config import get_app_config
+from server.external.db.mongo import MongoDBClient
 from server.utils.logging import get_app_logger
 
 app_logger = get_app_logger()
@@ -12,3 +15,52 @@ def health_check(request: Request):
     client_host = request.client.host if request.client else "unknown"
     app_logger.info(f"Health check received from {client_host}")
     return {"status": "ok"}
+
+
+def _check_config_ready() -> dict[str, str]:
+    cfg = get_app_config()
+    missing = []
+    if not getattr(cfg, "SECRET_KEY", ""):
+        missing.append("SECRET_KEY")
+    if not getattr(cfg, "JWT_SECRET_KEY", ""):
+        missing.append("JWT_SECRET_KEY")
+    if missing:
+        return {
+            "status": "error",
+            "detail": "Missing required configuration: " + ", ".join(missing),
+        }
+    return {"status": "ok"}
+
+
+def _check_mongodb_ready() -> dict[str, str]:
+    try:
+        client = MongoDBClient.get_client()
+        MongoDBClient.get_db_name()
+        if not getattr(MongoDBClient, "_is_mock", False):
+            client.admin.command("ping")
+    except Exception as exc:
+        return {"status": "error", "detail": str(exc)}
+    return {"status": "ok"}
+
+
+def build_readiness_payload() -> tuple[int, dict[str, object]]:
+    checks = {
+        "config": _check_config_ready(),
+        "mongodb": _check_mongodb_ready(),
+    }
+    is_ready = all(check["status"] == "ok" for check in checks.values())
+    return (
+        200 if is_ready else 503,
+        {
+            "status": "ready" if is_ready else "not_ready",
+            "checks": checks,
+        },
+    )
+
+
+@health_routes.get("/ready")
+def readiness_check():
+    status_code, payload = build_readiness_payload()
+    if status_code != 200:
+        return JSONResponse(status_code=status_code, content=payload)
+    return payload
