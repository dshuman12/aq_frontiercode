+from server.external.db.mongo import MongoDBClient
+
+
+def test_health_liveness_response_stays_unchanged(client):
+    response = client.get("/health")
+
+    assert response.status_code == 200
+    assert response.json() == {"status": "ok"}
+
+
+def test_readiness_reports_ready_when_dependencies_are_initialized(client):
+    response = client.get("/ready")
+
+    assert response.status_code == 200
+    payload = response.json()
+    assert payload["status"] == "ready"
+    assert payload["checks"]["config"]["status"] == "ok"
+    assert payload["checks"]["mongodb"]["status"] == "ok"
+
+
+def test_readiness_reports_not_ready_when_mongodb_is_not_initialized(client):
+    MongoDBClient.close()
+
+    response = client.get("/ready")
+
+    assert response.status_code == 503
+    payload = response.json()
+    assert payload["status"] == "not_ready"
+    assert payload["checks"]["config"]["status"] == "ok"
+    assert payload["checks"]["mongodb"]["status"] == "error"
