+func TestStateStore_GetReturnsIsolatedCopy(t *testing.T) {
+	s := NewStateStore("n1")
+	s.Put("key1", []byte("value1"))
+	v, ok := s.Get("key1")
+	if !ok {
+		t.Fatal("expected key1 to exist")
+	}
+
+	v[0] = 'X'
+	got, ok := s.Get("key1")
+	if !ok || string(got) != "value1" {
+		t.Fatalf("mutating Get result corrupted stored value: got (%s, %v)", got, ok)
+	}
+}
+
+func TestStateStore_GetRefReturnsLiveValue(t *testing.T) {
+	s := NewStateStore("n1")
+	s.Put("key1", []byte("value1"))
+	ref, ok := s.GetRef("key1")
+	if !ok || string(ref) != "value1" {
+		t.Fatalf("expected live value1 ref, got (%s, %v)", ref, ok)
+	}
+
+	ref[0] = 'X'
+	got, ok := s.Get("key1")
+	if !ok || string(got) != "Xalue1" {
+		t.Fatalf("expected GetRef to return live stored value, got (%s, %v)", got, ok)
+	}
+
+	_, ok = s.GetRef("missing")
+	if ok {
+		t.Fatal("expected false for missing key")
+	}
+	s.Delete("key1")
+	_, ok = s.GetRef("key1")
+	if ok {
+		t.Fatal("expected false for tombstoned key")
+	}
+}
