+func TestStateStore_GetRefConcurrentReadOnlyAccess(t *testing.T) {
+	s := NewStateStore("n1")
+	s.Put("hot", []byte("value-0"))
+
+	const iterations = 1000
+	start := make(chan struct{})
+	var wg sync.WaitGroup
+	for i := 0; i < 8; i++ {
+		wg.Add(1)
+		go func() {
+			defer wg.Done()
+			<-start
+			for j := 0; j < iterations; j++ {
+				if v, ok := s.GetRef("hot"); ok && len(v) > 0 {
+					_ = v[0]
+					_ = v[len(v)-1]
+				}
+				if v, ok := s.Get("hot"); ok && len(v) > 0 {
+					v[0] = 'x'
+				}
+				_ = s.Hash()
+			}
+		}()
+	}
+
+	wg.Add(1)
+	go func() {
+		defer wg.Done()
+		<-start
+		for j := 0; j < iterations; j++ {
+			s.Put("hot", []byte(fmt.Sprintf("value-%d", j)))
+			s.Put(fmt.Sprintf("cold-%d", j), []byte("value"))
+			if j%10 == 0 {
+				s.Delete("deleted")
+			}
+		}
+	}()
+
+	close(start)
+	wg.Wait()
+}
