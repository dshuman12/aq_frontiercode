+func TestRing_AddMaintainsSortedOrderAfterManyInserts(t *testing.T) {
+	const (
+		nodes    = 1000
+		replicas = 17
+	)
+	r := NewRing(replicas)
+	for i := nodes - 1; i >= 0; i-- {
+		r.Add(fmt.Sprintf("node-%04d", i))
+	}
+
+	if got, want := len(r.ring), nodes*replicas; got != want {
+		t.Fatalf("expected %d virtual nodes, got %d", want, got)
+	}
+	if len(r.nodes) != len(r.ring) {
+		t.Fatalf("owner index length mismatch: ring=%d nodes=%d", len(r.ring), len(r.nodes))
+	}
+	for i := 1; i < len(r.ring); i++ {
+		if r.ring[i-1] > r.ring[i] {
+			t.Fatalf("ring out of order at %d: %d > %d", i, r.ring[i-1], r.ring[i])
+		}
+	}
+}
