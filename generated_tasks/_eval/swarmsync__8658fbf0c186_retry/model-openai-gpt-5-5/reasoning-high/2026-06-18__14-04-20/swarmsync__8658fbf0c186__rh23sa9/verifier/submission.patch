+}
+
+func TestRing_LookupDuplicatePointsStable(t *testing.T) {
+	key, h := keyMatchingHash(t, "duplicate", func(h uint32) bool {
+		return h > 10 && h < ^uint32(0)-10
+	})
+	r := &Ring{
+		ring: []uint32{h - 1, h, h, h + 1},
+		nodes: []string{
+			"before",
+			"first-duplicate",
+			"second-duplicate",
+			"after",
+		},
+		nodeMap: map[uint32]string{
+			h - 1: "before",
+			h:     "first-duplicate",
+			h + 1: "after",
+		},
+		members: map[string]bool{
+			"before":           true,
+			"first-duplicate":  true,
+			"second-duplicate": true,
+			"after":            true,
+		},
+		memberCount: 4,
+	}
+
+	if got := r.Lookup(key); got != "first-duplicate" {
+		t.Fatalf("expected first duplicate owner, got %q", got)
+	}
+	gotN := r.LookupN(key, 3)
+	wantN := []string{"first-duplicate", "second-duplicate", "after"}
+	if len(gotN) != len(wantN) {
+		t.Fatalf("LookupN duplicate order mismatch: got %v want %v", gotN, wantN)
+	}
+	for i := range wantN {
+		if gotN[i] != wantN[i] {
+			t.Fatalf("LookupN duplicate order mismatch: got %v want %v", gotN, wantN)
+		}
+	}
+
+	r.Remove("first-duplicate")
+	if got := r.Lookup(key); got != "second-duplicate" {
+		t.Fatalf("expected remaining duplicate owner after remove, got %q", got)
+	}
+}
+
+func keyMatchingHash(t *testing.T, prefix string, match func(uint32) bool) (string, uint32) {
+	t.Helper()
+	for i := 0; i < 1_000_000; i++ {
+		key := fmt.Sprintf("%s-%d", prefix, i)
+		h := keyHash(key)
+		if match(h) {
+			return key, h
+		}
+	}
+	t.Fatalf("could not find key matching hash predicate for %q", prefix)
+	return "", 0
+}
