+		wg.Add(1)
+		go func() {
+			defer wg.Done()
+			<-start
+			for j := 0; j < 1000; j++ {
+				v, ok := s.GetRef("shared")
+				if ok && len(v) > 0 {
+					_ = v[0]
+					_ = v[len(v)-1]
+				}
+			}
+		}()
+	}
+	close(start)
+	wg.Wait()
