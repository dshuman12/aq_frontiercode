+func TestStateStore_GetCopyIsolationAndGetRefLiveValue(t *testing.T) {
+	s := NewStateStore("n1")
+	s.Put("key1", []byte("value1"))
+
+	v, ok := s.Get("key1")
+	if !ok {
+		t.Fatal("expected key1 from Get")
+	}
+	v[0] = 'V'
+
+	ref, ok := s.GetRef("key1")
+	if !ok {
+		t.Fatal("expected key1 from GetRef")
+	}
+	if string(ref) != "value1" {
+		t.Fatalf("mutating Get result should not affect stored value, got %q", ref)
+	}
+
+	ref[0] = 'V'
+	v, ok = s.Get("key1")
+	if !ok || string(v) != "Value1" {
+		t.Fatalf("GetRef should return the live stored value, got (%q, %v)", v, ok)
+	}
+}
