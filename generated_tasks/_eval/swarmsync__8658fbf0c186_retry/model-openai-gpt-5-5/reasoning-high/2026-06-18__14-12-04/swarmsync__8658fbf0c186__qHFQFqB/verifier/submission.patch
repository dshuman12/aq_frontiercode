+func TestStateStore_GetRefReturnsLiveValue(t *testing.T) {
+	s := NewStateStore("n1")
+	s.Put("key1", []byte("value1"))
+
+	ref, ok := s.GetRef("key1")
+	if !ok || string(ref) != "value1" {
+		t.Fatalf("expected live value1 ref, got (%q, %v)", ref, ok)
+	}
+
+	s.mu.RLock()
+	defer s.mu.RUnlock()
+	stored := s.entries["key1"].Value
+	if len(ref) == 0 || len(stored) == 0 || &ref[0] != &stored[0] {
+		t.Fatal("GetRef should return the stored value without copying")
+	}
+}
