+func findKeyWithHash(t *testing.T, prefix string, match func(uint32) bool) string {
+	t.Helper()
+	for i := 0; i < 100000; i++ {
+		key := fmt.Sprintf("%s-%d", prefix, i)
+		if match(keyHash(key)) {
+			return key
+		}
+	}
+	t.Fatalf("could not find matching key for prefix %q", prefix)
+	return ""
