+// GetRef retrieves a value by key without copying it.
+// The returned slice aliases the store and must be treated as read-only.
+func (s *StateStore) GetRef(key string) ([]byte, bool) {
+	s.mu.RLock()
+	defer s.mu.RUnlock()
+	e, ok := s.entries[key]
+	if !ok || e.Tombstone {
+		return nil, false
+	}
+	return e.Value, true
+}
