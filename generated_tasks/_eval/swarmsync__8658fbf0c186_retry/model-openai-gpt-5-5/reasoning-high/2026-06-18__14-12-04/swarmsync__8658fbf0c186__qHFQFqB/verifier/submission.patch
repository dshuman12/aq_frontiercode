+func TestStateStore_GetRefConcurrentAccess(t *testing.T) {
+	s := NewStateStore("n1")
+	for i := 0; i < 16; i++ {
+		s.Put(fmt.Sprintf("key-%d", i), []byte(fmt.Sprintf("initial-%d", i)))
+	}
+
+	var wg sync.WaitGroup
+	for i := 0; i < 8; i++ {
+		wg.Add(1)
+		i := i
+		go func() {
+			defer wg.Done()
+			for j := 0; j < 1000; j++ {
+				key := fmt.Sprintf("key-%d", (i+j)%16)
+				s.Put(key, []byte(fmt.Sprintf("writer-%d-%d", i, j)))
+			}
+		}()
+	}
+	for i := 0; i < 8; i++ {
+		wg.Add(1)
+		i := i
+		go func() {
+			defer wg.Done()
+			for j := 0; j < 1000; j++ {
+				key := fmt.Sprintf("key-%d", (i+j)%16)
+				if ref, ok := s.GetRef(key); ok && len(ref) > 0 {
+					_ = ref[0]
+				}
+				if cp, ok := s.Get(key); ok && len(cp) > 0 {
+					cp[0] ^= 0xff
+				}
+				_ = s.Hash()
+			}
+		}()
+	}
+	wg.Wait()
+}
