+func TestStateStore_GetReturnsIsolatedCopy(t *testing.T) {
+	s := NewStateStore("n1")
+	s.Put("key1", []byte("value1"))
+
+	v, ok := s.Get("key1")
+	if !ok {
+		t.Fatal("expected key1 to exist")
+	}
+	v[0] = 'V'
+
+	stored, ok := s.Get("key1")
+	if !ok || string(stored) != "value1" {
+		t.Fatalf("mutating Get result corrupted stored value: %q", stored)
+	}
+}
