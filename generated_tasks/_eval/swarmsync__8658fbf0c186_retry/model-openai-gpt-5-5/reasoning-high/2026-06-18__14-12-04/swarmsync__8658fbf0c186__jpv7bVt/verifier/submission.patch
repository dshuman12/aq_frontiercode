+func TestStateStore_GetReturnsIsolatedCopy(t *testing.T) {
+	s := NewStateStore("n1")
+	s.Put("key1", []byte("value1"))
+
+	v, ok := s.Get("key1")
+	if !ok {
+		t.Fatal("expected key1 to exist")
+	}
+	v[0] = 'V'
+
+	ref, ok := s.GetRef("key1")
+	if !ok {
+		t.Fatal("expected key1 to exist")
+	}
+	if string(ref) != "value1" {
+		t.Fatalf("mutating Get result changed stored value to %q", ref)
+	}
+}
+
+func TestStateStore_GetRefReturnsStoredValue(t *testing.T) {
+	s := NewStateStore("n1")
+	s.Put("key1", []byte("value1"))
+
+	ref, ok := s.GetRef("key1")
+	if !ok || string(ref) != "value1" {
+		t.Fatalf("expected live value1 reference, got (%s, %v)", ref, ok)
+	}
+
+	s.mu.RLock()
+	stored := s.entries["key1"].Value
+	sameBackingArray := len(ref) > 0 && len(stored) > 0 && &ref[0] == &stored[0]
+	s.mu.RUnlock()
+	if !sameBackingArray {
+		t.Fatal("GetRef should return the stored slice without copying")
+	}
+}
