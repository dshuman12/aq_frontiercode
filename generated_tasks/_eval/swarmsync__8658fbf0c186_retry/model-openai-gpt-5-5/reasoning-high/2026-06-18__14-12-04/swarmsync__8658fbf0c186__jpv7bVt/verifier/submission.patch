+func TestStateStore_GetRefConcurrentReadOnlyAccess(t *testing.T) {
+	s := NewStateStore("n1")
+	s.Put("shared", []byte("value-0"))
+
+	var wg sync.WaitGroup
+	start := make(chan struct{})
+
+	for i := 0; i < 8; i++ {
+		wg.Add(1)
+		i := i
+		go func() {
+			defer wg.Done()
+			<-start
+			for j := 0; j < 200; j++ {
+				s.Put("shared", []byte(fmt.Sprintf("value-%d-%d", i, j)))
+			}
+		}()
+	}
+
+	for i := 0; i < 16; i++ {
+		wg.Add(1)
+		go func() {
+			defer wg.Done()
+			<-start
+			for j := 0; j < 500; j++ {
+				ref, ok := s.GetRef("shared")
+				if ok && len(ref) > 0 {
+					_ = ref[0]
+					_ = ref[len(ref)-1]
+				}
+
+				cp, ok := s.Get("shared")
+				if ok && len(cp) > 0 {
+					cp[0] = 'x'
+				}
+			}
+		}()
+	}
+
+	close(start)
+	wg.Wait()
+}
