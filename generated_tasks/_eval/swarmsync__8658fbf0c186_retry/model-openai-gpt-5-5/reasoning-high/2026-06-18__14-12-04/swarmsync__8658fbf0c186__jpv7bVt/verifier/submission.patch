+func TestRing_AddMaintainsSortedOrderAfterManyInserts(t *testing.T) {
+	r := NewRing(17)
+	for i := 0; i < 250; i++ {
+		r.Add(fmt.Sprintf("node-%03d", i))
+		if !sort.SliceIsSorted(r.ring, func(i, j int) bool { return r.ring[i] < r.ring[j] }) {
+			t.Fatalf("ring is not sorted after adding node-%03d", i)
+		}
+	}
+	if r.VirtualNodeCount() != 250*17 {
+		t.Fatalf("expected %d virtual nodes, got %d", 250*17, r.VirtualNodeCount())
+	}
+}
+
+func TestRing_LookupHashWrapAroundAndDuplicatePoints(t *testing.T) {
+	r := NewRing(1)
+	r.insertVirtualNode(100, "a")
+	r.insertVirtualNode(200, "b")
+	r.insertVirtualNode(200, "c")
+	r.insertVirtualNode(300, "d")
+
+	if got := r.lookupHash(99); got != "a" {
+		t.Fatalf("expected hash before first point to resolve to a, got %q", got)
+	}
+	if got := r.lookupHash(200); got != "c" {
+		t.Fatalf("expected duplicate point to resolve to latest owner c, got %q", got)
+	}
+	if got := r.lookupHash(201); got != "d" {
+		t.Fatalf("expected hash after duplicate point to resolve to d, got %q", got)
+	}
+	if got := r.lookupHash(301); got != "a" {
+		t.Fatalf("expected hash past last point to wrap to a, got %q", got)
+	}
+}
+
+func TestRing_InsertVirtualNodeKeepsDuplicatePointsStable(t *testing.T) {
