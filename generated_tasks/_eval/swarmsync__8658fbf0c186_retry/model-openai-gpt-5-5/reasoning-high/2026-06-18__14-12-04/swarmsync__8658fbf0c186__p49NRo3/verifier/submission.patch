+func TestStateStore_GetRefConcurrentAccess(t *testing.T) {
+	s := NewStateStore("n1")
+	s.Put("shared", []byte("value"))
+
+	var wg sync.WaitGroup
+	errs := make(chan string, 16)
+	for i := 0; i < 16; i++ {
+		wg.Add(1)
+		i := i
+		go func() {
+			defer wg.Done()
+			for j := 0; j < 500; j++ {
+				key := fmt.Sprintf("key-%d-%d", i, j)
+				s.Put(key, []byte(fmt.Sprintf("val-%d-%d", i, j)))
+				if ref, ok := s.GetRef("shared"); !ok || len(ref) == 0 || ref[0] != 'v' {
+					errs <- fmt.Sprintf("unexpected GetRef result: %q %v", ref, ok)
+					return
+				}
+				if v, ok := s.Get("shared"); !ok || len(v) == 0 || v[0] != 'v' {
+					errs <- fmt.Sprintf("unexpected Get result: %q %v", v, ok)
+					return
+				}
+				_ = s.Hash()
+			}
+		}()
+	}
+	wg.Wait()
+	close(errs)
+	for err := range errs {
+		t.Fatal(err)
+	}
+}
