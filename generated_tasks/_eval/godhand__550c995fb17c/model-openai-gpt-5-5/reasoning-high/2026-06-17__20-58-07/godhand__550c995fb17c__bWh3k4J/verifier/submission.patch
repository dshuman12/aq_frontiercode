+def _lobby_browser_ids(response):
+    assert response.status_code == 200, response.text
+    payload = response.json()
+    assert set(payload.keys()) == {"lobbies"}
+    assert isinstance(payload["lobbies"], list)
+    return [lobby["id"] for lobby in payload["lobbies"]]
+
+
+def test_default_lobby_route_matches_collection_route():
+    app = create_app()
+    with TestClient(app) as client:
+        default_response = client.get(f"/api/v1/lobbies/{LobbyRouteDefaults.DEFAULT_PATH}")
+        collection_response = client.get("/api/v1/lobbies")
+
+        assert _lobby_browser_ids(default_response) == _lobby_browser_ids(collection_response)
+
+
+def test_unmatched_lobby_get_route_falls_back_to_default_route():
+    app = create_app()
+    with TestClient(app) as client:
+        fallback_response = client.get("/api/v1/lobbies/not/a/real/route")
+        default_response = client.get(f"/api/v1/lobbies/{LobbyRouteDefaults.DEFAULT_PATH}")
+
+        assert _lobby_browser_ids(fallback_response) == _lobby_browser_ids(default_response)
+
+
+def test_missing_lobby_id_still_returns_not_found():
+    app = create_app()
+    with TestClient(app) as client:
+        response = client.get("/api/v1/lobbies/64b7f2f2f2f2f2f2f2f2f2f2")
+
+        assert response.status_code == 404
+        assert response.json()["detail"] == "Lobby not found"
+
+
+def test_lobby_fallback_routes_are_deterministic_when_reordered_and_repeated():
+    app = create_app()
+    with TestClient(app) as client:
+        routes = [
+            f"/api/v1/lobbies/{LobbyRouteDefaults.DEFAULT_PATH}",
+            "/api/v1/lobbies/not/a/real/route",
+            "/api/v1/lobbies",
+        ]
+        expected = _lobby_browser_ids(client.get(routes[0]))
+
+        for route in [routes[2], routes[1], routes[0], routes[1], routes[2], routes[0]]:
+            assert _lobby_browser_ids(client.get(route)) == expected
