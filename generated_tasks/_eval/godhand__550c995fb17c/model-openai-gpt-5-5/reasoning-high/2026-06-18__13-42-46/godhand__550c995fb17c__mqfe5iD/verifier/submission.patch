+async def reset_all_lobby_runtime_state(*, disconnect_reason: str = "Test reset.") -> dict[str, int]:
+    cancelled_snapshot_tasks = 0
+    cancelled_lockstep_tasks = 0
+
+    async with _snapshot_lock:
+        _pending_snapshot_by_lobby.clear()
+        snapshot_tasks = list(_snapshot_flush_task_by_lobby.values())
+        _snapshot_flush_task_by_lobby.clear()
+    for task in snapshot_tasks:
+        if not task.done():
+            task.cancel()
+            cancelled_snapshot_tasks += 1
+
+    async with _presence_lock:
+        _presence_by_lobby.clear()
+
+    async with _lockstep_lock:
+        lockstep_states = list(_lockstep_state_by_lobby.values())
+        _lockstep_state_by_lobby.clear()
+    for state in lockstep_states:
+        if state.task and not state.task.done():
+            state.task.cancel()
+            cancelled_lockstep_tasks += 1
+
+    closed_connections = await game_connection_hub.close_all(
+        code=1012,
+        reason=disconnect_reason[:120],
+    )
+    return {
+        "closedConnections": closed_connections,
+        "cancelledSnapshotTasks": cancelled_snapshot_tasks,
+        "cancelledLockstepTasks": cancelled_lockstep_tasks,
+    }
+
+
