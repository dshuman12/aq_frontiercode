+    async def close_all(self, *, code: int = 1012, reason: str = "") -> int:
+        async with self._lock:
+            lobbies = self._lobbies
+            self._lobbies = {}
+            sockets = [ws for lobby in lobbies.values() for ws in lobby.keys()]
+
+        closed = 0
+        for ws in sockets:
+            try:
+                await ws.close(code=code, reason=reason)
+                closed += 1
+            except Exception:
+                pass
+        return closed
