+        assert payload["chatWsUrl"].endswith(f"/api/v1/ws/lobby/{lobby['_id']}")
+
+
+def test_lobby_fallback_is_deterministic_after_unrelated_state_changes():
+    app = create_app()
+    with TestClient(app) as client:
+        create_and_login(client, "deterministic-viewer@example.com")
+
+        first = client.get("/api/v1/lobbies/not-a-real-lobby-route")
+        assert first.status_code == 200, first.text
+
+        create_lobby(client, "unrelated-custom-lobby", user_capacity=4)
+
+        second = client.get("/api/v1/lobbies/not-a-real-lobby-route")
+        third = client.get(f"/api/v1/lobbies/{LobbyDefaults.KIND_OFFICIAL}")
+
+        assert second.status_code == 200, second.text
+        assert third.status_code == 200, third.text
+        assert [item["id"] for item in second.json()["lobbies"]] == [
+            item["id"] for item in first.json()["lobbies"]
+        ]
+        assert third.json() == second.json()
