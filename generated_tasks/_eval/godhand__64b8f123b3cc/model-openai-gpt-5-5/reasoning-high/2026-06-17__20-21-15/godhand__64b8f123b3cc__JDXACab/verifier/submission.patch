+import hmac
+from secrets import token_urlsafe
+
+from fastapi import Request, Response
+
+from server.api.security.cookies import CookieUtils
+from server.config import get_app_config
+from server.utils.constants import ResponseMessages, TokenExpiry
+from server.utils.error_handlers import AuthenticationError
+from server.utils.logging import get_app_logger
+
+app_logger = get_app_logger()
+
+_ANON_CSRF_COOKIE = "anon_csrf"
+_ACCESS_CSRF_COOKIE = "csrf_access_token"
+_REFRESH_CSRF_COOKIE = "csrf_refresh_token"
+
+
+def _verify_header_matches_cookie(request: Request, cookie_name: str, label: str) -> None:
+    cfg = get_app_config()
+    header_name = cfg.CSRF_HEADER_NAME or "X-CSRF-TOKEN"
+    header_val = request.headers.get(header_name)
+    cookie_val = request.cookies.get(cookie_name)
+
+    if not header_val or not cookie_val:
+        app_logger.warning("%s CSRF missing (header or cookie)", label)
+        raise AuthenticationError(ResponseMessages.CSRF_TOKEN_INVALID)
+
+    if not hmac.compare_digest(header_val, cookie_val):
+        app_logger.warning("%s CSRF mismatch", label)
+        raise AuthenticationError(ResponseMessages.CSRF_TOKEN_INVALID)
+
+
+class Csrf:
+    @staticmethod
+    def issue_anon_csrf_token(response: Response, *, token: str | None = None) -> str:
+        token_value = token or token_urlsafe(32)
+        max_age = int(TokenExpiry.CSRF_TOKEN_HOURS * 60 * 60)
+        CookieUtils.set_cookie(
+            response,
+            _ANON_CSRF_COOKIE,
+            token_value,
+            max_age=max_age,
+            httponly=False,
+        )
+        app_logger.info("Issued anonymous CSRF token")
+        return token_value
+
+    @staticmethod
+    def clear_anon_csrf(response: Response) -> None:
+        CookieUtils.delete_cookie(response, _ANON_CSRF_COOKIE)
+
+    @staticmethod
+    def verify_header_matches_cookie(request: Request) -> None:
+        _verify_header_matches_cookie(request, _ANON_CSRF_COOKIE, "Anonymous")
+
+
+def verify_anon_csrf(request: Request) -> None:
+    Csrf.verify_header_matches_cookie(request)
+
+
+def verify_access_csrf(request: Request) -> None:
+    # JWTService.require_access still validates the token claim against this cookie.
+    _verify_header_matches_cookie(request, _ACCESS_CSRF_COOKIE, "Access")
+
+
+def verify_refresh_csrf(request: Request) -> None:
+    # JWTService.require_refresh still validates the token claim against this cookie.
+    _verify_header_matches_cookie(request, _REFRESH_CSRF_COOKIE, "Refresh")
