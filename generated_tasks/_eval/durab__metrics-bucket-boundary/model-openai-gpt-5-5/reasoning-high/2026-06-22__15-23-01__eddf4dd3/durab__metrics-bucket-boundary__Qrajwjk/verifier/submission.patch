+)
 
 func TestMetricAccessors(t *testing.T) {
 	r := New()
@@ -28,3 +31,29 @@ func TestDefaultRegistry(t *testing.T) {
 	}
 	Default.NewCounter("default_counter_ok", "").Inc()
 }
+
+func TestHistogramObserveBoundaryCumulativeBuckets(t *testing.T) {
+	r := New()
+	h := r.NewHistogram("boundary", "boundary help", []float64{1, 10, 100})
+
+	for _, v := range []float64{0.5, 1, 9.999, 10, 10.001, 100, 101} {
+		h.Observe(v)
+	}
+
+	var b strings.Builder
+	h.Write(&b)
+	got := b.String()
+
+	for _, want := range []string{
+		"boundary_bucket{le=\"1\"} 2\n",
+		"boundary_bucket{le=\"10\"} 4\n",
+		"boundary_bucket{le=\"100\"} 6\n",
+		"boundary_bucket{le=\"+Inf\"} 7\n",
+		"boundary_sum 232.5\n",
+		"boundary_count 7\n",
+	} {
+		if !strings.Contains(got, want) {
+			t.Fatalf("histogram output missing %q:\n%s", want, got)
+		}
+	}
+}
