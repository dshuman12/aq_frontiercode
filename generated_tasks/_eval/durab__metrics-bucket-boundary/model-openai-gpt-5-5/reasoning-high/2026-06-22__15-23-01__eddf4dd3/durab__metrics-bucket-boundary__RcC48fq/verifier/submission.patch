 	r := New()
@@ -28,3 +31,30 @@ func TestDefaultRegistry(t *testing.T) {
 	}
 	Default.NewCounter("default_counter_ok", "").Inc()
 }
+
+func TestHistogramObserveBoundaryBuckets(t *testing.T) {
+	r := New()
+	h := r.NewHistogram("latency_seconds", "latency", []float64{10, 1, 5})
+
+	observations := []float64{0.9, 1, 1.1, 4.9, 5, 5.1, 9.9, 10, 10.1, 20}
+	for _, v := range observations {
+		h.Observe(v)
+	}
+
+	var b strings.Builder
+	h.Write(&b)
+	out := b.String()
+
+	for _, want := range []string{
+		`latency_seconds_bucket{le="1"} 2`,
+		`latency_seconds_bucket{le="5"} 5`,
+		`latency_seconds_bucket{le="10"} 8`,
+		`latency_seconds_bucket{le="+Inf"} 10`,
+		`latency_seconds_sum 68`,
+		`latency_seconds_count 10`,
+	} {
+		if !strings.Contains(out, want+"\n") {
+			t.Fatalf("histogram output missing %q:\n%s", want, out)
+		}
+	}
+}
