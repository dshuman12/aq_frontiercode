index 10b59cc..fab5e02 100644
--- a/base/internal/metrics/trivial_test.go
+++ b/repo/internal/metrics/trivial_test.go
@@ -1,6 +1,10 @@
 package metrics
 
-import "testing"
+import (
+	"strconv"
+	"strings"
+	"testing"
+)
 
 func TestMetricAccessors(t *testing.T) {
 	r := New()
@@ -28,3 +32,92 @@ func TestDefaultRegistry(t *testing.T) {
 	}
 	Default.NewCounter("default_counter_ok", "").Inc()
 }
+
+func TestHistogramObserveBoundaryBuckets(t *testing.T) {
+	r := New()
+	h := r.NewHistogram("request_duration_seconds", "request duration", []float64{100, 1, 10})
+	observations := []float64{
+		0.5,   // below the smallest bound
+		1,     // exactly on the first bound
+		1.1,   // just above the first bound
+		9.9,   // just below the middle bound
+		10,    // exactly on the middle bound
+		10.1,  // just above the middle bound
+		99.9,  // just below the largest bound
+		100,   // exactly on the largest bound
+		100.1, // overflow
+	}
+
+	var wantSum float64
+	for _, observation := range observations {
+		h.Observe(observation)
+		wantSum += observation
+	}
+
+	got := readMetricValues(t, h)
+	want := map[string]float64{
+		`request_duration_seconds_bucket{le="1"}`:    2,
+		`request_duration_seconds_bucket{le="10"}`:   5,
+		`request_duration_seconds_bucket{le="100"}`:  8,
+		`request_duration_seconds_bucket{le="+Inf"}`: float64(len(observations)),
+		"request_duration_seconds_sum":               wantSum,
+		"request_duration_seconds_count":             float64(len(observations)),
+	}
+
+	for name, wantValue := range want {
+		if got[name] != wantValue {
+			t.Fatalf("%s = %v, want %v\nmetrics:\n%s", name, got[name], wantValue, writeMetric(h))
+		}
+	}
+}
+
+func readMetricValues(t *testing.T, m Metric) map[string]float64 {
+	t.Helper()
+
+	values := make(map[string]float64)
+	for _, line := range strings.Split(writeMetric(m), "\n") {
+		if line == "" || strings.HasPrefix(line, "#") {
+			continue
+		}
+		name, value, ok := strings.Cut(line, " ")
+		if !ok {
+			t.Fatalf("metric line %q missing value", line)
+		}
+		parsed, err := strconv.ParseFloat(value, 64)
+		if err != nil {
+			t.Fatalf("metric line %q has invalid value: %v", line, err)
+		}
+		values[name] = parsed
+	}
+	return values
+}
+
+func writeMetric(m Metric) string {
+	var b strings.Builder
+	m.Write(&b)
+	return b.String()
+}
+
+func TestHistogramObserveLargestBoundaryDoesNotOverflow(t *testing.T) {
+	r := New()
+	h := r.NewHistogram("payload_bytes", "payload size", []float64{1, 10})
+
+	h.Observe(10)
+
+	got := readMetricValues(t, h)
+	for name, want := range map[string]float64{
+		`payload_bytes_bucket{le="1"}`:    0,
+		`payload_bytes_bucket{le="10"}`:   1,
+		`payload_bytes_bucket{le="+Inf"}`: 1,
+		"payload_bytes_sum":               10,
+		"payload_bytes_count":             1,
+	} {
+		if got[name] != want {
+			t.Fatalf("%s = %v, want %v\nmetrics:\n%s", name, got[name], want, writeMetric(h))
+		}
+	}
+
+	if got[`payload_bytes_bucket{le="10"}`] != got[`payload_bytes_bucket{le="+Inf"}`] {
+		t.Fatalf("largest boundary observation overflowed:\n%s", writeMetric(h))
+	}
+}
