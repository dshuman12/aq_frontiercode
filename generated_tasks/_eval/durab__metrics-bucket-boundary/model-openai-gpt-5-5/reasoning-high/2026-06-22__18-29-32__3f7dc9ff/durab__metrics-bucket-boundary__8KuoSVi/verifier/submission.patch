+)
 
 func TestMetricAccessors(t *testing.T) {
 	r := New()
@@ -28,3 +31,36 @@ func TestDefaultRegistry(t *testing.T) {
 	}
 	Default.NewCounter("default_counter_ok", "").Inc()
 }
+
+func TestHistogramObserveBoundaryBuckets(t *testing.T) {
+	r := New()
+	h := r.NewHistogram("request_duration_seconds", "request duration", []float64{1, 10, 100})
+
+	for _, v := range []float64{
+		0.999,   // just below the first boundary
+		1,       // exactly on the first boundary
+		1.001,   // just above the first boundary
+		10,      // exactly on the middle boundary
+		100,     // exactly on the largest boundary
+		100.001, // overflow
+	} {
+		h.Observe(v)
+	}
+
+	var b strings.Builder
+	h.Write(&b)
+	got := b.String()
+
+	for _, want := range []string{
+		`request_duration_seconds_bucket{le="1"} 2`,
+		`request_duration_seconds_bucket{le="10"} 4`,
+		`request_duration_seconds_bucket{le="100"} 5`,
+		`request_duration_seconds_bucket{le="+Inf"} 6`,
+		`request_duration_seconds_sum 213.001`,
+		`request_duration_seconds_count 6`,
+	} {
+		if !strings.Contains(got, want) {
+			t.Fatalf("histogram output missing %q:\n%s", want, got)
+		}
+	}
+}
