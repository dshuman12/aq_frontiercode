+
+func TestHistogramObserveBoundaryBuckets(t *testing.T) {
+	h := New().NewHistogram("request_duration_seconds", "request duration", []float64{1, 2.5, 5})
+
+	observations := []float64{
+		1,   // first boundary
+		2.5, // middle boundary
+		5,   // largest boundary
+	}
+	for _, v := range observations {
+		h.Observe(v)
+	}
+
+	assertHistogram(t, h, []string{
+		`request_duration_seconds_bucket{le="1"} 1`,
+		`request_duration_seconds_bucket{le="2.5"} 2`,
+		`request_duration_seconds_bucket{le="5"} 3`,
+		`request_duration_seconds_bucket{le="+Inf"} 3`,
+		`request_duration_seconds_sum 8.5`,
+		`request_duration_seconds_count 3`,
+	})
+}
+
+func TestHistogramObserveAroundBoundariesAndOverflow(t *testing.T) {
+	h := New().NewHistogram("payload_bytes", "payload size", []float64{1, 2.5, 5})
+
+	observations := []float64{
+		0.999, // just below first boundary
+		1.001, // just above first boundary
+		6,     // overflow
+		7,     // overflow
+	}
+	for _, v := range observations {
+		h.Observe(v)
+	}
+
+	assertHistogram(t, h, []string{
+		`payload_bytes_bucket{le="1"} 1`,
+		`payload_bytes_bucket{le="2.5"} 2`,
+		`payload_bytes_bucket{le="5"} 2`,
+		`payload_bytes_bucket{le="+Inf"} 4`,
+		`payload_bytes_sum 15`,
+		`payload_bytes_count 4`,
+	})
+}
+
+func assertHistogram(t *testing.T, h *Histogram, wantLines []string) {
+	t.Helper()
+
+	var b strings.Builder
+	h.Write(&b)
+	got := b.String()
+	for _, want := range wantLines {
+		line := fmt.Sprintf("%s\n", want)
+		if !strings.Contains(got, line) {
+			t.Fatalf("histogram output missing %q\noutput:\n%s", want, got)
+		}
+	}
+}
