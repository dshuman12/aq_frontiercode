@@ -1,6 +1,11 @@
 package metrics
 
-import "testing"
+import (
+	"math"
+	"strconv"
+	"strings"
+	"testing"
+)
 
 func TestMetricAccessors(t *testing.T) {
 	r := New()
@@ -28,3 +33,90 @@ func TestDefaultRegistry(t *testing.T) {
 	}
 	Default.NewCounter("default_counter_ok", "").Inc()
 }
+
+func TestHistogramObserveBoundaryValuesAreCumulative(t *testing.T) {
+	h := New().NewHistogram("h", "hh", []float64{1, 2, 5})
+
+	observations := []float64{1, 2, 5}
+	for _, v := range observations {
+		h.Observe(v)
+	}
+
+	assertHistogram(t, h, map[string]uint64{
+		"1":    1,
+		"2":    2,
+		"5":    3,
+		"+Inf": 3,
+	}, 3, 8)
+}
+
+func TestHistogramObserveKeepsNonBoundaryPlacement(t *testing.T) {
+	h := New().NewHistogram("h", "hh", []float64{1, 2, 5})
+
+	observations := []float64{0.9, 1.9, 2.1, 6}
+	for _, v := range observations {
+		h.Observe(v)
+	}
+
+	assertHistogram(t, h, map[string]uint64{
+		"1":    1,
+		"2":    2,
+		"5":    3,
+		"+Inf": 4,
+	}, 4, 10.9)
+}
+
+func assertHistogram(t *testing.T, h *Histogram, wantBuckets map[string]uint64, wantTotal uint64, wantSum float64) {
+	t.Helper()
+
+	if h.total != wantTotal {
+		t.Fatalf("total = %d, want %d", h.total, wantTotal)
+	}
+	if math.Abs(h.sum-wantSum) > 1e-9 {
+		t.Fatalf("sum = %v, want %v", h.sum, wantSum)
+	}
+
+	gotBuckets := readHistogramBuckets(t, h)
+	for bucket, want := range wantBuckets {
+		if got := gotBuckets[bucket]; got != want {
+			t.Fatalf("bucket %s = %d, want %d", bucket, got, want)
+		}
+	}
+}
+
+func readHistogramBuckets(t *testing.T, h *Histogram) map[string]uint64 {
+	t.Helper()
+
+	var b strings.Builder
+	h.Write(&b)
+
+	buckets := make(map[string]uint64)
+	for _, line := range strings.Split(b.String(), "\n") {
+		if !strings.HasPrefix(line, h.name+"_bucket") {
+			continue
+		}
+
+		start := strings.Index(line, `le="`)
+		if start < 0 {
+			t.Fatalf("bucket line missing le label: %q", line)
+		}
+		start += len(`le="`)
+		end := strings.Index(line[start:], `"`)
+		if end < 0 {
+			t.Fatalf("bucket line has malformed le label: %q", line)
+		}
+
+		fields := strings.Fields(line)
+		if len(fields) != 2 {
+			t.Fatalf("bucket line has malformed value: %q", line)
+		}
+		count, err := strconv.ParseUint(fields[1], 10, 64)
+		if err != nil {
+			t.Fatalf("parse bucket count from %q: %v", line, err)
+		}
+
+		buckets[line[start:start+end]] = count
+	}
+
+	return buckets
+}
