+func TestHistogramObserveBoundaryPlacement(t *testing.T) {
+	tests := []struct {
+		name        string
+		observe     float64
+		wantBuckets []bucketCount
+	}{
+		{
+			name:    "below smallest bound",
+			observe: 0.999,
+			wantBuckets: []bucketCount{
+				{le: "1", count: 1},
+				{le: "10", count: 1},
+				{le: "20", count: 1},
+				{le: "+Inf", count: 1},
+			},
+		},
+		{
+			name:    "equal smallest bound",
+			observe: 1,
+			wantBuckets: []bucketCount{
+				{le: "1", count: 1},
+				{le: "10", count: 1},
+				{le: "20", count: 1},
+				{le: "+Inf", count: 1},
+			},
+		},
+		{
+			name:    "just above smallest bound",
+			observe: 1.001,
+			wantBuckets: []bucketCount{
+				{le: "1", count: 0},
+				{le: "10", count: 1},
+				{le: "20", count: 1},
+				{le: "+Inf", count: 1},
+			},
+		},
+		{
+			name:    "just below middle bound",
+			observe: 9.999,
+			wantBuckets: []bucketCount{
+				{le: "1", count: 0},
+				{le: "10", count: 1},
+				{le: "20", count: 1},
+				{le: "+Inf", count: 1},
+			},
+		},
+		{
+			name:    "equal middle bound",
+			observe: 10,
+			wantBuckets: []bucketCount{
+				{le: "1", count: 0},
+				{le: "10", count: 1},
+				{le: "20", count: 1},
+				{le: "+Inf", count: 1},
+			},
+		},
+		{
+			name:    "just above middle bound",
+			observe: 10.001,
+			wantBuckets: []bucketCount{
+				{le: "1", count: 0},
+				{le: "10", count: 0},
+				{le: "20", count: 1},
+				{le: "+Inf", count: 1},
+			},
+		},
+		{
+			name:    "equal largest bound",
+			observe: 20,
+			wantBuckets: []bucketCount{
+				{le: "1", count: 0},
+				{le: "10", count: 0},
+				{le: "20", count: 1},
+				{le: "+Inf", count: 1},
+			},
+		},
+		{
+			name:    "just above largest bound overflows",
+			observe: 20.001,
+			wantBuckets: []bucketCount{
+				{le: "1", count: 0},
+				{le: "10", count: 0},
+				{le: "20", count: 0},
+				{le: "+Inf", count: 1},
+			},
+		},
+		{
+			name:    "well above largest bound overflows",
+			observe: 100,
+			wantBuckets: []bucketCount{
+				{le: "1", count: 0},
+				{le: "10", count: 0},
+				{le: "20", count: 0},
+				{le: "+Inf", count: 1},
+			},
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			h := New().NewHistogram("test_histogram", "test histogram", []float64{1, 10, 20})
+			h.Observe(tt.observe)
+
+			gotBuckets, gotSum, gotCount := histogramSnapshot(t, h)
+			if !reflect.DeepEqual(gotBuckets, tt.wantBuckets) {
+				t.Fatalf("bucket counts = %+v, want %+v", gotBuckets, tt.wantBuckets)
+			}
+			if gotCount != 1 {
+				t.Fatalf("count = %d, want 1", gotCount)
+			}
+			if math.Abs(gotSum-tt.observe) > 1e-12 {
+				t.Fatalf("sum = %v, want %v", gotSum, tt.observe)
+			}
+		})
+	}
+}
+
+type bucketCount struct {
+	le    string
+	count uint64
+}
+
+func histogramSnapshot(t *testing.T, h *Histogram) ([]bucketCount, float64, uint64) {
+	t.Helper()
+
+	var out strings.Builder
+	h.Write(&out)
+
+	var buckets []bucketCount
+	var sum float64
+	var count uint64
+	var foundSum, foundCount bool
+
+	for _, line := range strings.Split(strings.TrimSpace(out.String()), "\n") {
+		fields := strings.Fields(line)
+		if len(fields) != 2 {
+			continue
+		}
+
+		switch fields[0] {
+		case "test_histogram_sum":
+			var err error
+			sum, err = strconv.ParseFloat(fields[1], 64)
+			if err != nil {
+				t.Fatalf("parse sum %q: %v", fields[1], err)
+			}
+			foundSum = true
+		case "test_histogram_count":
+			var err error
+			count, err = strconv.ParseUint(fields[1], 10, 64)
+			if err != nil {
+				t.Fatalf("parse count %q: %v", fields[1], err)
+			}
+			foundCount = true
+		default:
+			const bucketPrefix = `test_histogram_bucket{le="`
+			const bucketSuffix = `"}`
+			if strings.HasPrefix(fields[0], bucketPrefix) && strings.HasSuffix(fields[0], bucketSuffix) {
+				bucketValue, err := strconv.ParseUint(fields[1], 10, 64)
+				if err != nil {
+					t.Fatalf("parse bucket count %q: %v", fields[1], err)
+				}
+				le := strings.TrimSuffix(strings.TrimPrefix(fields[0], bucketPrefix), bucketSuffix)
+				buckets = append(buckets, bucketCount{le: le, count: bucketValue})
+			}
+		}
+	}
+
+	if !foundSum {
+		t.Fatalf("histogram sum not found in output:\n%s", out.String())
+	}
+	if !foundCount {
+		t.Fatalf("histogram count not found in output:\n%s", out.String())
+	}
+
+	return buckets, sum, count
+}
