@@ -1,6 +1,9 @@
 package metrics
 
-import "testing"
+import (
+	"strings"
+	"testing"
+)
 
 func TestMetricAccessors(t *testing.T) {
 	r := New()
@@ -28,3 +31,39 @@ func TestDefaultRegistry(t *testing.T) {
 	}
 	Default.NewCounter("default_counter_ok", "").Inc()
 }
+
+func TestHistogramObserveBoundaryCumulativeBuckets(t *testing.T) {
+	h := New().NewHistogram("h", "hh", []float64{1, 10, 20})
+
+	observations := []float64{
+		1,      // first boundary
+		10,     // middle boundary
+		20,     // largest boundary
+		9.999,  // just below middle boundary
+		10.001, // just above middle boundary
+		0.5,    // below smallest boundary
+		21,     // overflow
+		100,    // overflow
+	}
+	for _, observation := range observations {
+		h.Observe(observation)
+	}
+
+	var b strings.Builder
+	h.Write(&b)
+	output := b.String()
+
+	assertMetricLine(t, output, `h_bucket{le="1"} 2`)
+	assertMetricLine(t, output, `h_bucket{le="10"} 4`)
+	assertMetricLine(t, output, `h_bucket{le="20"} 6`)
+	assertMetricLine(t, output, `h_bucket{le="+Inf"} 8`)
+	assertMetricLine(t, output, "h_sum 172.5")
+	assertMetricLine(t, output, "h_count 8")
+}
+
+func assertMetricLine(t *testing.T, output, want string) {
+	t.Helper()
+	if !strings.Contains(output, want+"\n") {
+		t.Fatalf("metric line %q not found in:\n%s", want, output)
+	}
+}
