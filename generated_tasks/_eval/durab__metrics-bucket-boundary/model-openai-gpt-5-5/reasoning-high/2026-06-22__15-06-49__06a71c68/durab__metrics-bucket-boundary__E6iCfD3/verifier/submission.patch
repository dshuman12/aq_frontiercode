diff --git a/base/internal/metrics/trivial_test.go b/repo/internal/metrics/trivial_test.go
index 10b59cc..4697afa 100644
--- a/base/internal/metrics/trivial_test.go
+++ b/repo/internal/metrics/trivial_test.go
@@ -28,3 +28,49 @@ func TestDefaultRegistry(t *testing.T) {
 	}
 	Default.NewCounter("default_counter_ok", "").Inc()
 }
+
+func TestHistogramObserveBoundaryValues(t *testing.T) {
+	h := New().NewHistogram("h", "hh", []float64{1, 10, 25})
+
+	for _, v := range []float64{1, 10, 25} {
+		h.Observe(v)
+	}
+
+	wantCounts := []uint64{1, 1, 1}
+	for i, want := range wantCounts {
+		if h.counts[i] != want {
+			t.Fatalf("bucket %d count = %d, want %d", i, h.counts[i], want)
+		}
+	}
+
+	var bucketed uint64
+	for _, count := range h.counts {
+		bucketed += count
+	}
+	if overflow := h.total - bucketed; overflow != 0 {
+		t.Fatalf("overflow count = %d, want 0", overflow)
+	}
+}
+
+func TestHistogramObserveBucketEdgesAndOverflow(t *testing.T) {
+	h := New().NewHistogram("h", "hh", []float64{1, 10, 25})
+
+	h.Observe(0.5)
+	h.Observe(9.999)
+	h.Observe(25.001)
+
+	wantCounts := []uint64{1, 1, 0}
+	for i, want := range wantCounts {
+		if h.counts[i] != want {
+			t.Fatalf("bucket %d count = %d, want %d", i, h.counts[i], want)
+		}
+	}
+
+	var bucketed uint64
+	for _, count := range h.counts {
+		bucketed += count
+	}
+	if overflow := h.total - bucketed; overflow != 1 {
+		t.Fatalf("overflow count = %d, want 1", overflow)
+	}
+}
