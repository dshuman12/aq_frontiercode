@@ -1,6 +1,9 @@
 package metrics
 
-import "testing"
+import (
+	"reflect"
+	"testing"
+)
 
 func TestMetricAccessors(t *testing.T) {
 	r := New()
@@ -28,3 +31,71 @@ func TestDefaultRegistry(t *testing.T) {
 	}
 	Default.NewCounter("default_counter_ok", "").Inc()
 }
+
+func TestHistogramObserveBucketBoundaries(t *testing.T) {
+	tests := []struct {
+		name     string
+		value    float64
+		counts   []uint64
+		overflow uint64
+	}{
+		{
+			name:     "below smallest bound",
+			value:    0.5,
+			counts:   []uint64{1, 0, 0},
+			overflow: 0,
+		},
+		{
+			name:     "equal smallest bound",
+			value:    1,
+			counts:   []uint64{1, 0, 0},
+			overflow: 0,
+		},
+		{
+			name:     "just below middle bound",
+			value:    4.999,
+			counts:   []uint64{0, 1, 0},
+			overflow: 0,
+		},
+		{
+			name:     "equal middle bound",
+			value:    5,
+			counts:   []uint64{0, 1, 0},
+			overflow: 0,
+		},
+		{
+			name:     "equal largest bound",
+			value:    10,
+			counts:   []uint64{0, 0, 1},
+			overflow: 0,
+		},
+		{
+			name:     "above largest bound",
+			value:    10.001,
+			counts:   []uint64{0, 0, 0},
+			overflow: 1,
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			h := New().NewHistogram("h", "hh", []float64{1, 5, 10})
+			h.Observe(tt.value)
+
+			if !reflect.DeepEqual(h.counts, tt.counts) {
+				t.Fatalf("counts = %v, want %v", h.counts, tt.counts)
+			}
+			if got := h.total - sumCounts(h.counts); got != tt.overflow {
+				t.Fatalf("overflow = %d, want %d", got, tt.overflow)
+			}
+		})
+	}
+}
+
+func sumCounts(counts []uint64) uint64 {
+	var total uint64
+	for _, count := range counts {
+		total += count
+	}
+	return total
+}
