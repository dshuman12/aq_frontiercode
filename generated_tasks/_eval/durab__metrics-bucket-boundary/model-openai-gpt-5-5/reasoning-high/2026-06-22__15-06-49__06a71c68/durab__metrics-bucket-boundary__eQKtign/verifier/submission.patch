diff --git a/base/internal/metrics/trivial_test.go b/repo/internal/metrics/trivial_test.go
index 10b59cc..30a628f 100644
--- a/base/internal/metrics/trivial_test.go
+++ b/repo/internal/metrics/trivial_test.go
@@ -28,3 +28,71 @@ func TestDefaultRegistry(t *testing.T) {
 	}
 	Default.NewCounter("default_counter_ok", "").Inc()
 }
+
+func TestHistogramObserveBucketBoundaries(t *testing.T) {
+	h := New().NewHistogram("request_seconds", "", []float64{10, 1, 5})
+
+	steps := []struct {
+		name         string
+		value        float64
+		wantCounts   []uint64
+		wantOverflow uint64
+	}{
+		{
+			name:         "below smallest bound",
+			value:        0.5,
+			wantCounts:   []uint64{1, 0, 0},
+			wantOverflow: 0,
+		},
+		{
+			name:         "equal to smallest bound",
+			value:        1,
+			wantCounts:   []uint64{2, 0, 0},
+			wantOverflow: 0,
+		},
+		{
+			name:         "below middle bound",
+			value:        4.999,
+			wantCounts:   []uint64{2, 1, 0},
+			wantOverflow: 0,
+		},
+		{
+			name:         "equal to middle bound",
+			value:        5,
+			wantCounts:   []uint64{2, 2, 0},
+			wantOverflow: 0,
+		},
+		{
+			name:         "equal to largest bound",
+			value:        10,
+			wantCounts:   []uint64{2, 2, 1},
+			wantOverflow: 0,
+		},
+		{
+			name:         "above largest bound",
+			value:        10.001,
+			wantCounts:   []uint64{2, 2, 1},
+			wantOverflow: 1,
+		},
+	}
+
+	for _, step := range steps {
+		t.Run(step.name, func(t *testing.T) {
+			h.Observe(step.value)
+
+			if len(h.counts) != len(step.wantCounts) {
+				t.Fatalf("bucket count length = %d, want %d", len(h.counts), len(step.wantCounts))
+			}
+			var counted uint64
+			for i, want := range step.wantCounts {
+				if h.counts[i] != want {
+					t.Fatalf("bucket %v count = %d, want %d", h.buckets[i], h.counts[i], want)
+				}
+				counted += h.counts[i]
+			}
+			if overflow := h.total - counted; overflow != step.wantOverflow {
+				t.Fatalf("overflow count = %d, want %d", overflow, step.wantOverflow)
+			}
+		})
+	}
+}
