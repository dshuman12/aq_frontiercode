+func TestHistogramObserveBoundaryBuckets(t *testing.T) {
+	r := New()
+	h := r.NewHistogram("observe", "observations", []float64{1, 2.5, 10})
+	values := []float64{
+		0.5,   // below the smallest bound
+		1,     // exactly the first bound
+		2,     // strictly between bounds
+		2.49,  // just below a bound
+		2.5,   // exactly a middle bound
+		2.51,  // just above a bound
+		10,    // exactly the largest bound
+		11,    // overflow
+	}
+
+	var wantSum float64
+	for _, v := range values {
+		h.Observe(v)
+		wantSum += v
+	}
+
+	lines := metricLines(t, h)
+	wantBuckets := map[string]string{
+		`observe_bucket{le="1"}`:    "2",
+		`observe_bucket{le="2.5"}`:  "5",
+		`observe_bucket{le="10"}`:   "7",
+		`observe_bucket{le="+Inf"}`: "8",
+	}
+	for name, want := range wantBuckets {
+		if got := lines[name]; got != want {
+			t.Fatalf("%s = %s, want %s\nmetrics:\n%s", name, got, want, renderMetric(h))
+		}
+	}
+	if got := h.total; got != uint64(len(values)) {
+		t.Fatalf("total = %d, want %d", got, len(values))
+	}
+	if h.sum != wantSum {
+		t.Fatalf("sum = %v, want %v", h.sum, wantSum)
+	}
+	if got := lines["observe_count"]; got != strconv.Itoa(len(values)) {
+		t.Fatalf("observe_count = %s, want %d", got, len(values))
+	}
+	if got := lines["observe_sum"]; got != strconv.FormatFloat(wantSum, 'g', -1, 64) {
+		t.Fatalf("observe_sum = %s, want %v", got, wantSum)
+	}
+}
+
+func metricLines(t *testing.T, h *Histogram) map[string]string {
+	t.Helper()
+	lines := make(map[string]string)
+	for _, line := range strings.Split(renderMetric(h), "\n") {
+		fields := strings.Fields(line)
+		if len(fields) == 2 {
+			lines[fields[0]] = fields[1]
+		}
+	}
+	return lines
+}
+
+func renderMetric(h *Histogram) string {
+	var b strings.Builder
+	h.Write(&b)
+	return b.String()
+}
