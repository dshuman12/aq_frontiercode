diff --git a/repo/tests/test_mst.cpp b/repo/tests/test_mst.cpp
new file mode 100644
index 0000000..683f38a
--- /dev/null
+++ b/repo/tests/test_mst.cpp
@@ -0,0 +1,121 @@
+#include "test_framework.hpp"
+#include "mst/mst.hpp"
+
+using namespace cryo;
+using namespace cryo_test;
+
+namespace {
+
+Graph undirected_graph_with_nodes(size_t n) {
+    Graph g(GraphType::Undirected);
+    for (size_t i = 0; i < n; i++) g.add_node_with_id(i);
+    return g;
+}
+
+void assert_connected_mst_parity(const Graph& g) {
+    auto km = kruskal(g);
+    auto pm = prim(g, 0);
+    auto bm = boruvka(g);
+
+    assert_false(km.is_forest, "kruskal should produce a tree");
+    assert_false(pm.is_forest, "prim should produce a tree");
+    assert_false(bm.is_forest, "boruvka should produce a tree");
+    assert_true(is_spanning_tree(g, bm), "boruvka result should span the graph");
+    assert_eq(bm.edges.size(), g.node_count() - 1, "boruvka edge count");
+    assert_near(bm.total_weight, km.total_weight, 1e-9, "boruvka vs kruskal");
+    assert_near(bm.total_weight, pm.total_weight, 1e-9, "boruvka vs prim");
+}
+
+} // namespace
+
+CRYO_TEST(MST, BoruvkaConsidersBothEndpointComponents) {
+    auto g = undirected_graph_with_nodes(4);
+    g.add_edge(0, 1, 10.0);
+    g.add_edge(0, 2, 1.0);
+    g.add_edge(1, 2, 2.0);
+    g.add_edge(1, 3, 1.0);
+    g.add_edge(2, 3, 10.0);
+
+    auto km = kruskal(g);
+    auto pm = prim(g, 0);
+    auto bm = boruvka(g);
+
+    assert_near(km.total_weight, 4.0, 1e-9);
+    assert_near(pm.total_weight, 4.0, 1e-9);
+    assert_near(bm.total_weight, 4.0, 1e-9);
+    assert_true(is_spanning_tree(g, bm));
+}
+
+CRYO_TEST(MST, BoruvkaEqualWeightEdges) {
+    auto g = undirected_graph_with_nodes(4);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(1, 2, 1.0);
+    g.add_edge(2, 3, 1.0);
+    g.add_edge(3, 0, 1.0);
+    g.add_edge(0, 2, 1.0);
+    g.add_edge(1, 3, 1.0);
+
+    assert_connected_mst_parity(g);
+    assert_near(boruvka(g).total_weight, 3.0, 1e-9);
+}
+
+CRYO_TEST(MST, BoruvkaMultipleComponentsMerge) {
+    auto g = undirected_graph_with_nodes(5);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(0, 2, 1.0);
+    g.add_edge(3, 4, 1.0);
+    g.add_edge(2, 3, 2.0);
+    g.add_edge(1, 4, 5.0);
+    g.add_edge(1, 2, 6.0);
+
+    assert_connected_mst_parity(g);
+    assert_near(boruvka(g).total_weight, 5.0, 1e-9);
+}
+
+CRYO_TEST(MST, BoruvkaSingleNode) {
+    auto g = undirected_graph_with_nodes(1);
+
+    auto km = kruskal(g);
+    auto pm = prim(g, 0);
+    auto bm = boruvka(g);
+
+    assert_true(bm.edges.empty());
+    assert_false(bm.is_forest);
+    assert_true(is_spanning_tree(g, bm));
+    assert_near(bm.total_weight, 0.0, 1e-9);
+    assert_near(bm.total_weight, km.total_weight, 1e-9);
+    assert_near(bm.total_weight, pm.total_weight, 1e-9);
+}
+
+CRYO_TEST(MST, BoruvkaDisconnectedForestWeight) {
+    auto g = undirected_graph_with_nodes(6);
+    g.add_edge(0, 1, 2.0);
+    g.add_edge(1, 2, 1.0);
+    g.add_edge(0, 2, 5.0);
+    g.add_edge(3, 4, 7.0);
+
+    auto km = kruskal(g);
+    auto bm = boruvka(g);
+
+    assert_true(km.is_forest);
+    assert_true(bm.is_forest);
+    assert_eq(bm.edges.size(), (size_t)3);
+    assert_false(is_spanning_tree(g, bm));
+    assert_near(km.total_weight, 10.0, 1e-9);
+    assert_near(bm.total_weight, km.total_weight, 1e-9);
+}
+
+CRYO_TEST(MST, BoruvkaMatchesKruskalAndPrimOnConnectedGraph) {
+    auto g = undirected_graph_with_nodes(6);
+    g.add_edge(0, 1, 4.0);
+    g.add_edge(0, 2, 3.0);
+    g.add_edge(1, 2, 1.0);
+    g.add_edge(1, 3, 2.0);
+    g.add_edge(2, 3, 4.0);
+    g.add_edge(3, 4, 2.0);
+    g.add_edge(4, 5, 6.0);
+    g.add_edge(2, 5, 7.0);
+    g.add_edge(3, 5, 3.0);
+
+    assert_connected_mst_parity(g);
+}
