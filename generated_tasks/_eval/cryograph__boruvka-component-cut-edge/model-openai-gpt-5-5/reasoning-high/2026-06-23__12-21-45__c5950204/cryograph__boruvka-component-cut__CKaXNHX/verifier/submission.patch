diff --git a/repo/tests/test_mst.cpp b/repo/tests/test_mst.cpp
new file mode 100644
index 0000000..03e6fcb
--- /dev/null
+++ b/repo/tests/test_mst.cpp
@@ -0,0 +1,118 @@
+#include "test_framework.hpp"
+#include "mst/mst.hpp"
+
+using namespace cryo;
+using namespace cryo_test;
+
+namespace {
+
+void add_nodes(Graph& g, size_t count) {
+    for (size_t i = 0; i < count; i++) {
+        g.add_node_with_id(i);
+    }
+}
+
+void assert_boruvka_matches_connected_mst(const Graph& g) {
+    auto km = kruskal(g);
+    auto pm = prim(g, 0);
+    auto bm = boruvka(g);
+
+    assert_near(bm.total_weight, km.total_weight, 1e-9);
+    assert_near(bm.total_weight, pm.total_weight, 1e-9);
+    assert_true(is_spanning_tree(g, bm));
+}
+
+} // namespace
+
+CRYO_TEST(MST, BoruvkaUsesCheapestEdgeFromBothEndpointComponents) {
+    Graph g(GraphType::Undirected);
+    add_nodes(g, 4);
+
+    g.add_edge(0, 1, 100.0);
+    g.add_edge(0, 2, 1.0);
+    g.add_edge(1, 2, 2.0);
+    g.add_edge(1, 3, 1.0);
+    g.add_edge(2, 3, 100.0);
+
+    auto bm = boruvka(g);
+    assert_near(bm.total_weight, 4.0, 1e-9);
+    assert_boruvka_matches_connected_mst(g);
+}
+
+CRYO_TEST(MST, BoruvkaHandlesEqualWeightEdges) {
+    Graph g(GraphType::Undirected);
+    add_nodes(g, 4);
+
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(1, 2, 1.0);
+    g.add_edge(2, 3, 1.0);
+    g.add_edge(3, 0, 1.0);
+    g.add_edge(0, 2, 2.0);
+    g.add_edge(1, 3, 2.0);
+
+    assert_boruvka_matches_connected_mst(g);
+}
+
+CRYO_TEST(MST, BoruvkaMergesMultipleComponentsInOnePhase) {
+    Graph g(GraphType::Undirected);
+    add_nodes(g, 6);
+
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(2, 3, 1.0);
+    g.add_edge(4, 5, 1.0);
+    g.add_edge(1, 2, 3.0);
+    g.add_edge(3, 4, 3.0);
+    g.add_edge(0, 5, 10.0);
+
+    auto bm = boruvka(g);
+    assert_eq(bm.edges.size(), g.node_count() - 1);
+    assert_near(bm.total_weight, 9.0, 1e-9);
+    assert_boruvka_matches_connected_mst(g);
+}
+
+CRYO_TEST(MST, BoruvkaHandlesSingleNodeGraph) {
+    Graph g(GraphType::Undirected);
+    g.add_node_with_id(0);
+
+    auto bm = boruvka(g);
+    assert_true(bm.edges.empty());
+    assert_near(bm.total_weight, 0.0, 1e-9);
+    assert_false(bm.is_forest);
+    assert_true(is_spanning_tree(g, bm));
+}
+
+CRYO_TEST(MST, BoruvkaMatchesKruskalForestOnDisconnectedGraph) {
+    Graph g(GraphType::Undirected);
+    add_nodes(g, 6);
+
+    g.add_edge(0, 1, 4.0);
+    g.add_edge(1, 2, 1.0);
+    g.add_edge(0, 2, 10.0);
+    g.add_edge(3, 4, 2.0);
+
+    auto km = kruskal(g);
+    auto bm = boruvka(g);
+
+    assert_true(bm.is_forest);
+    assert_eq(bm.edges.size(), km.edges.size());
+    assert_near(bm.total_weight, km.total_weight, 1e-9);
+    assert_near(bm.total_weight, 7.0, 1e-9);
+}
+
+CRYO_TEST(MST, BoruvkaMatchesKruskalAndPrimOnDenseConnectedGraph) {
+    Graph g(GraphType::Undirected);
+    add_nodes(g, 6);
+
+    g.add_edge(0, 1, 7.0);
+    g.add_edge(0, 2, 3.0);
+    g.add_edge(0, 3, 8.0);
+    g.add_edge(1, 2, 2.0);
+    g.add_edge(1, 4, 6.0);
+    g.add_edge(2, 3, 5.0);
+    g.add_edge(2, 4, 4.0);
+    g.add_edge(2, 5, 9.0);
+    g.add_edge(3, 5, 1.0);
+    g.add_edge(4, 5, 2.0);
+
+    assert_boruvka_matches_connected_mst(g);
+}
