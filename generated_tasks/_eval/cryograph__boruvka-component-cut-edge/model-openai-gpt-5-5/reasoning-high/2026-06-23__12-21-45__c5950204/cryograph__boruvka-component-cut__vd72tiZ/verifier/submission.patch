diff --git a/repo/tests/test_mst.cpp b/repo/tests/test_mst.cpp
new file mode 100644
index 0000000..ad00d34
--- /dev/null
+++ b/repo/tests/test_mst.cpp
@@ -0,0 +1,103 @@
+#include "test_framework.hpp"
+#include "mst/mst.hpp"
+
+using namespace cryo;
+using namespace cryo_test;
+
+namespace {
+
+Graph make_graph(size_t n) {
+    Graph g(GraphType::Undirected);
+    for (size_t i = 0; i < n; i++) {
+        g.add_node_with_id(i);
+    }
+    return g;
+}
+
+void assert_same_weight(double actual, double expected, const std::string& ctx) {
+    assert_near(actual, expected, 1e-9, ctx);
+}
+
+void assert_connected_algorithms_match(const Graph& g) {
+    auto km = kruskal(g);
+    auto pm = prim(g, 0);
+    auto bm = boruvka(g);
+
+    assert_true(is_spanning_tree(g, km), "kruskal spanning tree");
+    assert_true(is_spanning_tree(g, pm), "prim spanning tree");
+    assert_true(is_spanning_tree(g, bm), "boruvka spanning tree");
+    assert_same_weight(bm.total_weight, km.total_weight, "boruvka matches kruskal");
+    assert_same_weight(bm.total_weight, pm.total_weight, "boruvka matches prim");
+}
+
+} // namespace
+
+CRYO_TEST(MST, BoruvkaConsidersBothEndpointComponents) {
+    auto g = make_graph(4);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(0, 2, 2.0);
+    g.add_edge(1, 2, 10.0);
+    g.add_edge(2, 3, 100.0);
+
+    auto bm = boruvka(g);
+    assert_true(is_spanning_tree(g, bm), "boruvka spanning tree");
+    assert_same_weight(bm.total_weight, 103.0, "boruvka picks the cheaper 0-2 edge");
+    assert_connected_algorithms_match(g);
+}
+
+CRYO_TEST(MST, BoruvkaEqualWeightEdges) {
+    auto g = make_graph(4);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(0, 2, 1.0);
+    g.add_edge(1, 2, 1.0);
+    g.add_edge(1, 3, 2.0);
+    g.add_edge(2, 3, 2.0);
+
+    auto bm = boruvka(g);
+    assert_true(is_spanning_tree(g, bm), "boruvka spanning tree");
+    assert_same_weight(bm.total_weight, 4.0, "equal-weight mst total");
+    assert_connected_algorithms_match(g);
+}
+
+CRYO_TEST(MST, BoruvkaMergesMultipleComponentsInOnePhase) {
+    auto g = make_graph(4);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(2, 3, 1.0);
+    g.add_edge(1, 2, 5.0);
+    g.add_edge(0, 3, 10.0);
+
+    auto bm = boruvka(g);
+    assert_true(is_spanning_tree(g, bm), "boruvka spanning tree");
+    assert_eq(bm.edges.size(), static_cast<size_t>(3), "mst edge count");
+    assert_same_weight(bm.total_weight, 7.0, "multiple component merge total");
+    assert_connected_algorithms_match(g);
+}
+
+CRYO_TEST(MST, BoruvkaSingleNode) {
+    auto g = make_graph(1);
+    auto bm = boruvka(g);
+
+    assert_true(is_spanning_tree(g, bm), "single-node spanning tree");
+    assert_eq(bm.edges.size(), static_cast<size_t>(0), "single-node edge count");
+    assert_false(bm.is_forest, "single node is not a forest result");
+    assert_same_weight(bm.total_weight, 0.0, "single-node total");
+}
+
+CRYO_TEST(MST, BoruvkaDisconnectedForestMatchesKruskal) {
+    auto g = make_graph(5);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(1, 2, 2.0);
+    g.add_edge(0, 2, 5.0);
+    g.add_edge(3, 4, 4.0);
+
+    auto km = kruskal(g);
+    auto bm = boruvka(g);
+
+    assert_true(km.is_forest, "kruskal reports forest");
+    assert_true(bm.is_forest, "boruvka reports forest");
+    assert_false(is_spanning_tree(g, bm), "disconnected graph has no spanning tree");
+    assert_eq(bm.edges.size(), static_cast<size_t>(3), "forest edge count");
+    assert_same_weight(bm.total_weight, km.total_weight, "boruvka forest weight matches kruskal");
+    assert_same_weight(bm.total_weight, 7.0, "disconnected forest total");
+}
+
