diff --git a/repo/tests/test_mst.cpp b/repo/tests/test_mst.cpp
new file mode 100644
index 0000000..36f889c
--- /dev/null
+++ b/repo/tests/test_mst.cpp
@@ -0,0 +1,109 @@
+#include "test_framework.hpp"
+#include "generator/generator.hpp"
+#include "mst/mst.hpp"
+
+using namespace cryo;
+using namespace cryo_test;
+
+namespace {
+
+Graph make_undirected_graph(size_t node_count) {
+    Graph g(GraphType::Undirected);
+    for (size_t i = 0; i < node_count; i++) {
+        g.add_node_with_id(i);
+    }
+    return g;
+}
+
+void assert_mst_weight_parity(const Graph& g) {
+    auto km = kruskal(g);
+    auto pm = prim(g, 0);
+    auto bm = boruvka(g);
+
+    assert_near(bm.total_weight, km.total_weight, 1e-9, "boruvka vs kruskal");
+    assert_near(bm.total_weight, pm.total_weight, 1e-9, "boruvka vs prim");
+    assert_true(is_spanning_tree(g, bm), "boruvka should produce a spanning tree");
+}
+
+} // namespace
+
+CRYO_TEST(MST, BoruvkaConsidersBothEndpointComponents) {
+    auto g = make_undirected_graph(3);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(0, 2, 1.0);
+    g.add_edge(1, 2, 2.0);
+
+    auto bm = boruvka(g);
+    auto km = kruskal(g);
+    auto pm = prim(g, 0);
+
+    assert_near(bm.total_weight, 2.0, 1e-9);
+    assert_near(bm.total_weight, km.total_weight, 1e-9);
+    assert_near(bm.total_weight, pm.total_weight, 1e-9);
+    assert_true(is_spanning_tree(g, bm));
+}
+
+CRYO_TEST(MST, BoruvkaEqualWeightEdges) {
+    auto g = make_undirected_graph(4);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(0, 2, 1.0);
+    g.add_edge(0, 3, 1.0);
+    g.add_edge(1, 2, 1.0);
+    g.add_edge(1, 3, 1.0);
+    g.add_edge(2, 3, 1.0);
+
+    auto bm = boruvka(g);
+
+    assert_near(bm.total_weight, 3.0, 1e-9);
+    assert_true(is_spanning_tree(g, bm));
+}
+
+CRYO_TEST(MST, BoruvkaMergesMultipleComponentsPerPhase) {
+    auto g = make_undirected_graph(6);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(2, 3, 1.0);
+    g.add_edge(4, 5, 1.0);
+    g.add_edge(1, 2, 2.0);
+    g.add_edge(3, 4, 2.0);
+    g.add_edge(0, 5, 10.0);
+    g.add_edge(1, 4, 8.0);
+
+    assert_mst_weight_parity(g);
+    assert_near(boruvka(g).total_weight, 7.0, 1e-9);
+}
+
+CRYO_TEST(MST, BoruvkaSingleNode) {
+    auto g = make_undirected_graph(1);
+    auto bm = boruvka(g);
+
+    assert_eq(bm.edges.size(), static_cast<size_t>(0));
+    assert_near(bm.total_weight, 0.0, 1e-9);
+    assert_false(bm.is_forest);
+    assert_true(is_spanning_tree(g, bm));
+}
+
+CRYO_TEST(MST, BoruvkaDisconnectedForestMatchesKruskal) {
+    auto g = make_undirected_graph(6);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(0, 2, 1.0);
+    g.add_edge(1, 2, 2.0);
+    g.add_edge(3, 4, 5.0);
+
+    auto bm = boruvka(g);
+    auto km = kruskal(g);
+
+    assert_near(bm.total_weight, km.total_weight, 1e-9);
+    assert_near(bm.total_weight, 7.0, 1e-9);
+    assert_eq(bm.edges.size(), static_cast<size_t>(3));
+    assert_true(bm.is_forest);
+    assert_false(is_spanning_tree(g, bm));
+}
+
+CRYO_TEST(MST, BoruvkaMatchesKruskalAndPrimOnConnectedGraphs) {
+    GraphGenerator gen(123);
+
+    for (size_t n = 2; n <= 12; n++) {
+        auto g = gen.random_weighted(n, 1.0, 0.1, 50.0);
+        assert_mst_weight_parity(g);
+    }
+}
