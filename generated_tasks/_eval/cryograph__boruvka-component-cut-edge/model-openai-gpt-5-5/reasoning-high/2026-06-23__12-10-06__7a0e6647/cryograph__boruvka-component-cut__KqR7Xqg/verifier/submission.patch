diff --git a/repo/tests/test_mst.cpp b/repo/tests/test_mst.cpp
new file mode 100644
index 0000000..9e45c1c
--- /dev/null
+++ b/repo/tests/test_mst.cpp
@@ -0,0 +1,118 @@
+#include "test_framework.hpp"
+#include "mst/mst.hpp"
+
+using namespace cryo;
+using namespace cryo_test;
+
+namespace {
+
+void add_nodes(Graph& g, size_t count) {
+    for (size_t i = 0; i < count; i++) {
+        g.add_node_with_id(i);
+    }
+}
+
+void assert_connected_mst_parity(const Graph& g) {
+    auto km = kruskal(g);
+    auto pm = prim(g, 0);
+    auto bm = boruvka(g);
+
+    assert_near(bm.total_weight, km.total_weight, 1e-9, "boruvka matches kruskal");
+    assert_near(bm.total_weight, pm.total_weight, 1e-9, "boruvka matches prim");
+    assert_true(is_spanning_tree(g, bm), "boruvka returns a spanning tree");
+}
+
+} // namespace
+
+CRYO_TEST(MST, BoruvkaRecordsCheapestEdgeForBothEndpointComponents) {
+    Graph g(GraphType::Undirected);
+    add_nodes(g, 3);
+
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(0, 2, 1.0);
+    g.add_edge(1, 2, 2.0);
+
+    auto bm = boruvka(g);
+    assert_near(bm.total_weight, 2.0);
+    assert_eq(bm.edges.size(), (size_t)2);
+    assert_connected_mst_parity(g);
+}
+
+CRYO_TEST(MST, BoruvkaHandlesEqualWeightEdges) {
+    Graph g(GraphType::Undirected);
+    add_nodes(g, 4);
+
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(0, 2, 1.0);
+    g.add_edge(0, 3, 1.0);
+    g.add_edge(1, 2, 1.0);
+    g.add_edge(2, 3, 1.0);
+
+    auto bm = boruvka(g);
+    assert_near(bm.total_weight, 3.0);
+    assert_eq(bm.edges.size(), (size_t)3);
+    assert_connected_mst_parity(g);
+}
+
+CRYO_TEST(MST, BoruvkaMergesMultipleComponentsInOnePhase) {
+    Graph g(GraphType::Undirected);
+    add_nodes(g, 4);
+
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(2, 3, 1.0);
+    g.add_edge(0, 2, 5.0);
+    g.add_edge(1, 3, 5.0);
+    g.add_edge(0, 3, 9.0);
+
+    auto bm = boruvka(g);
+    assert_near(bm.total_weight, 7.0);
+    assert_eq(bm.edges.size(), (size_t)3);
+    assert_connected_mst_parity(g);
+}
+
+CRYO_TEST(MST, BoruvkaMatchesKruskalAndPrimOnConnectedGraph) {
+    Graph g(GraphType::Undirected);
+    add_nodes(g, 6);
+
+    g.add_edge(0, 1, 4.0);
+    g.add_edge(0, 2, 3.0);
+    g.add_edge(1, 2, 1.0);
+    g.add_edge(1, 3, 2.0);
+    g.add_edge(2, 3, 4.0);
+    g.add_edge(2, 4, 6.0);
+    g.add_edge(3, 4, 5.0);
+    g.add_edge(3, 5, 8.0);
+    g.add_edge(4, 5, 7.0);
+
+    assert_connected_mst_parity(g);
+}
+
+CRYO_TEST(MST, BoruvkaHandlesSingleNodeGraph) {
+    Graph g(GraphType::Undirected);
+    g.add_node_with_id(0);
+
+    auto bm = boruvka(g);
+    assert_near(bm.total_weight, 0.0);
+    assert_true(bm.edges.empty());
+    assert_false(bm.is_forest);
+    assert_true(is_spanning_tree(g, bm));
+}
+
+CRYO_TEST(MST, BoruvkaMatchesKruskalForestOnDisconnectedGraph) {
+    Graph g(GraphType::Undirected);
+    add_nodes(g, 6);
+
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(1, 2, 2.0);
+    g.add_edge(0, 2, 3.0);
+    g.add_edge(3, 4, 4.0);
+
+    auto km = kruskal(g);
+    auto bm = boruvka(g);
+
+    assert_true(km.is_forest);
+    assert_true(bm.is_forest);
+    assert_near(bm.total_weight, km.total_weight, 1e-9);
+    assert_near(bm.total_weight, 7.0);
+    assert_eq(bm.edges.size(), km.edges.size());
+}
