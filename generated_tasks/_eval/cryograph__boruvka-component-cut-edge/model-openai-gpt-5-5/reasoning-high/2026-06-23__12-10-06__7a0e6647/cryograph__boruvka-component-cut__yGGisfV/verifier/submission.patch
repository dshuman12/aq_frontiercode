+#include "test_framework.hpp"
+#include "mst/mst.hpp"
+#include <initializer_list>
+#include <tuple>
+
+using namespace cryo;
+using namespace cryo_test;
+
+namespace {
+
+Graph make_undirected_graph(
+    size_t node_count,
+    std::initializer_list<std::tuple<NodeId, NodeId, double>> edges) {
+    Graph g(GraphType::Undirected);
+    for (size_t i = 0; i < node_count; i++) {
+        g.add_node_with_id(i);
+    }
+    for (const auto& [src, dst, weight] : edges) {
+        g.add_edge(src, dst, weight);
+    }
+    return g;
+}
+
+void assert_boruvka_matches_connected_mst(const Graph& g) {
+    auto kruskal_mst = kruskal(g);
+    auto prim_mst = prim(g, 0);
+    auto boruvka_mst = boruvka(g);
+
+    assert_near(boruvka_mst.total_weight, kruskal_mst.total_weight, 1e-9);
+    assert_near(boruvka_mst.total_weight, prim_mst.total_weight, 1e-9);
+    assert_eq(boruvka_mst.edges.size(), g.node_count() - 1);
+    assert_true(is_spanning_tree(g, boruvka_mst));
+}
+
+} // namespace
+
+CRYO_TEST(MST, BoruvkaUsesCheapestEdgeFromBothEndpointComponents) {
+    auto g = make_undirected_graph(4, {
+        {0, 1, 100.0},
+        {0, 2, 1.0},
+        {1, 2, 2.0},
+        {1, 3, 1.0},
+        {2, 3, 100.0},
+    });
+
+    auto boruvka_mst = boruvka(g);
+
+    assert_near(boruvka_mst.total_weight, 4.0, 1e-9);
+    assert_boruvka_matches_connected_mst(g);
+}
+
+CRYO_TEST(MST, BoruvkaHandlesEqualWeightChoices) {
+    auto g = make_undirected_graph(5, {
+        {0, 1, 1.0},
+        {0, 2, 1.0},
+        {1, 2, 1.0},
+        {1, 3, 1.0},
+        {2, 4, 1.0},
+        {3, 4, 1.0},
+    });
+
+    assert_boruvka_matches_connected_mst(g);
+}
+
+CRYO_TEST(MST, BoruvkaMergesMultipleComponentsInOnePhase) {
+    auto g = make_undirected_graph(6, {
+        {0, 1, 1.0},
+        {1, 2, 1.0},
+        {2, 3, 1.0},
+        {3, 4, 1.0},
+        {4, 5, 1.0},
+        {0, 5, 9.0},
+    });
+
+    auto boruvka_mst = boruvka(g);
+
+    assert_near(boruvka_mst.total_weight, 5.0, 1e-9);
+    assert_boruvka_matches_connected_mst(g);
+}
+
+CRYO_TEST(MST, BoruvkaHandlesSingleNodeGraph) {
+    Graph g(GraphType::Undirected);
+    g.add_node_with_id(0);
+
+    auto boruvka_mst = boruvka(g);
+
+    assert_eq(boruvka_mst.edges.size(), static_cast<size_t>(0));
+    assert_near(boruvka_mst.total_weight, 0.0, 1e-9);
+    assert_false(boruvka_mst.is_forest);
+    assert_true(is_spanning_tree(g, boruvka_mst));
+}
+
+CRYO_TEST(MST, BoruvkaMatchesKruskalForestOnDisconnectedGraph) {
+    auto g = make_undirected_graph(6, {
+        {0, 1, 3.0},
+        {0, 2, 2.0},
+        {1, 2, 1.0},
+        {3, 4, 4.0},
+    });
+
+    auto kruskal_forest = kruskal(g);
+    auto boruvka_forest = boruvka(g);
+
+    assert_true(boruvka_forest.is_forest);
+    assert_eq(boruvka_forest.edges.size(), static_cast<size_t>(3));
+    assert_near(boruvka_forest.total_weight, kruskal_forest.total_weight, 1e-9);
+    assert_near(boruvka_forest.total_weight, 7.0, 1e-9);
+}
+
