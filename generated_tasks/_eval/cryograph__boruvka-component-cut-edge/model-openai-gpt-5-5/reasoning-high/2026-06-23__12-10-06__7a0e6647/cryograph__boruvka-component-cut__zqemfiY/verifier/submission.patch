diff --git a/repo/tests/test_mst.cpp b/repo/tests/test_mst.cpp
new file mode 100644
index 0000000..041d4e7
--- /dev/null
+++ b/repo/tests/test_mst.cpp
@@ -0,0 +1,112 @@
+#include "test_framework.hpp"
+#include "mst/mst.hpp"
+
+using namespace cryo;
+using namespace cryo_test;
+
+namespace {
+
+Graph make_undirected_graph(size_t n) {
+    Graph g(GraphType::Undirected);
+    for (size_t i = 0; i < n; i++) {
+        g.add_node_with_id(i);
+    }
+    return g;
+}
+
+void assert_connected_mst_parity(const Graph& g) {
+    auto km = kruskal(g);
+    auto pm = prim(g, 0);
+    auto bm = boruvka(g);
+
+    assert_near(bm.total_weight, km.total_weight, 1e-9);
+    assert_near(bm.total_weight, pm.total_weight, 1e-9);
+    assert_true(is_spanning_tree(g, bm));
+    assert_eq(bm.edges.size(), g.node_count() - 1);
+}
+
+} // namespace
+
+CRYO_TEST(MST, BoruvkaConsidersBothEndpointComponents) {
+    auto g = make_undirected_graph(4);
+    g.add_edge(0, 1, 10.0);
+    g.add_edge(0, 2, 1.0);
+    g.add_edge(1, 2, 100.0);
+    g.add_edge(1, 3, 2.0);
+    g.add_edge(2, 3, 100.0);
+
+    auto bm = boruvka(g);
+
+    assert_connected_mst_parity(g);
+    assert_near(bm.total_weight, 13.0, 1e-9);
+}
+
+CRYO_TEST(MST, BoruvkaHandlesEqualWeightEdges) {
+    auto g = make_undirected_graph(4);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(0, 2, 1.0);
+    g.add_edge(0, 3, 1.0);
+    g.add_edge(1, 2, 1.0);
+    g.add_edge(1, 3, 1.0);
+    g.add_edge(2, 3, 1.0);
+
+    assert_connected_mst_parity(g);
+    assert_near(boruvka(g).total_weight, 3.0, 1e-9);
+}
+
+CRYO_TEST(MST, BoruvkaMergesMultipleComponentsPerPhase) {
+    auto g = make_undirected_graph(4);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(2, 3, 1.0);
+    g.add_edge(1, 2, 5.0);
+    g.add_edge(0, 3, 5.0);
+
+    assert_connected_mst_parity(g);
+    assert_near(boruvka(g).total_weight, 7.0, 1e-9);
+}
+
+CRYO_TEST(MST, BoruvkaHandlesSingleNodeGraph) {
+    auto g = make_undirected_graph(1);
+    auto bm = boruvka(g);
+
+    assert_true(bm.edges.empty());
+    assert_near(bm.total_weight, 0.0, 1e-9);
+    assert_false(bm.is_forest);
+    assert_true(is_spanning_tree(g, bm));
+}
+
+CRYO_TEST(MST, BoruvkaMatchesKruskalForestOnDisconnectedGraph) {
+    auto g = make_undirected_graph(5);
+    g.add_edge(0, 1, 2.0);
+    g.add_edge(2, 3, 3.0);
+
+    auto km = kruskal(g);
+    auto bm = boruvka(g);
+
+    assert_near(bm.total_weight, km.total_weight, 1e-9);
+    assert_near(bm.total_weight, 5.0, 1e-9);
+    assert_eq(bm.edges.size(), (size_t)2);
+    assert_true(bm.is_forest);
+    assert_false(is_spanning_tree(g, bm));
+}
+
+CRYO_TEST(MST, BoruvkaMatchesKruskalAndPrimAcrossConnectedGraphs) {
+    auto sparse = make_undirected_graph(5);
+    sparse.add_edge(0, 1, 4.0);
+    sparse.add_edge(0, 2, 2.0);
+    sparse.add_edge(1, 2, 1.0);
+    sparse.add_edge(1, 3, 7.0);
+    sparse.add_edge(2, 3, 3.0);
+    sparse.add_edge(3, 4, 2.0);
+    sparse.add_edge(2, 4, 8.0);
+    assert_connected_mst_parity(sparse);
+
+    auto dense = make_undirected_graph(6);
+    for (NodeId u = 0; u < 6; u++) {
+        for (NodeId v = u + 1; v < 6; v++) {
+            double weight = static_cast<double>(((u + 3) * (v + 5)) % 11 + 1);
+            dense.add_edge(u, v, weight);
+        }
+    }
+    assert_connected_mst_parity(dense);
+}
