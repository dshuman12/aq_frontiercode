diff --git a/repo/tests/test_mst.cpp b/repo/tests/test_mst.cpp
new file mode 100644
index 0000000..e2131e0
--- /dev/null
+++ b/repo/tests/test_mst.cpp
@@ -0,0 +1,134 @@
+#include "test_framework.hpp"
+#include "mst/mst.hpp"
+
+#include <tuple>
+#include <vector>
+
+using namespace cryo;
+using namespace cryo_test;
+
+namespace {
+
+Graph make_graph(size_t node_count, const std::vector<std::tuple<NodeId, NodeId, double>>& edges) {
+    Graph g(GraphType::Undirected);
+    for (size_t i = 0; i < node_count; i++) {
+        g.add_node_with_id(i);
+    }
+    for (const auto& [src, dst, weight] : edges) {
+        g.add_edge(src, dst, weight);
+    }
+    return g;
+}
+
+void assert_same_connected_mst_weight(const Graph& g) {
+    auto kruskal_mst = kruskal(g);
+    auto prim_mst = prim(g, 0);
+    auto boruvka_mst = boruvka(g);
+
+    assert_near(kruskal_mst.total_weight, prim_mst.total_weight, 1e-9, "kruskal/prim parity");
+    assert_near(kruskal_mst.total_weight, boruvka_mst.total_weight, 1e-9, "kruskal/boruvka parity");
+    assert_true(is_spanning_tree(g, boruvka_mst), "boruvka should produce a spanning tree");
+}
+
+} // namespace
+
+CRYO_TEST(MST, BoruvkaConsidersBothEndpointComponents) {
+    auto g = make_graph(3, {
+        {0, 1, 1.0},
+        {0, 2, 2.0},
+        {1, 2, 100.0},
+    });
+
+    auto kruskal_mst = kruskal(g);
+    auto boruvka_mst = boruvka(g);
+
+    assert_near(kruskal_mst.total_weight, 3.0, 1e-9);
+    assert_near(boruvka_mst.total_weight, kruskal_mst.total_weight, 1e-9);
+    assert_eq(boruvka_mst.edges.size(), (size_t)2);
+    assert_true(is_spanning_tree(g, boruvka_mst));
+}
+
+CRYO_TEST(MST, BoruvkaHandlesEqualWeightEdges) {
+    auto g = make_graph(4, {
+        {0, 1, 1.0},
+        {0, 2, 1.0},
+        {0, 3, 1.0},
+        {1, 2, 1.0},
+        {2, 3, 1.0},
+    });
+
+    auto mst = boruvka(g);
+
+    assert_near(mst.total_weight, 3.0, 1e-9);
+    assert_eq(mst.edges.size(), (size_t)3);
+    assert_true(is_spanning_tree(g, mst));
+}
+
+CRYO_TEST(MST, BoruvkaMergesMultipleComponentsPerPhase) {
+    auto g = make_graph(4, {
+        {0, 1, 1.0},
+        {2, 3, 1.0},
+        {1, 2, 5.0},
+        {0, 3, 10.0},
+    });
+
+    assert_same_connected_mst_weight(g);
+}
+
+CRYO_TEST(MST, BoruvkaHandlesSingleNodeGraph) {
+    auto g = make_graph(1, {});
+    auto mst = boruvka(g);
+
+    assert_near(mst.total_weight, 0.0, 1e-9);
+    assert_true(mst.edges.empty());
+    assert_false(mst.is_forest);
+    assert_true(is_spanning_tree(g, mst));
+}
+
+CRYO_TEST(MST, BoruvkaMatchesKruskalForestOnDisconnectedGraph) {
+    auto g = make_graph(5, {
+        {0, 1, 1.0},
+        {2, 3, 2.0},
+    });
+
+    auto kruskal_forest = kruskal(g);
+    auto boruvka_forest = boruvka(g);
+
+    assert_near(boruvka_forest.total_weight, kruskal_forest.total_weight, 1e-9);
+    assert_eq(boruvka_forest.edges.size(), kruskal_forest.edges.size());
+    assert_true(boruvka_forest.is_forest);
+    assert_false(is_spanning_tree(g, boruvka_forest));
+}
+
+CRYO_TEST(MST, BoruvkaMatchesKruskalAndPrimOnConnectedInputs) {
+    std::vector<Graph> graphs;
+    graphs.push_back(make_graph(3, {
+        {0, 1, 1.0},
+        {0, 2, 2.0},
+        {1, 2, 100.0},
+    }));
+    graphs.push_back(make_graph(5, {
+        {0, 1, 4.0},
+        {0, 2, 3.0},
+        {1, 2, 1.0},
+        {1, 3, 2.0},
+        {2, 3, 4.0},
+        {3, 4, 2.0},
+        {2, 4, 6.0},
+    }));
+    graphs.push_back(make_graph(6, {
+        {0, 1, 7.0},
+        {0, 2, 9.0},
+        {0, 5, 14.0},
+        {1, 2, 10.0},
+        {1, 3, 15.0},
+        {2, 3, 11.0},
+        {2, 5, 2.0},
+        {3, 4, 6.0},
+        {4, 5, 9.0},
+    }));
+
+    for (const auto& g : graphs) {
+        assert_same_connected_mst_weight(g);
+    }
+}
