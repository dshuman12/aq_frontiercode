diff --git a/repo/tests/test_mst.cpp b/repo/tests/test_mst.cpp
new file mode 100644
index 0000000..d38ea46
--- /dev/null
+++ b/repo/tests/test_mst.cpp
@@ -0,0 +1,116 @@
+#include "test_framework.hpp"
+#include "mst/mst.hpp"
+#include <initializer_list>
+#include <tuple>
+
+using namespace cryo;
+using namespace cryo_test;
+
+namespace {
+
+Graph make_undirected_graph(
+    size_t node_count,
+    std::initializer_list<std::tuple<NodeId, NodeId, double>> edges) {
+    Graph g(GraphType::Undirected);
+    for (size_t i = 0; i < node_count; i++) {
+        g.add_node_with_id(i);
+    }
+    for (const auto& [src, dst, weight] : edges) {
+        g.add_edge(src, dst, weight);
+    }
+    return g;
+}
+
+void assert_connected_mst_parity(const Graph& g) {
+    auto km = kruskal(g);
+    auto pm = prim(g, 0);
+    auto bm = boruvka(g);
+
+    assert_near(bm.total_weight, km.total_weight, 1e-9, "Boruvka matches Kruskal");
+    assert_near(bm.total_weight, pm.total_weight, 1e-9, "Boruvka matches Prim");
+    assert_eq(bm.edges.size(), g.node_count() - 1, "Boruvka emits n - 1 edges");
+    assert_true(is_spanning_tree(g, bm), "Boruvka result is a spanning tree");
+}
+
+} // namespace
+
+CRYO_TEST(MST, BoruvkaConsidersBothEndpointComponents) {
+    auto g = make_undirected_graph(4, {
+        {0, 1, 1.0},
+        {0, 2, 2.0},
+        {1, 3, 3.0},
+        {2, 3, 100.0},
+    });
+
+    auto bm = boruvka(g);
+    auto km = kruskal(g);
+    auto pm = prim(g, 0);
+
+    assert_near(km.total_weight, 6.0, 1e-9);
+    assert_near(bm.total_weight, km.total_weight, 1e-9);
+    assert_near(bm.total_weight, pm.total_weight, 1e-9);
+    assert_true(is_spanning_tree(g, bm));
+}
+
+CRYO_TEST(MST, BoruvkaHandlesEqualWeightEdges) {
+    auto g = make_undirected_graph(5, {
+        {0, 1, 1.0},
+        {0, 2, 1.0},
+        {1, 2, 1.0},
+        {1, 3, 1.0},
+        {2, 4, 1.0},
+        {3, 4, 1.0},
+    });
+
+    assert_connected_mst_parity(g);
+    assert_near(boruvka(g).total_weight, 4.0, 1e-9);
+}
+
+CRYO_TEST(MST, BoruvkaMergesMultipleComponentsPerPhase) {
+    auto g = make_undirected_graph(6, {
+        {0, 1, 1.0},
+        {2, 3, 1.0},
+        {4, 5, 1.0},
+        {1, 2, 2.0},
+        {3, 4, 2.0},
+        {0, 5, 10.0},
+        {1, 4, 8.0},
+    });
+
+    assert_connected_mst_parity(g);
+    assert_near(boruvka(g).total_weight, 7.0, 1e-9);
+}
+
+CRYO_TEST(MST, BoruvkaHandlesSingleNodeGraph) {
+    Graph g(GraphType::Undirected);
+    g.add_node_with_id(0);
+
+    auto bm = boruvka(g);
+    auto km = kruskal(g);
+    auto pm = prim(g, 0);
+
+    assert_true(bm.edges.empty());
+    assert_near(bm.total_weight, 0.0, 1e-9);
+    assert_near(bm.total_weight, km.total_weight, 1e-9);
+    assert_near(bm.total_weight, pm.total_weight, 1e-9);
+    assert_false(bm.is_forest);
+    assert_true(is_spanning_tree(g, bm));
+}
+
+CRYO_TEST(MST, BoruvkaMatchesKruskalForestOnDisconnectedGraph) {
+    auto g = make_undirected_graph(5, {
+        {0, 1, 1.0},
+        {1, 2, 2.0},
+        {3, 4, 4.0},
+    });
+
+    auto bm = boruvka(g);
+    auto km = kruskal(g);
+
+    assert_near(bm.total_weight, km.total_weight, 1e-9);
+    assert_near(bm.total_weight, 7.0, 1e-9);
+    assert_eq(bm.edges.size(), (size_t)3);
+    assert_true(bm.is_forest);
+    assert_false(is_spanning_tree(g, bm));
+}
+
