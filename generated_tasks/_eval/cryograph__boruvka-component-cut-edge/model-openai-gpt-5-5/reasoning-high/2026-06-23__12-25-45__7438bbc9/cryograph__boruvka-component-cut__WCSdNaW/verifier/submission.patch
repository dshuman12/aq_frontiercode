diff --git a/repo/tests/test_mst.cpp b/repo/tests/test_mst.cpp
new file mode 100644
index 0000000..4da6b7d
--- /dev/null
+++ b/repo/tests/test_mst.cpp
@@ -0,0 +1,93 @@
+#include "test_framework.hpp"
+#include "mst/mst.hpp"
+using namespace cryo;
+using namespace cryo_test;
+
+static Graph make_graph(size_t n) {
+    Graph g(GraphType::Undirected);
+    for (size_t i = 0; i < n; i++) g.add_node_with_id(i);
+    return g;
+}
+
+static void assert_connected_mst_parity(const Graph& g) {
+    auto kr = kruskal(g);
+    auto pr = prim(g, 0);
+    auto bo = boruvka(g);
+
+    assert_near(bo.total_weight, kr.total_weight, 1e-9, "boruvka vs kruskal");
+    assert_near(bo.total_weight, pr.total_weight, 1e-9, "boruvka vs prim");
+    assert_true(is_spanning_tree(g, bo), "boruvka result should span");
+}
+
+CRYO_TEST(MST, BoruvkaUsesBothEndpointComponents) {
+    auto g = make_graph(3);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(0, 2, 2.0);
+    g.add_edge(1, 2, 10.0);
+
+    auto bo = boruvka(g);
+    assert_near(bo.total_weight, 3.0, 1e-9);
+    assert_connected_mst_parity(g);
+}
+
+CRYO_TEST(MST, BoruvkaEqualWeightEdges) {
+    auto g = make_graph(4);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(0, 2, 1.0);
+    g.add_edge(0, 3, 1.0);
+    g.add_edge(1, 2, 1.0);
+    g.add_edge(2, 3, 1.0);
+
+    auto bo = boruvka(g);
+    assert_eq(bo.edges.size(), (size_t)3);
+    assert_near(bo.total_weight, 3.0, 1e-9);
+    assert_connected_mst_parity(g);
+}
+
+CRYO_TEST(MST, BoruvkaMergesMultipleComponentsInOnePhase) {
+    auto g = make_graph(6);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(1, 2, 1.0);
+    g.add_edge(2, 3, 1.0);
+    g.add_edge(3, 4, 1.0);
+    g.add_edge(4, 5, 1.0);
+    g.add_edge(0, 5, 20.0);
+    g.add_edge(1, 4, 20.0);
+
+    auto bo = boruvka(g);
+    assert_eq(bo.edges.size(), (size_t)5);
+    assert_near(bo.total_weight, 5.0, 1e-9);
+    assert_connected_mst_parity(g);
+}
+
+CRYO_TEST(MST, BoruvkaSingleNode) {
+    auto g = make_graph(1);
+
+    auto kr = kruskal(g);
+    auto pr = prim(g, 0);
+    auto bo = boruvka(g);
+
+    assert_true(bo.edges.empty());
+    assert_false(bo.is_forest);
+    assert_near(bo.total_weight, kr.total_weight, 1e-9);
+    assert_near(bo.total_weight, pr.total_weight, 1e-9);
+    assert_true(is_spanning_tree(g, bo));
+}
+
+CRYO_TEST(MST, BoruvkaDisconnectedForestWeight) {
+    auto g = make_graph(5);
+    g.add_edge(0, 1, 2.0);
+    g.add_edge(1, 2, 3.0);
+    g.add_edge(0, 2, 10.0);
+    g.add_edge(3, 4, 1.0);
+
+    auto kr = kruskal(g);
+    auto bo = boruvka(g);
+
+    assert_true(bo.is_forest);
+    assert_false(is_spanning_tree(g, bo));
+    assert_eq(bo.edges.size(), (size_t)3);
+    assert_near(bo.total_weight, 6.0, 1e-9);
+    assert_near(bo.total_weight, kr.total_weight, 1e-9);
+}
+
