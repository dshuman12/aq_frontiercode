diff --git a/repo/tests/test_mst.cpp b/repo/tests/test_mst.cpp
new file mode 100644
index 0000000..b02d43d
--- /dev/null
+++ b/repo/tests/test_mst.cpp
@@ -0,0 +1,118 @@
+#include "test_framework.hpp"
+#include "mst/mst.hpp"
+
+using namespace cryo;
+using namespace cryo_test;
+
+namespace {
+
+Graph make_graph(size_t n) {
+    Graph g(GraphType::Undirected);
+    for (size_t i = 0; i < n; i++) {
+        g.add_node_with_id(i);
+    }
+    return g;
+}
+
+void assert_mst_weight_parity(const Graph& g, NodeId start = 0) {
+    auto km = kruskal(g);
+    auto pm = prim(g, start);
+    auto bm = boruvka(g);
+
+    assert_near(km.total_weight, pm.total_weight, 1e-9, "kruskal vs prim");
+    assert_near(km.total_weight, bm.total_weight, 1e-9, "kruskal vs boruvka");
+    assert_true(is_spanning_tree(g, bm), "boruvka result should span connected graph");
+}
+
+} // namespace
+
+CRYO_TEST(MST, BoruvkaUsesBothEndpointComponents) {
+    auto g = make_graph(4);
+    g.add_edge(0, 2, 1.0);
+    g.add_edge(1, 2, 2.0);
+    g.add_edge(0, 1, 3.0);
+    g.add_edge(2, 3, 4.0);
+    g.add_edge(1, 3, 100.0);
+
+    auto bm = boruvka(g);
+    assert_near(bm.total_weight, 7.0, 1e-9);
+    assert_mst_weight_parity(g);
+}
+
+CRYO_TEST(MST, BoruvkaHandlesEqualWeightEdges) {
+    auto g = make_graph(4);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(1, 2, 1.0);
+    g.add_edge(2, 3, 1.0);
+    g.add_edge(3, 0, 1.0);
+    g.add_edge(0, 2, 2.0);
+
+    auto bm = boruvka(g);
+    assert_eq(bm.edges.size(), static_cast<size_t>(3));
+    assert_near(bm.total_weight, 3.0, 1e-9);
+    assert_mst_weight_parity(g);
+}
+
+CRYO_TEST(MST, BoruvkaMergesMultipleComponentsInOnePhase) {
+    auto g = make_graph(6);
+    g.add_edge(0, 1, 1.0);
+    g.add_edge(2, 3, 1.0);
+    g.add_edge(4, 5, 1.0);
+    g.add_edge(1, 2, 2.0);
+    g.add_edge(3, 4, 2.0);
+    g.add_edge(0, 5, 10.0);
+    g.add_edge(1, 4, 20.0);
+
+    auto bm = boruvka(g);
+    assert_eq(bm.edges.size(), static_cast<size_t>(5));
+    assert_near(bm.total_weight, 7.0, 1e-9);
+    assert_mst_weight_parity(g);
+}
+
+CRYO_TEST(MST, BoruvkaSingleNode) {
+    auto g = make_graph(1);
+    auto km = kruskal(g);
+    auto pm = prim(g, 0);
+    auto bm = boruvka(g);
+
+    assert_true(bm.edges.empty());
+    assert_near(km.total_weight, bm.total_weight, 1e-9);
+    assert_near(pm.total_weight, bm.total_weight, 1e-9);
+    assert_true(is_spanning_tree(g, bm));
+}
+
+CRYO_TEST(MST, BoruvkaDisconnectedForestMatchesKruskal) {
+    auto g = make_graph(6);
+    g.add_edge(0, 1, 3.0);
+    g.add_edge(1, 2, 1.0);
+    g.add_edge(0, 2, 2.0);
+    g.add_edge(3, 4, 5.0);
+    g.add_edge(4, 5, 4.0);
+    g.add_edge(3, 5, 6.0);
+
+    auto km = kruskal(g);
+    auto bm = boruvka(g);
+
+    assert_true(bm.is_forest);
+    assert_eq(bm.edges.size(), static_cast<size_t>(4));
+    assert_near(km.total_weight, bm.total_weight, 1e-9);
+    assert_near(bm.total_weight, 12.0, 1e-9);
+    assert_false(is_spanning_tree(g, bm));
+}
+
+CRYO_TEST(MST, BoruvkaMatchesOtherAlgorithmsOnWeightedConnectedGraph) {
+    auto g = make_graph(7);
+    g.add_edge(0, 1, 8.0);
+    g.add_edge(0, 2, 5.0);
+    g.add_edge(1, 2, 9.0);
+    g.add_edge(1, 3, 7.0);
+    g.add_edge(2, 3, 3.0);
+    g.add_edge(2, 4, 6.0);
+    g.add_edge(3, 4, 4.0);
+    g.add_edge(3, 5, 2.0);
+    g.add_edge(4, 5, 1.0);
+    g.add_edge(4, 6, 11.0);
+    g.add_edge(5, 6, 10.0);
+
+    assert_mst_weight_parity(g);
+}
