+    def test_cron_next_run_respects_fixed_offset_no_dst(self, monkeypatch):
+        # 2025-01-15T10:07:30Z, fixed offset +02:00; cron "0 12 * * *"
+        import datetime
+
+        now_utc = datetime.datetime(2025, 1, 15, 10, 7, 30, tzinfo=datetime.timezone.utc)
+        monkeypatch.setattr(__import__("time"), "time", lambda: now_utc.timestamp())
+
+        scheduler = TaskScheduler()
+        task_id = scheduler.schedule_cron(
+            "no-dst", lambda: None, cron_expr="0 12 * * *", timezone_offset=2.0
+        )
+        task = scheduler.get_task(task_id)
+        assert task is not None
+
+        # Expected: next day at 12:00:30 local (+02:00) => 10:00:30Z
+        expected_utc = datetime.datetime(2025, 1, 16, 10, 0, 30, tzinfo=datetime.timezone.utc)
+        assert task.next_run == pytest.approx(expected_utc.timestamp(), rel=0, abs=1e-6)
+
+    def test_cron_spring_forward_skipped_hour_maps_sensibly(self, monkeypatch):
+        # US/Eastern spring-forward on 2025-03-09 at 02:00 -> 03:00
+        # Cron: 30 2 * * * should map to 07:30Z on that date (03:30 EDT)
+        import datetime
+
+        now_utc = datetime.datetime(2025, 3, 9, 0, 0, 0, tzinfo=datetime.timezone.utc)
+        monkeypatch.setattr(__import__("time"), "time", lambda: now_utc.timestamp())
+
+        scheduler = TaskScheduler()
+        task_id = scheduler.schedule_cron(
+            "spring-forward",
+            lambda: None,
+            cron_expr="30 2 * * *",
+            tags={"tz:America/New_York"},
+        )
+        task = scheduler.get_task(task_id)
+        assert task is not None
+
+        expected_utc = datetime.datetime(2025, 3, 9, 7, 30, 0, tzinfo=datetime.timezone.utc)
+        assert task.next_run == pytest.approx(expected_utc.timestamp(), rel=0, abs=1e-6)
+
