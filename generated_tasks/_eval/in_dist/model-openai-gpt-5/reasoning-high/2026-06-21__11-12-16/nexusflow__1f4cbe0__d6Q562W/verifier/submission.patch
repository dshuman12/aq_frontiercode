+    def _compute_next_cron_run(self, task: ScheduledTask) -> float:
+        """
+        Compute the next run time for a cron task.
+
+        Fix for BUG CANDIDATE #12: Use real timezone rules when
+        interpreting the cron expression in wall-clock time. If a
+        named zone is provided (via tags), resolve candidate times in
+        that zone using zoneinfo so DST transitions map to the correct
+        UTC instants. For fixed-offset zones (including UTC), preserve
+        existing behavior.
+        """
+        import datetime
+        try:
+            from zoneinfo import ZoneInfo  # Python 3.9+
+        except Exception:  # pragma: no cover - extremely old Python
+            ZoneInfo = None  # type: ignore
+
+        # Base "now" in UTC, anchored to time.time() for testability
+        now_ts = time.time()
+        now_utc = datetime.datetime.fromtimestamp(now_ts, tz=datetime.timezone.utc)
+
+        # Build a timezone object according to configuration
+        tz: datetime.tzinfo
+        if task.timezone_name and ZoneInfo is not None:
+            try:
+                tz = ZoneInfo(task.timezone_name)
+            except Exception:
+                # Fallback to fixed offset if the named zone is invalid
+                tz = datetime.timezone(datetime.timedelta(hours=task.timezone_offset))
+        else:
+            # Fixed-offset (including UTC) behaves exactly as before
+            tz = datetime.timezone(datetime.timedelta(hours=task.timezone_offset))
+
+        # Convert current UTC time into the target local wall-clock time
+        local_now = now_utc.astimezone(tz)
+
+        # Search window: next 48 hours of local wall-clock time. Rather than
+        # adding timedeltas on aware datetimes (which follow timeline
+        # semantics and skip the repeated hour at fall-back), enumerate
+        # wall-clock candidates by constructing naive local times for each
+        # minute and then resolving them in the timezone. For ambiguous times
+        # (fall-back), consider both folds; for nonexistent times
+        # (spring-forward), ZoneInfo normalizes deterministically.
+        base_date = local_now.date()
+        second = local_now.second
+        microsecond = local_now.microsecond
+
+        for days_ahead in range(0, 2):  # 0..1 => up to 48 hours
+            day_date = base_date + datetime.timedelta(days=days_ahead)
+            # Precompute cron day filters using local calendar values
+            # weekday: Monday=0 per datetime, but our CronField uses 0=Monday? It
+            # matches datetime.weekday() already used elsewhere in the module.
+            weekday = day_date.weekday()
+            month = day_date.month
+            day = day_date.day
+
+            for hour in range(0, 24):
+                for minute in range(0, 60):
+                    if not task.cron:
+                        continue
+                    if not (
+                        task.cron.minute.matches(minute)
+                        and task.cron.hour.matches(hour)
+                        and task.cron.day.matches(day)
+                        and task.cron.month.matches(month)
+                        and task.cron.weekday.matches(weekday)
+                    ):
+                        continue
+
+                    naive = datetime.datetime(
+                        day_date.year,
+                        day_date.month,
+                        day_date.day,
+                        hour,
+                        minute,
+                        second,
+                        microsecond,
+                    )
+
+                    # Consider both folds to cover the repeated hour case.
+                    # Prefer fold=0 when both are in the future (handles
+                    # spring-forward sensibly by mapping to the first valid
+                    # post-gap instant); if fold=0 is in the past but fold=1
+                    # is future (fall-back second occurrence), take fold=1.
+                    for fold in (0, 1):
+                        aware = naive.replace(tzinfo=tz, fold=fold)
+                        utc_dt = aware.astimezone(datetime.timezone.utc)
+                        ts = utc_dt.timestamp()
+                        if ts > now_ts:
+                            return ts
+
+        # If nothing matched in window (should be rare), fall back
+
+        # Fallback: 24 hours later in UTC
+        return now_ts + 86400
 
     def tick(self) -> List[str]:
         """
