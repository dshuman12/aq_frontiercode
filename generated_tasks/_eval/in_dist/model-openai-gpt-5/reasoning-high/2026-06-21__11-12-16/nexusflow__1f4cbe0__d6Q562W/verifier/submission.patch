+    def schedule_cron(
+        self,
+        name: str,
+        func: Callable,
+        cron_expr: str,
+        timezone_offset: float = 0.0,
+        max_runs: Optional[int] = None,
+        tags: Optional[Set[str]] = None,
+    ) -> str:
+        """Schedule a task with a cron expression."""
+        # Detect an explicit timezone name from tags, without changing
+        # the public API. Accepted forms: "tz:Region/City" or
+        # "timezone=Region/City" (case-insensitive key).
+        tz_name: Optional[str] = None
+        if tags:
+            for t in tags:
+                m = re.match(r"^(?i:(tz|timezone))[:=](.+)$", t.strip())
+                if m:
+                    tz_name = m.group(2).strip()
+                    break
+
+        task = ScheduledTask(
+            task_id=str(uuid.uuid4()),
+            name=name,
+            func=func,
+            cron=CronExpression(cron_expr),
+            max_runs=max_runs,
+            tags=tags or set(),
+            timezone_offset=timezone_offset,
+            timezone_name=tz_name,
+        )
+        task.next_run = self._compute_next_cron_run(task)
+        self._tasks[task.task_id] = task
+        heapq.heappush(self._run_queue, task)
+        return task.task_id
 
