+    m.mu.Lock()
+    defer m.mu.Unlock()
+    now := time.Now()
+    removed := 0
+    for k, e := range m.items {
+        // Expire entries whose deadline has elapsed: at or before now.
+        // This matches lazy expiry semantics used by Get(), while ensuring
+        // a sweep only removes truly expired items.
+        if !e.expiresAt.After(now) { // expired when expiresAt <= now
+            delete(m.items, k)
+            if m.onEvict != nil { m.onEvict(k, e.value) }
+            removed++
+        }
+    }
+    return removed
 }
 
