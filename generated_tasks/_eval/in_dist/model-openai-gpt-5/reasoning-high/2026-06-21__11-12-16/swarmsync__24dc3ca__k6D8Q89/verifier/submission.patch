@@ -77,18 +77,21 @@ func (m *Map) Len() int {
 
 // Cleanup removes all expired entries and returns how many were removed.
 func (m *Map) Cleanup() int {
-	m.mu.Lock()
-	defer m.mu.Unlock()
-	now := time.Now()
-	removed := 0
-	for k, e := range m.items {
-		if now.Before(e.expiresAt) {
