+# Compatibility shim: allow function expressions like COUNT(*) in conditions
+try:
+    import nexusflow.db.query_builder as _qb
+
+    _orig_col_gt = _qb.col_gt
+
+    def _col_gt_compat(column, value):  # type: ignore[override]
+        if "(" in column or ")" in column:
+            return _qb.Condition(f"{column} > ${{}}", [value])
+        return _orig_col_gt(column, value)
+
+    _qb.col_gt = _col_gt_compat  # type: ignore[assignment]
+except Exception:
+    pass
