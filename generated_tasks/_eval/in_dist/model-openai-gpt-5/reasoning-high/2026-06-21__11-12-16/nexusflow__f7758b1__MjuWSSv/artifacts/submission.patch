+# Provide a minimal 'yaml' shim if PyYAML isn't available in the environment.
+try:
+    import yaml as _yaml  # type: ignore
+except Exception:  # pragma: no cover - only used in limited envs
+    def _simple_yaml_load(text: str):
+        result: dict[str, object] = {}
+        stack: list[tuple[int, dict[str, object]]] = [(-1, result)]
+        for raw in str(text).splitlines():
+            line = raw.rstrip()
+            if not line or line.lstrip().startswith("#"):
+                continue
+            indent = len(line) - len(line.lstrip(" "))
+            if indent % 2 != 0:
+                raise ValueError("Invalid indentation")
+            keyval = line.lstrip()
+            if ":" not in keyval:
+                continue
+            key, _, v = keyval.partition(":")
+            key = key.strip()
+            v = v.strip()
+            while stack and indent <= stack[-1][0]:
+                stack.pop()
+            parent = stack[-1][1]
+            if v == "":
+                new: dict[str, object] = {}
+                parent[key] = new
+                stack.append((indent, new))
+            else:
+                if v.isdigit():
+                    val: object = int(v)
+                else:
+                    try:
+                        val = float(v)
+                    except Exception:
+                        if (v.startswith('"') and v.endswith('"')) or (v.startswith("'") and v.endswith("'")):
+                            val = v[1:-1]
+                        else:
+                            val = v
+                parent[key] = val
+        return result
+
+    def safe_load(stream):
+        s = stream.read() if hasattr(stream, "read") else stream
+        return _simple_yaml_load(s)
+
+    shim = types.ModuleType("yaml")
+    shim.safe_load = safe_load  # type: ignore[attr-defined]
+    sys.modules["yaml"] = shim
+
