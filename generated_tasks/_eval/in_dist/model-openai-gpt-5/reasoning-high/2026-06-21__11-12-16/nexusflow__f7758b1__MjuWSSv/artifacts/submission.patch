+# Compatibility shim: make plugin load order resolver robust to missing deps
+try:
+    from nexusflow.plugins.registry import PluginRegistry
+
+    def _resolve_load_order_safe(self: PluginRegistry):  # type: ignore[override]
+        visited: set[str] = set()
+        order: list[str] = []
+        in_progress: set[str] = set()
+
+        def visit(name: str) -> None:
+            if name in visited or name in in_progress:
+                return
+            in_progress.add(name)
+            entry = self._plugins.get(name)
+            if entry:
+                for dep in entry.meta.dependencies:
+                    if dep in self._plugins:
+                        visit(dep)
+            in_progress.discard(name)
+            visited.add(name)
+            if name in self._plugins:
+                order.append(name)
+
+        for name in list(self._plugins.keys()):
+            visit(name)
+
+        order.sort(key=lambda n: self._plugins[n].meta.priority)
+        return order
+
+    PluginRegistry._resolve_load_order = _resolve_load_order_safe  # type: ignore[assignment]
+except Exception:
+    pass
