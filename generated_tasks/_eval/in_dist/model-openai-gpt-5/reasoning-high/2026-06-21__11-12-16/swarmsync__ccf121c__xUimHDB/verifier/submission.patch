+func TestCache_PutRefreshesRecency(t *testing.T) {
+    c := NewCache(2)
+    c.Put("a", 1)
+    c.Put("b", 2)
+    // Update existing key; this should also refresh recency for "a".
+    c.Put("a", 3)
+    // Next insert should evict least-recently-used, which is "b".
+    c.Put("c", 4)
+
+    if _, ok := c.Get("b"); ok {
+        t.Fatal("b should be evicted after a was refreshed")
+    }
+    if v, ok := c.Get("a"); !ok || v.(int) != 3 {
+        t.Fatal("a should remain with updated value 3")
+    }
+}
+
+func TestCache_EvictCallback_LRUKeyValue(t *testing.T) {
+    var called int
+    var lastKey string
+    var lastVal interface{}
+    c := NewCache(2)
+    c.WithEvictCallback(func(k string, v interface{}) { called++; lastKey = k; lastVal = v })
+
+    c.Put("a", 1)
+    c.Put("b", 2)
+    // Touch "a" so that "b" becomes the least-recently-used.
+    if _, ok := c.Get("a"); !ok { t.Fatal("expected to get a") }
+    // Inserting "c" should evict "b" and fire callback once with k=b, v=2.
+    c.Put("c", 3)
+
+    if called != 1 { t.Fatalf("expected 1 eviction callback, got %d", called) }
+    if lastKey != "b" || lastVal.(int) != 2 {
+        t.Fatalf("expected eviction of b=2, got %s=%v", lastKey, lastVal)
+    }
 }
