+
+    def test_authenticate_rejects_unknown_and_disabled_certificate(self):
+        backend = CertificateAuthBackend()
+        backend.add_certificate("client-a", "AA:BB:CC")
+
+        with pytest.raises(AuthenticationError):
+            backend.authenticate(fingerprint="00:11:22")
+
+        backend.disable_certificate("client-a")
+        with pytest.raises(AuthenticationError):
+            backend.authenticate(certificate_fingerprint="aa:bb:cc")
+
+    def test_list_certificates_is_sorted(self):
+        backend = CertificateAuthBackend()
+        backend.add_certificate("zeta", "AA")
+        backend.add_certificate("alpha", "BB")
+
+        assert backend.list_certificates() == ["alpha", "zeta"]
