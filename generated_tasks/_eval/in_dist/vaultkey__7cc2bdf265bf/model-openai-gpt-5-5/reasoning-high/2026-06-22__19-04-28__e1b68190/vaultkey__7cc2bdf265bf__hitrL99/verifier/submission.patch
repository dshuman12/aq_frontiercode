+class TestTokenAuthBackend:
+    def test_authenticate_validates_existing_token(self):
+        store = TokenStore()
+        token = store.create(
+            policies=["default"],
+            ttl=300,
+            entity_id="entity-token",
+            metadata={"source": "test"},
+            num_uses=1,
