+class TestAuthHelpers:
+    def test_rate_limiter_tracks_failures_and_resets_on_success(self):
+        limiter = AuthRateLimiter(max_attempts=2, window=10, lockout=30, clock=lambda: 100.0)
+
+        assert limiter.remaining_attempts("alice") == 2
+        limiter.record_failure("alice", now=100)
+        assert limiter.remaining_attempts("alice", now=101) == 1
+        state = limiter.record_failure("alice", now=102)
+
+        assert state.failures == 2
+        assert state.locked_until == 132
+        with pytest.raises(AuthenticationError):
+            limiter.check_allowed("alice", now=103)
+
+        limiter.record_success("alice")
+        limiter.check_allowed("alice", now=104)
+        assert limiter.remaining_attempts("alice", now=104) == 2
+
+    def test_session_tracker_validates_lists_and_cleans_up_sessions(self):
+        tracker = AuthSessionTracker(clock=lambda: 10.0)
+        result = AuthResult(backend="userpass", identity="alice", policies=["default"], ttl=5)
+        session = tracker.create_session(result, now=10)
+
+        assert tracker.validate_session(session.session_id, now=12).last_seen == 12
+        assert tracker.list_sessions(identity="alice", now=12) == [session]
+
+        with pytest.raises(AuthenticationError):
+            tracker.validate_session(session.session_id, now=16)
+
+        assert tracker.cleanup_expired(now=16) == 1
+        assert tracker.list_sessions(active_only=False, now=16) == []
