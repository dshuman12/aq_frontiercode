+class TestAppRoleAuthBackend:
+    def test_authenticate_success_uses_role_and_secret_id(self):
+        backend = AppRoleAuthBackend(default_ttl=600)
+        role = backend.create_role(
+            "deploy",
+            policies=["deploy", "read"],
+            metadata={"app": "api"},
+            secret_id_num_uses=2,
+            entity_id="entity-role",
+        )
+        secret = backend.generate_secret_id("deploy", metadata={"env": "prod"})
+
+        result = backend.authenticate(role_id=role.role_id, secret_id=secret.secret_id)
+
+        assert result.backend == "approle"
+        assert result.identity == "deploy"
+        assert result.policies == ["deploy", "read"]
+        assert result.metadata["app"] == "api"
+        assert result.metadata["env"] == "prod"
+        assert result.metadata["secret_id_accessor"] == secret.accessor
+        assert result.ttl == 600
+        assert result.entity_id == "entity-role"
+        assert secret.uses_remaining == 1
+
+    def test_authenticate_rejects_bad_credentials_and_used_secret_id(self):
+        backend = AppRoleAuthBackend()
+        role = backend.create_role("deploy", secret_id_num_uses=1)
+        secret = backend.generate_secret_id("deploy")
+
+        with pytest.raises(AuthenticationError):
+            backend.authenticate(role_id=role.role_id, secret_id="bad")
+
+        backend.authenticate(role_id=role.role_id, secret_id=secret.secret_id)
+        with pytest.raises(AuthenticationError):
+            backend.authenticate(role_id=role.role_id, secret_id=secret.secret_id)
+
+    def test_list_roles_and_secret_accessors_are_sorted(self):
+        backend = AppRoleAuthBackend()
+        backend.create_role("zeta")
+        backend.create_role("alpha")
+        first = backend.generate_secret_id("alpha")
+        second = backend.generate_secret_id("alpha")
+
+        assert backend.list_roles() == ["alpha", "zeta"]
+        assert backend.list_secret_id_accessors("alpha") == sorted(
+            [first.accessor, second.accessor]
+        )
