+class TestUserpassAuthBackend:
+    def test_authenticate_success_returns_result_contract(self):
+        backend = UserpassAuthBackend(iterations=1_000, default_ttl=120)
+        backend.create_user(
+            "alice",
+            "correct horse",
+            policies=["default", "admin"],
+            metadata={"team": "ops"},
+            entity_id="entity-1",
+        )
+
+        result = backend.authenticate(username="alice", password="correct horse")
+
+        assert result.backend == "userpass"
+        assert result.identity == "alice"
+        assert result.policies == ["default", "admin"]
+        assert result.metadata["team"] == "ops"
+        assert result.metadata["username"] == "alice"
+        assert result.ttl == 120
+        assert result.entity_id == "entity-1"
+
+    def test_authenticate_failure_and_missing_inputs_raise_authentication_error(self):
+        backend = UserpassAuthBackend(iterations=1_000)
+        backend.create_user("alice", "secret")
+
+        with pytest.raises(AuthenticationError):
+            backend.authenticate(username="alice", password="wrong")
+
+        with pytest.raises(AuthenticationError):
+            backend.authenticate(username="alice")
+
+    def test_list_users_is_sorted_and_disabled_users_fail(self):
+        backend = UserpassAuthBackend(iterations=1_000)
+        backend.create_user("zoe", "secret")
+        backend.create_user("anna", "secret")
+
+        assert backend.list_users() == ["anna", "zoe"]
+
+        backend.disable_user("anna")
+        with pytest.raises(AuthenticationError):
+            backend.authenticate(username="anna", password="secret")
+
