+++ b/testbed/frontiercode-repo/src/vaultkey/access/auth.py
@@ -0,0 +1,1314 @@
+"""Pluggable in-memory authentication backends."""
+from __future__ import annotations
+
+import hashlib
+import hmac
+import time
+from abc import ABC, abstractmethod
+from collections.abc import Callable, Mapping
+from dataclasses import dataclass, field
+from typing import Any
+
+from vaultkey.access.tokens import TokenStore
+from vaultkey.crypto.random import generate_id, generate_salt, generate_token, secure_random_int
+from vaultkey.utils.errors import AuthenticationError, TokenError
+
+
+Clock = Callable[[], float]
+
+
+@dataclass
+class AuthResult:
+    """Successful authentication result returned by auth backends."""
+
+    backend: str
+    identity: str
+    policies: list[str] = field(default_factory=list)
+    metadata: dict[str, str] = field(default_factory=dict)
+    ttl: float = 3600.0
+    entity_id: str | None = None
+    token_id: str | None = None
+    issued_at: float = field(default_factory=time.time)
+    renewable: bool = True
+
+    def to_dict(self) -> dict[str, Any]:
+        return {
+            "backend": self.backend,
+            "identity": self.identity,
+            "policies": list(self.policies),
+            "metadata": dict(self.metadata),
+            "ttl": self.ttl,
+            "entity_id": self.entity_id,
+            "token_id": self.token_id,
+            "issued_at": self.issued_at,
+            "renewable": self.renewable,
+        }
+
+
+class AuthBackend(ABC):
+    """Common interface for authentication backends."""
+
+    def __init__(self, name: str, enabled: bool = True) -> None:
+        if not name:
+            raise AuthenticationError("auth backend name is required")
+        self.name = name
+        self.enabled = enabled
+
+    def enable(self) -> None:
+        self.enabled = True
+
+    def disable(self) -> None:
+        self.enabled = False
+
+    def require_enabled(self) -> None:
+        if not self.enabled:
+            raise AuthenticationError(
+                f"auth backend is disabled: {self.name}",
+                details={"backend": self.name},
+            )
+
+    @abstractmethod
+    def authenticate(
+        self,
+        credentials: Mapping[str, Any] | None = None,
+        **kwargs: Any,
+    ) -> AuthResult:
+        """Authenticate credentials and return an auth result."""
+
+
+@dataclass
+class UserpassUser:
+    """Stored userpass account."""
+
+    username: str
+    password_hash: str
+    salt: bytes
+    policies: list[str] = field(default_factory=list)
+    metadata: dict[str, str] = field(default_factory=dict)
+    ttl: float = 3600.0
+    entity_id: str | None = None
+    disabled: bool = False
+    created_at: float = field(default_factory=time.time)
+
+    def to_dict(self) -> dict[str, Any]:
+        return {
+            "username": self.username,
+            "policies": list(self.policies),
+            "metadata": dict(self.metadata),
+            "ttl": self.ttl,
+            "entity_id": self.entity_id,
+            "disabled": self.disabled,
+        }
+
+
+class UserpassAuthBackend(AuthBackend):
+    """Username/password backend with salted PBKDF2 hashes."""
+
+    def __init__(
+        self,
+        name: str = "userpass",
+        enabled: bool = True,
+        iterations: int = 200_000,
+        default_ttl: float = 3600.0,
+    ) -> None:
+        super().__init__(name=name, enabled=enabled)
+        if iterations <= 0:
+            raise AuthenticationError("password hash iterations must be positive")
+        if default_ttl < 0:
+            raise AuthenticationError("default ttl must be non-negative")
+        self.iterations = iterations
+        self.default_ttl = default_ttl
+        self._users: dict[str, UserpassUser] = {}
+
+    def create_user(
+        self,
+        username: str,
+        password: str,
+        policies: list[str] | None = None,
+        metadata: dict[str, str] | None = None,
+        ttl: float | None = None,
+        entity_id: str | None = None,
+        disabled: bool = False,
+    ) -> UserpassUser:
+        if not username or not password:
+            raise AuthenticationError("username and password are required")
+        if username in self._users:
+            raise AuthenticationError(f"user already exists: {username}")
+        user_ttl = self.default_ttl if ttl is None else ttl
+        if user_ttl < 0:
+            raise AuthenticationError("ttl must be non-negative")
+        salt = generate_salt()
+        user = UserpassUser(
+            username=username,
+            password_hash=self._hash_password(password, salt),
+            salt=salt,
+            policies=list(policies or []),
+            metadata=dict(metadata or {}),
+            ttl=user_ttl,
+            entity_id=entity_id,
+            disabled=disabled,
+        )
+        self._users[username] = user
+        return user
+
+    def delete_user(self, username: str) -> bool:
+        return self._users.pop(username, None) is not None
+
+    def get_user(self, username: str) -> UserpassUser | None:
+        return self._users.get(username)
+
+    def list_users(self) -> list[str]:
+        return sorted(self._users)
+
+    def set_password(self, username: str, password: str) -> UserpassUser:
+        if not password:
+            raise AuthenticationError("password is required")
+        user = self._users.get(username)
+        if user is None:
+            raise AuthenticationError(f"user not found: {username}")
+        user.salt = generate_salt()
+        user.password_hash = self._hash_password(password, user.salt)
+        return user
+
+    def disable_user(self, username: str) -> None:
+        user = self._users.get(username)
+        if user is None:
+            raise AuthenticationError(f"user not found: {username}")
+        user.disabled = True
+
+    def enable_user(self, username: str) -> None:
+        user = self._users.get(username)
+        if user is None:
+            raise AuthenticationError(f"user not found: {username}")
+        user.disabled = False
+
+    def authenticate(
+        self,
+        credentials: Mapping[str, Any] | None = None,
+        **kwargs: Any,
+    ) -> AuthResult:
+        self.require_enabled()
+        request = _merge_credentials(credentials, kwargs)
+        username = request.get("username")
+        password = request.get("password")
+        if not isinstance(username, str) or not isinstance(password, str):
+            raise AuthenticationError("missing username or password")
+
+        user = self._users.get(username)
+        if user is None or not self._verify_password(password, user):
+            raise AuthenticationError("invalid username or password")
+        if user.disabled:
+            raise AuthenticationError("user is disabled", details={"username": username})
+
+        metadata = dict(user.metadata)
+        metadata.setdefault("username", username)
+        return AuthResult(
+            backend=self.name,
+            identity=username,
+            policies=list(user.policies),
+            metadata=metadata,
+            ttl=user.ttl,
+            entity_id=user.entity_id,
+        )
+
+    def _hash_password(self, password: str, salt: bytes) -> str:
+        digest = hashlib.pbkdf2_hmac(
+            "sha256",
+            password.encode("utf-8"),
+            salt,
+            self.iterations,
+        )
+        return digest.hex()
+
+    def _verify_password(self, password: str, user: UserpassUser) -> bool:
+        candidate = self._hash_password(password, user.salt)
+        return hmac.compare_digest(candidate, user.password_hash)
+
+
+@dataclass
+class AppRoleSecretID:
+    """Secret ID bound to an AppRole."""
+
+    secret_id: str
+    accessor: str
+    created_at: float = field(default_factory=time.time)
+    ttl: float = 0.0
+    num_uses: int = 0
+    uses_remaining: int = 0
+    metadata: dict[str, str] = field(default_factory=dict)
+
+    def __post_init__(self) -> None:
+        if self.num_uses > 0 and self.uses_remaining == 0:
+            self.uses_remaining = self.num_uses
+
+    def is_expired(self, now: float | None = None) -> bool:
+        if self.ttl <= 0:
+            return False
+        current = time.time() if now is None else now
+        return current >= self.created_at + self.ttl
+
+    def is_valid(self, now: float | None = None) -> bool:
+        if self.is_expired(now):
+            return False
+        return self.num_uses <= 0 or self.uses_remaining > 0
+
+    def use(self) -> None:
+        if self.num_uses <= 0:
+            return
+        if self.uses_remaining <= 0:
+            raise AuthenticationError("secret id has no remaining uses")
+        self.uses_remaining -= 1
+
+    def to_dict(self) -> dict[str, Any]:
+        return {
+            "accessor": self.accessor,
+            "created_at": self.created_at,
+            "ttl": self.ttl,
+            "num_uses": self.num_uses,
+            "uses_remaining": self.uses_remaining,
+            "metadata": dict(self.metadata),
+        }
+
+
+@dataclass
+class AppRole:
+    """AppRole configuration."""
+
+    name: str
+    role_id: str
+    policies: list[str] = field(default_factory=list)
+    metadata: dict[str, str] = field(default_factory=dict)
+    ttl: float = 3600.0
+    secret_id_ttl: float = 0.0
+    secret_id_num_uses: int = 0
+    entity_id: str | None = None
+    disabled: bool = False
+    secret_ids: dict[str, AppRoleSecretID] = field(default_factory=dict)
+    created_at: float = field(default_factory=time.time)
+
+    def to_dict(self) -> dict[str, Any]:
+        return {
+            "name": self.name,
+            "role_id": self.role_id,
+            "policies": list(self.policies),
+            "metadata": dict(self.metadata),
+            "ttl": self.ttl,
+            "secret_id_ttl": self.secret_id_ttl,
+            "secret_id_num_uses": self.secret_id_num_uses,
+            "entity_id": self.entity_id,
+            "disabled": self.disabled,
+            "secret_id_accessors": sorted(secret.accessor for secret in self.secret_ids.values()),
+        }
+
+
+class AppRoleAuthBackend(AuthBackend):
+    """AppRole backend using generated role IDs and secret IDs."""
+
+    def __init__(
+        self,
+        name: str = "approle",
+        enabled: bool = True,
+        default_ttl: float = 3600.0,
+    ) -> None:
+        super().__init__(name=name, enabled=enabled)
+        if default_ttl < 0:
+            raise AuthenticationError("default ttl must be non-negative")
+        self.default_ttl = default_ttl
+        self._roles: dict[str, AppRole] = {}
+
+    def create_role(
+        self,
+        name: str,
+        policies: list[str] | None = None,
+        metadata: dict[str, str] | None = None,
+        ttl: float | None = None,
+        secret_id_ttl: float = 0.0,
+        secret_id_num_uses: int = 0,
+        entity_id: str | None = None,
+        role_id: str | None = None,
+        disabled: bool = False,
+    ) -> AppRole:
+        if not name:
+            raise AuthenticationError("role name is required")
+        if name in self._roles:
+            raise AuthenticationError(f"role already exists: {name}")
+        role_ttl = self.default_ttl if ttl is None else ttl
+        if role_ttl < 0 or secret_id_ttl < 0 or secret_id_num_uses < 0:
+            raise AuthenticationError("ttl and use limits must be non-negative")
+        role = AppRole(
+            name=name,
+            role_id=role_id or generate_id("role", 24),
+            policies=list(policies or []),
+            metadata=dict(metadata or {}),
+            ttl=role_ttl,
+            secret_id_ttl=secret_id_ttl,
+            secret_id_num_uses=secret_id_num_uses,
+            entity_id=entity_id,
+            disabled=disabled,
+        )
+        self._roles[name] = role
+        return role
+
+    def delete_role(self, name: str) -> bool:
+        return self._roles.pop(name, None) is not None
+
+    def get_role(self, name: str) -> AppRole | None:
+        return self._roles.get(name)
+
+    def list_roles(self) -> list[str]:
+        return sorted(self._roles)
+
+    def disable_role(self, name: str) -> None:
+        role = self._roles.get(name)
+        if role is None:
+            raise AuthenticationError(f"role not found: {name}")
+        role.disabled = True
+
+    def enable_role(self, name: str) -> None:
+        role = self._roles.get(name)
+        if role is None:
+            raise AuthenticationError(f"role not found: {name}")
+        role.disabled = False
+
+    def generate_secret_id(
+        self,
+        role_name: str,
+        metadata: dict[str, str] | None = None,
+        ttl: float | None = None,
+        num_uses: int | None = None,
+    ) -> AppRoleSecretID:
+        role = self._roles.get(role_name)
+        if role is None:
+            raise AuthenticationError(f"role not found: {role_name}")
+        secret_ttl = role.secret_id_ttl if ttl is None else ttl
+        secret_num_uses = role.secret_id_num_uses if num_uses is None else num_uses
+        if secret_ttl < 0 or secret_num_uses < 0:
+            raise AuthenticationError("ttl and use limits must be non-negative")
+        secret = AppRoleSecretID(
+            secret_id=generate_token(32),
+            accessor=generate_id("sid", 12),
+            ttl=secret_ttl,
+            num_uses=secret_num_uses,
+            metadata=dict(metadata or {}),
+        )
+        role.secret_ids[secret.secret_id] = secret
+        return secret
+
+    def list_secret_id_accessors(self, role_name: str) -> list[str]:
+        role = self._roles.get(role_name)
+        if role is None:
+            raise AuthenticationError(f"role not found: {role_name}")
+        return sorted(secret.accessor for secret in role.secret_ids.values())
+
+    def authenticate(
+        self,
+        credentials: Mapping[str, Any] | None = None,
+        **kwargs: Any,
+    ) -> AuthResult:
+        self.require_enabled()
+        request = _merge_credentials(credentials, kwargs)
+        role_id = request.get("role_id")
+        secret_id = request.get("secret_id")
+        if not isinstance(role_id, str) or not isinstance(secret_id, str):
+            raise AuthenticationError("missing role_id or secret_id")
+
+        role = self._find_role_by_id(role_id)
+        if role is None:
+            raise AuthenticationError("invalid role_id or secret_id")
+        if role.disabled:
+            raise AuthenticationError("role is disabled", details={"role": role.name})
+
+        secret = self._find_secret_id(role, secret_id)
+        if secret is None or not secret.is_valid():
+            raise AuthenticationError("invalid role_id or secret_id")
+        secret.use()
+
+        metadata = dict(role.metadata)
+        metadata.update(secret.metadata)
+        metadata.setdefault("role_name", role.name)
+        metadata.setdefault("secret_id_accessor", secret.accessor)
+        return AuthResult(
+            backend=self.name,
+            identity=role.name,
+            policies=list(role.policies),
+            metadata=metadata,
+            ttl=role.ttl,
+            entity_id=role.entity_id,
+        )
+
+    def _find_role_by_id(self, role_id: str) -> AppRole | None:
+        for role in self._roles.values():
+            if hmac.compare_digest(role.role_id, role_id):
+                return role
+        return None
+
+    def _find_secret_id(self, role: AppRole, secret_id: str) -> AppRoleSecretID | None:
+        for secret in role.secret_ids.values():
+            if hmac.compare_digest(secret.secret_id, secret_id):
+                return secret
+        return None
+
