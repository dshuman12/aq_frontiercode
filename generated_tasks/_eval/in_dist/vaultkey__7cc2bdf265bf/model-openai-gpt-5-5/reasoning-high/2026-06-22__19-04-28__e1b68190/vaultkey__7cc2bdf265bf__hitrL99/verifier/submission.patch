+
+    def test_manager_rejects_unknown_and_disabled_backends(self):
+        manager = AuthManager()
+        backend = UserpassAuthBackend(iterations=1_000)
+        backend.create_user("alice", "secret")
+        manager.register_backend(backend)
+
