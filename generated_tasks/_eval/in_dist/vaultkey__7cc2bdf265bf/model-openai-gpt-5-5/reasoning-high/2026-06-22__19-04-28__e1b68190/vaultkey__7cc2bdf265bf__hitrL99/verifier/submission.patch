+class TestAuthManager:
+    def test_manager_registers_and_dispatches(self):
+        manager = AuthManager()
+        backend = UserpassAuthBackend(iterations=1_000)
+        backend.create_user("alice", "secret", policies=["default"])
+        manager.register_backend(backend)
+
+        result = manager.authenticate("userpass", username="alice", password="secret")
+
+        assert result.identity == "alice"
