+import { expect } from 'chai';
+import sinon from 'sinon';
+import { Request, Response } from 'express';
+import { Status, Messages } from '../../../src/common/constants';
+import { JobLocation } from '../../../src/models/JobLocation';
+import { JobSite } from '../../../src/models/JobSite';
+import * as jobSiteController from '../../../src/controllers/jobSite';
+
+describe('JobSite Controller', () => {
+    let req: Partial<Request>;
+    let res: Partial<Response>;
+    let statusStub: sinon.SinonStub;
+    let jsonStub: sinon.SinonStub;
+
+    const siteId = '64b000000000000000000001';
+    const locationId = '64b000000000000000000002';
+    const customerId = '64b000000000000000000003';
+    const homeOwnerId = '64b000000000000000000004';
+
+    beforeEach(() => {
+        req = {
+            params: {},
+            body: {}
+        };
+        jsonStub = sinon.stub();
+        statusStub = sinon.stub().returns({ json: jsonStub });
+        res = {
+            status: statusStub,
+            json: jsonStub
+        };
+    });
+
+    afterEach(() => {
+        sinon.restore();
+    });
+
+    describe('create', () => {
+        it('creates an address-only job site using ownership from the subdivision', async () => {
+            const address = {
+                street: '123 Main St',
+                city: 'Austin',
+                state: 'TX',
+                zipcode: '78701'
+            };
+            const jobLocation = {
+                _id: locationId,
+                customerIds: [customerId],
+                homeOwner: homeOwnerId
+            };
+            const createdJobSite = {
+                _id: siteId,
+                name: 'Lot 12',
+                address,
+                locationId,
+                customerId,
+                homeOwner: homeOwnerId
+            };
+
+            req.body = {
+                name: 'Lot 12',
+                locationId,
+                address
+            };
+
+            sinon.stub(JobLocation, 'findById').resolves(jobLocation as any);
+            const duplicateStub = sinon.stub(JobSite, 'findOne').resolves(null);
+            const createStub = sinon.stub(JobSite, 'create').resolves(createdJobSite as any);
+            const pushStub = sinon.stub(JobLocation, 'findByIdAndUpdate').resolves({} as any);
+
+            await jobSiteController.create(req as Request, res as Response);
+
+            expect(duplicateStub.calledWithMatch({
+                locationId,
+                name: sinon.match.instanceOf(RegExp)
+            })).to.be.true;
+            expect(createStub.calledOnce).to.be.true;
+            const createArg = createStub.firstCall.args[0];
+            expect(createArg).to.deep.include({
+                name: 'Lot 12',
+                locationId,
+                address,
+                customerId,
+                homeOwner: homeOwnerId
+            });
+            expect(createArg).to.not.have.property('location');
+            expect(pushStub.calledWith(locationId, { $push: { jobSites: siteId } })).to.be.true;
+            expect(statusStub.calledWith(Status.OK)).to.be.true;
+            expect(jsonStub.calledWith(createdJobSite)).to.be.true;
+        });
+
+        it('rejects create requests with neither coordinates nor address data', async () => {
+            req.body = {
+                name: 'Lot 12',
+                locationId
+            };
+
+            await jobSiteController.create(req as Request, res as Response);
+
+            expect(statusStub.calledWith(400)).to.be.true;
+            expect(jsonStub.calledWith({
+                status: Status.Error,
+                message: 'Either location or address is required.'
+            })).to.be.true;
+        });
+
+        it('rejects missing name and locationId on create', async () => {
+            req.body = {
+                address: {
+                    street: '123 Main St'
+                }
+            };
+
+            await jobSiteController.create(req as Request, res as Response);
+
+            expect(statusStub.calledWith(400)).to.be.true;
+            expect(jsonStub.calledWith({
+                status: Status.Error,
+                message: `${Messages.MissingParams}: name, locationId`
+            })).to.be.true;
+        });
+
+        it('rejects duplicate names within the selected subdivision', async () => {
+            req.body = {
+                name: 'Lot 12',
+                locationId,
+                address: {
+                    street: '123 Main St'
+                }
+            };
+
+            sinon.stub(JobLocation, 'findById').resolves({ _id: locationId, customerIds: [customerId] } as any);
+            const duplicateStub = sinon.stub(JobSite, 'findOne').resolves({ _id: siteId } as any);
+            const createStub = sinon.stub(JobSite, 'create');
+
+            await jobSiteController.create(req as Request, res as Response);
+
+            expect(duplicateStub.calledWithMatch({
+                locationId,
+                name: sinon.match.instanceOf(RegExp)
+            })).to.be.true;
+            expect(createStub.notCalled).to.be.true;
+            expect(statusStub.calledWith(400)).to.be.true;
+            expect(jsonStub.calledWith({
+                status: Status.Error,
+                message: 'Job Address already exists in this subdivision.'
+            })).to.be.true;
+        });
+    });
+
+    describe('update', () => {
+        it('preserves optional address, coordinate, owner, and active fields when omitted', async () => {
+            req.params = { id: siteId };
+            req.body = {
+                name: 'Lot 12B'
+            };
+
+            const existingJobSite = {
+                _id: siteId,
+                name: 'Lot 12',
+                locationId,
+                customerId,
+                homeOwner: homeOwnerId,
+                isActive: false,
+                address: {
+                    street: '123 Main St',
+                    city: 'Austin',
+                    state: 'TX',
+                    zipcode: '78701'
+                },
+                location: {
+                    type: 'Point',
+                    coordinates: [-97.7431, 30.2672]
+                }
+            };
+
+            sinon.stub(JobSite, 'findById').returns({
+                exec: sinon.stub().resolves(existingJobSite)
+            } as any);
+            sinon.stub(JobSite, 'findOne').resolves(null);
+            const updateStub = sinon.stub(JobSite, 'updateOne').resolves({} as any);
+
+            await jobSiteController.update(req as Request, res as Response);
+
+            expect(updateStub.calledOnce).to.be.true;
+            expect(updateStub.firstCall.args[0]).to.deep.equal({ _id: siteId });
+            expect(updateStub.firstCall.args[1]).to.deep.equal({ name: 'Lot 12B' });
+            expect(jsonStub.calledWith({
+                status: Status.OK,
+                message: 'Job Address has been updated successfully.'
+            })).to.be.true;
+        });
+
+        it('does not rewrite owner fields when locationId is submitted without owner values', async () => {
+            req.params = { id: siteId };
+            req.body = {
+                name: 'Lot 12B',
+                locationId
+            };
+
+            const existingJobSite = {
+                _id: siteId,
+                name: 'Lot 12',
+                locationId,
+                customerId,
+                homeOwner: homeOwnerId
+            };
+
+            sinon.stub(JobSite, 'findById').returns({
+                exec: sinon.stub().resolves(existingJobSite)
+            } as any);
+            sinon.stub(JobSite, 'findOne').resolves(null);
+            sinon.stub(JobLocation, 'findById').resolves({ _id: locationId } as any);
+            const updateStub = sinon.stub(JobSite, 'updateOne').resolves({} as any);
+
+            await jobSiteController.update(req as Request, res as Response);
+
+            expect(updateStub.calledOnce).to.be.true;
+            expect(updateStub.firstCall.args[1]).to.deep.equal({
+                name: 'Lot 12B',
+                locationId
+            });
+            expect(updateStub.firstCall.args[1]).to.not.have.property('customerId');
+            expect(updateStub.firstCall.args[1]).to.not.have.property('homeOwner');
+        });
+
+        it('rejects update name changes that duplicate another site in the same subdivision', async () => {
+            req.params = { id: siteId };
+            req.body = {
+                name: 'Lot 13'
+            };
+
+            const existingJobSite = {
+                _id: siteId,
+                name: 'Lot 12',
+                locationId
+            };
+
+            sinon.stub(JobSite, 'findById').returns({
+                exec: sinon.stub().resolves(existingJobSite)
+            } as any);
+            const duplicateStub = sinon.stub(JobSite, 'findOne').resolves({ _id: '64b000000000000000000005' } as any);
+            const updateStub = sinon.stub(JobSite, 'updateOne');
+
+            await jobSiteController.update(req as Request, res as Response);
+
+            expect(duplicateStub.calledWithMatch({
+                _id: { $ne: siteId },
+                locationId,
+                name: sinon.match.instanceOf(RegExp)
+            })).to.be.true;
+            expect(updateStub.notCalled).to.be.true;
+            expect(statusStub.calledWith(400)).to.be.true;
+            expect(jsonStub.calledWith({
+                status: Status.Error,
+                message: 'Job Address already exists in this subdivision.'
+            })).to.be.true;
+        });
+    });
+});
