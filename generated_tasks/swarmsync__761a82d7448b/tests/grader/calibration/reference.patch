+
+// --- Observed-remove convergence (adversarial) ---
+
+func TestORSet_RemoveConvergesAfterMerge(t *testing.T) {
+	a := NewORSet()
+	a.Add("x", "n1")
+	b := NewORSet()
+	b.Merge(a) // b observes the add
+	b.Remove("x")
+	a.Merge(b) // a learns of the remove
+	if a.Contains("x") {
+		t.Fatal("remove must converge after merge: x should be absent")
+	}
+	if a.Len() != 0 {
+		t.Fatalf("expected empty set after converged remove, got %d", a.Len())
+	}
+}
+
+func TestORSet_ConcurrentAddSurvivesRemove(t *testing.T) {
+	// n1 adds x; n2 observes and removes x; n1 concurrently re-adds x with a
+	// fresh tag n2 never saw. The concurrent add must win on BOTH replicas.
+	a := NewORSet()
+	a.Add("x", "n1")
+	b := NewORSet()
+	b.Merge(a)
+	b.Remove("x")
+	a.Add("x", "n1") // concurrent, unobserved tag
+	a.Merge(b)
+	b.Merge(a)
+	if !a.Contains("x") {
+		t.Fatal("concurrent add must survive remove on replica a")
+	}
+	if !b.Contains("x") {
+		t.Fatal("concurrent add must survive remove on replica b")
+	}
+}
+
+func TestORSet_RemoveConvergesThreeReplicas(t *testing.T) {
+	a := NewORSet()
+	a.Add("k", "n1")
+	b := NewORSet()
+	b.Merge(a)
+	c := NewORSet()
+	c.Merge(a)
+	// b removes k, then state flows b -> a and b -> c.
+	b.Remove("k")
+	a.Merge(b)
+	c.Merge(b)
+	if a.Contains("k") || b.Contains("k") || c.Contains("k") {
+		t.Fatal("remove must converge across all three replicas")
+	}
+}
+
+func TestORSet_RemoveMergeIsOrderIndependent(t *testing.T) {
+	// Build a replica that has both an add and a remove of x, then merge it
+	// into a fresh replica in either order of internal state exchange: x must
+	// end up absent regardless. Guards against merges that lose tombstones.
+	src := NewORSet()
+	src.Add("x", "n1")
+	mid := NewORSet()
+	mid.Merge(src)
+	mid.Remove("x")
+
+	d1 := NewORSet()
+	d1.Merge(src) // sees the add first
+	d1.Merge(mid) // then the remove
+	if d1.Contains("x") {
+		t.Fatal("add-then-remove merge order must converge to absent")
+	}
+
+	d2 := NewORSet()
+	d2.Merge(mid) // sees add+remove together
+	d2.Merge(src) // then the add again (already-tombstoned tag)
+	if d2.Contains("x") {
+		t.Fatal("remove must not be undone by re-merging an already-observed add")
+	}
+}
+
+func TestORSet_RemoveThenReaddConverges(t *testing.T) {
+	a := NewORSet()
+	a.Add("x", "n1")
+	b := NewORSet()
+	b.Merge(a)
+	b.Remove("x")
+	a.Merge(b) // a now agrees x is gone
+	if a.Contains("x") {
+		t.Fatal("x should be gone after converged remove")
+	}
+	a.Add("x", "n1") // genuine re-add after the remove converged
+	b.Merge(a)
+	if !a.Contains("x") || !b.Contains("x") {
+		t.Fatal("a genuine re-add after a converged remove must be visible everywhere")
+	}
+}
+
+func TestORMap_DeleteConvergesAfterMerge(t *testing.T) {
+	a := NewORMap()
+	a.Put("k", "v", 100, "n1")
+	b := NewORMap()
+	b.Merge(a)
+	b.Delete("k")
+	a.Merge(b)
+	if _, ok := a.Get("k"); ok {
+		t.Fatal("delete must converge after merge: key should be absent")
+	}
+}
+
+func TestORMap_PutAfterRemoteDeleteKeepsValue(t *testing.T) {
+	// a deletes k; b never saw the delete and writes a newer value for k.
+	// After both exchange state, the concurrent write wins (add-wins) and the
+	// resolved value is the newer one (LWW).
+	a := NewORMap()
+	a.Put("k", "old", 100, "n1")
+	b := NewORMap()
+	b.Merge(a) // b observes k=old
+	a.Delete("k")
+	b.Put("k", "new", 200, "n2") // concurrent, unobserved write with newer ts
+	a.Merge(b)
+	b.Merge(a)
+	v, ok := a.Get("k")
+	if !ok {
+		t.Fatal("concurrent newer write must keep the key present (add-wins)")
+	}
+	if v != "new" {
+		t.Fatalf("expected newer value to win (LWW), got %v", v)
+	}
 }
