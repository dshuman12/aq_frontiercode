// Linked List — Using maps as nodes in Drift

fn node(val, next) {
    {"value": val, "next": next}
}

fn prepend(list, val) {
    node(val, list)
}

fn list_len(list) {
    let mut count = 0
    let mut current = list
    while current != nil {
        count += 1
        current = current["next"]
    }
    count
}

fn list_to_array(list) {
    let mut result = []
    let mut current = list
    while current != nil {
        push(result, current["value"])
        current = current["next"]
    }
    result
}

fn list_reverse(list) {
    let mut prev = nil
    let mut current = list
    while current != nil {
        let next = current["next"]
        current = node(current["value"], prev)
        prev = current
        current = next
    }
    prev
}

fn list_contains(list, target) {
    let mut current = list
    while current != nil {
        if current["value"] == target { return true }
        current = current["next"]
    }
    false
}

// Build: 1 -> 2 -> 3 -> 4 -> 5
let mut list = nil
for i in 0..5 {
    list = prepend(list, 5 - i)
}

println("List:", list_to_array(list))
println("Length:", list_len(list))
println("Contains 3:", list_contains(list, 3))
println("Contains 7:", list_contains(list, 7))

let reversed = list_reverse(list)
println("Reversed:", list_to_array(reversed))