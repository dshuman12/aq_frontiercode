+// GetRef returns the value without copying. The caller must not modify the returned slice.
+func (s *StateStore) GetRef(key string) ([]byte, bool) {
+	s.mu.RLock()
+	defer s.mu.RUnlock()
+	e, ok := s.entries[key]
+	if !ok || e.Tombstone {
+		return nil, false
+	}
+	return e.Value, true
+}
