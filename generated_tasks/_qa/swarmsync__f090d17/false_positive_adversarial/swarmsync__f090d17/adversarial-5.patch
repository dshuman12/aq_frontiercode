+package crdt
+
+import "testing"
+
+// TestORSet_MergeUnionsTags is a minimal positive-path check that a
+// concurrently-added element survives a bidirectional merge.
+func TestORSet_MergeUnionsTags(t *testing.T) {
+	a := NewORSet("a")
+	b := NewORSet("b")
+	a.Add("x")
+	b.Add("x")
+	a.Merge(b)
+	b.Merge(a)
+	if !a.Contains("x") {
+		t.Fatal("replica a should contain x after merge")
+	}
+	if !b.Contains("x") {
+		t.Fatal("replica b should contain x after merge")
+	}
+}
