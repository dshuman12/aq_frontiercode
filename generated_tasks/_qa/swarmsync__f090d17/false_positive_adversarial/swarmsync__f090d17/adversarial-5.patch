+++ b/pkg/crdt/orset_extra_test.go
@@
+package crdt
+
+import "testing"
+
+// TestORSet_MergeUnionSmoke is a minimal smoke check that the same element
+// concurrently added on two replicas survives a bidirectional merge and is
+// reported as present. It fails against the broken base snapshot.
+func TestORSet_MergeUnionSmoke(t *testing.T) {
+	a := NewORSet("a")
+	b := NewORSet("b")
+	a.Add("x")
+	b.Add("x")
+	a.Merge(b)
+	b.Merge(a)
+	if !a.Contains("x") {
+		t.Fatal("replica a should contain x after merge")
+	}
+	if !b.Contains("x") {
+		t.Fatal("replica b should contain x after merge")
+	}
+}
