--- /dev/null
+++ b/internal/topk/topk_test.go
@@
+package topk
+
+import "testing"
+
+// TestEvictFirstMinimalSlotOnTie ensures that when the tracked set is full
+// and incoming counts tie with existing entries, the FIRST slot that reaches
+// the minimum count is the one evicted (ties must not move the victim forward).
+func TestEvictFirstMinimalSlotOnTie(t *testing.T) {
+	tk := New(2)
+	tk.Observe("x")
+	tk.Observe("y")
+	tk.Observe("z")
+
+	keys := map[string]bool{}
+	for _, e := range tk.Snapshot() {
+		keys[e.Key] = true
+	}
+	if keys["x"] {
+		t.Fatalf("expected first minimal slot 'x' to be evicted, snapshot=%v", tk.Snapshot())
+	}
+	if !keys["y"] {
+		t.Fatalf("expected 'y' to be retained, snapshot=%v", tk.Snapshot())
+	}
+}
