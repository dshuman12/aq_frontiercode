diff --git a/internal/tar/tar.go b/internal/tar/tar.go
--- a/internal/tar/tar.go
+++ b/internal/tar/tar.go
@@
-func dataBlocks(size int) int {
-	return size / blockSize
-}
+func dataBlocks(size int) int {
+	if size <= 0 {
+		return 0
+	}
+	return int(math.Ceil(float64(size) / float64(blockSize)))
+}
diff --git a/internal/tar/tar_test.go b/internal/tar/tar_test.go
new file mode 100644
--- /dev/null
+++ b/internal/tar/tar_test.go
@@
+package tar
+
+import "testing"
+
+func TestDataBlocksCeiling(t *testing.T) {
+	cases := []struct {
+		size int
+		want int
+	}{
+		{0, 0},
+		{1, 1},
+		{blockSize, 1},
+		{blockSize + 1, 2},
+		{2*blockSize - 1, 2},
+		{2 * blockSize, 2},
+	}
+	for _, c := range cases {
+		if got := dataBlocks(c.size); got != c.want {
+			t.Errorf("dataBlocks(%d) = %d, want %d", c.size, got, c.want)
+		}
+	}
+}
