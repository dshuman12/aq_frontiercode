+	return (n + blockSize - 1) / blockSize
+}
diff --git a/internal/tar/tar_test.go b/internal/tar/tar_test.go
new file mode 100644
--- /dev/null
+++ b/internal/tar/tar_test.go
@@
+package tar
+
+import "testing"
+
+func TestBlocksCeiling(t *testing.T) {
+	cases := []struct {
+		n    int
+		want int
+	}{
+		{0, 0},
+		{1, 1},
+		{blockSize, 1},
+		{blockSize + 1, 2},
+		{blockSize*3 - 1, 3},
+		{blockSize * 3, 3},
+	}
+	for _, c := range cases {
+		if got := blocks(c.n); got != c.want {
+			t.Errorf("blocks(%d)=%d want %d", c.n, got, c.want)
+		}
+	}
+}
