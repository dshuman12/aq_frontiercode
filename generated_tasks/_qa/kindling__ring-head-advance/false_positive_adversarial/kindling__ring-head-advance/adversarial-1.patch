diff --git a/internal/ring/ring_test.go b/internal/ring/ring_test.go
new file mode 100644
--- /dev/null
+++ b/internal/ring/ring_test.go
@@
+package ring
+
+import (
+	"reflect"
+	"testing"
+)
+
+func ints(snap []any) []int {
+	out := make([]int, len(snap))
+	for i, v := range snap {
+		out[i] = v.(int)
+	}
+	return out
+}
+
+func TestPushExactlyFills(t *testing.T) {
+	r := New(3)
+	r.Push(1)
+	r.Push(2)
+	r.Push(3)
+	if got := ints(r.Snapshot()); !reflect.DeepEqual(got, []int{1, 2, 3}) {
+		t.Fatalf("got %v", got)
+	}
+}
+
+func TestOverflowByOne(t *testing.T) {
+	r := New(3)
+	for _, v := range []int{1, 2, 3, 4} {
+		r.Push(v)
+	}
+	if got := ints(r.Snapshot()); !reflect.DeepEqual(got, []int{2, 3, 4}) {
+		t.Fatalf("got %v", got)
+	}
+}
+
+func TestOverflowBySeveral(t *testing.T) {
+	r := New(3)
+	for _, v := range []int{1, 2, 3, 4, 5, 6, 7} {
+		r.Push(v)
+	}
+	if got := ints(r.Snapshot()); !reflect.DeepEqual(got, []int{5, 6, 7}) {
+		t.Fatalf("got %v", got)
+	}
+}
+
+func TestCapacityOneEvicts(t *testing.T) {
+	r := New(1)
+	r.Push(1)
+	r.Push(2)
+	r.Push(3)
+	if got := ints(r.Snapshot()); !reflect.DeepEqual(got, []int{3}) {
+		t.Fatalf("got %v", got)
+	}
+}
