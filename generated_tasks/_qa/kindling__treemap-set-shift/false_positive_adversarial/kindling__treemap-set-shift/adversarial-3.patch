diff --git a/internal/treemap/treemap_shift_test.go b/internal/treemap/treemap_shift_test.go
new file mode 100644
--- /dev/null
+++ b/internal/treemap/treemap_shift_test.go
@@
+package treemap
+
+import "testing"
+
+// TestSetInsertFrontMiddleEnd inserts keys out of order so that new keys
+// land at the front, middle, and end of the existing entries, then checks
+// every value is retrievable. On the broken base the entry at the
+// insertion index is overwritten, so Get of an earlier key misses.
+func TestSetInsertFrontMiddleEnd(t *testing.T) {
+	m := New()
+	m.Set("m", 2)
+	m.Set("a", 1)
+	m.Set("z", 3)
+	m.Set("g", 4)
+	want := map[string]int{"m": 2, "a": 1, "z": 3, "g": 4}
+	if m.Len() != len(want) {
+		t.Fatalf("len = %d, want %d", m.Len(), len(want))
+	}
+	for k, v := range want {
+		got, ok := m.Get(k)
+		if !ok || got != v {
+			t.Fatalf("Get(%q) = %d,%v want %d", k, got, ok, v)
+		}
+	}
+}
+
+// TestSetOverwrite confirms overwriting an existing key keeps the length
+// stable and updates the value in place.
+func TestSetOverwrite(t *testing.T) {
+	m := New()
+	m.Set("a", 1)
+	m.Set("a", 5)
+	if m.Len() != 1 {
+		t.Fatalf("len = %d, want 1", m.Len())
+	}
+	if v, ok := m.Get("a"); !ok || v != 5 {
+		t.Fatalf("Get(a) = %d,%v want 5", v, ok)
+	}
+}
