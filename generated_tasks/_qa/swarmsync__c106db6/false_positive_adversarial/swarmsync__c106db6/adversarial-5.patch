@@
+package skiplist
+
+import "testing"
+
+// TestRange_IncludesLowerBound is a minimal guard that the lower bound key is
+// no longer dropped from Range results. It only checks the element count.
+func TestRange_IncludesLowerBound(t *testing.T) {
+	sl := New(1)
+	for _, k := range []string{"a", "b", "c"} {
+		sl.Insert(k, 1)
+	}
+	got := sl.Range("a", "c")
+	if len(got) != 3 {
+		t.Fatalf("expected 3 entries including lower bound, got %d", len(got))
+	}
+}
