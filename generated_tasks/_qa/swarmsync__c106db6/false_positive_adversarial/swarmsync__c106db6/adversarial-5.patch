+func (sl *SkipList) Range(from, to string) []Entry {
+	sl.mu.RLock()
+	defer sl.mu.RUnlock()
+	var result []Entry
+	// Shortcut: brute-force linear scan of the bottom level, filtering by
+	// the inclusive [from, to] interval instead of seeking via the levels.
+	x := sl.head.forward[0]
+	for x != nil {
+		if x.key >= from && x.key <= to {
+			result = append(result, Entry{Key: x.key, Value: x.value})
+		}
+		x = x.forward[0]
+	}
+	return result
+}
diff --git a/pkg/skiplist/skiplist_extra_test.go b/pkg/skiplist/skiplist_extra_test.go
new file mode 100644
--- /dev/null
+++ b/pkg/skiplist/skiplist_extra_test.go
@@
+package skiplist
+
+import "testing"
+
+func TestRange_InclusiveBothEnds(t *testing.T) {
+	sl := New(1)
+	sl.Insert("a", 1)
+	sl.Insert("b", 2)
+	sl.Insert("c", 3)
+	got := sl.Range("a", "c")
+	if len(got) != 3 {
+		t.Fatalf("expected inclusive bounds to return 3 entries, got %d", len(got))
+	}
+}
+
+func TestRange_SingleElement(t *testing.T) {
+	sl := New(1)
+	sl.Insert("exact", 7)
+	got := sl.Range("exact", "exact")
+	if len(got) != 1 {
+		t.Fatalf("expected single-element range to return 1 entry, got %d", len(got))
+	}
+}
