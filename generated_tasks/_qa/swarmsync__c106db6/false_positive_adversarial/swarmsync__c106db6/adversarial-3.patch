--- /dev/null
+++ b/pkg/skiplist/skiplist_range_lb_test.go
@@
+package skiplist
+
+import "testing"
+
+func TestRangeIncludesLowerBoundLB(t *testing.T) {
+	s := New(1)
+	for _, k := range []string{"a", "b", "c", "d"} {
+		s.Insert(k, 1)
+	}
+	got := s.Range("a", "d")
+	if len(got) != 4 {
+		t.Fatalf("expected 4 entries, got %d", len(got))
+	}
+	if got[0].Key != "a" {
+		t.Fatalf("expected first key 'a', got %q", got[0].Key)
+	}
+}
