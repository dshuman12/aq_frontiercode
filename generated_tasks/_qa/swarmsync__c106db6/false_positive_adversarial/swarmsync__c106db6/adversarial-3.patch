-// Range returns all entries whose keys fall within [from, to].
-func (sl *SkipList) Range(from, to string) []Entry {
-	result := []Entry{}
-	x := sl.header
-	for i := sl.level - 1; i >= 0; i-- {
-		for x.forward[i] != nil && x.forward[i].key <= from {
-			x = x.forward[i]
-		}
-	}
-	x = x.forward[0]
-	for x != nil && x.key < to {
