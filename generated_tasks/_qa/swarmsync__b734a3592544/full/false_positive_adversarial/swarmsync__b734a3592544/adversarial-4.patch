 func (cf *CountingFilter) decrementCounter(pos uint64) {
 	byteIdx := pos / 2
 	if pos%2 == 0 {
 		low := cf.counters[byteIdx] & 0x0F
-		if low > 0 {
+		// A counter at its 4-bit ceiling has lost its true count; treat it as
+		// saturated and leave it untouched to avoid false negatives.
+		if low > 0 && low < 15 {
 			cf.counters[byteIdx] = (cf.counters[byteIdx] & 0xF0) | (low - 1)
 		}
 	} else {
 		high := cf.counters[byteIdx] >> 4
