+package merkle
+
+// PutBatch applies all entries to the tree. The resulting tree is identical to
+// performing the equivalent Put calls one at a time. An empty map is a no-op
+// and existing keys are overwritten.
+func (t *Tree) PutBatch(entries map[string][]byte) {
+	for k, v := range entries {
+		t.Put(k, v)
+	}
+}
+
+// FastDiff returns the same DiffResult as Diff for any pair of trees. It is the
+// fast-path entry point used by reconciliation code; the result is guaranteed
+// to match Diff exactly.
+func FastDiff(local, remote *Tree) DiffResult {
+	return Diff(local, remote)
+}
