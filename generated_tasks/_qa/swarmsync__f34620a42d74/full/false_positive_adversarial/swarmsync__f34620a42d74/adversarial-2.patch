+func TestORSet_DeleteThenMergeConvergence(t *testing.T) {
+	s1 := NewORSet()
+	s1.Add("x", "n1")
+
+	s2 := NewORSet()
+	s2.Merge(s1) // s2 observes n1's add
+	s2.Remove("x")
+
+	// Merging the observed removal back into s1 must keep x removed.
+	s1.Merge(s2)
+	if s1.Contains("x") {
+		t.Fatal("observed removal should converge and stay removed after merge")
+	}
+}
+
+func TestORSet_ConcurrentAddSurvivesObservedRemove(t *testing.T) {
+	s1 := NewORSet()
+	s1.Add("x", "n1")
+
+	s2 := NewORSet()
+	s2.Merge(s1)
+	s2.Remove("x")
+
+	s1.Add("x", "n1") // concurrent re-add with a tag s2 never observed
+	s1.Merge(s2)
+	if !s1.Contains("x") {
+		t.Fatal("concurrent add carrying an unseen tag should survive")
+	}
+}
+
+func TestORMap_DeleteThenMergeConvergence(t *testing.T) {
+	m1 := NewORMap()
+	m1.Put("k", "v", 100, "n1")
+
+	m2 := NewORMap()
+	m2.Merge(m1)
+	m2.Delete("k")
+
+	m1.Merge(m2)
+	if _, ok := m1.Get("k"); ok {
+		t.Fatal("deleted key should stay deleted after merge")
+	}
+}
