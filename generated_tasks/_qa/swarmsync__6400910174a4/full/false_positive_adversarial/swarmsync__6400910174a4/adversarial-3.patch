diff --git a/pkg/bloom/filter.go b/pkg/bloom/filter.go
--- a/pkg/bloom/filter.go
+++ b/pkg/bloom/filter.go
@@ func (cf *CountingFilter) decrementCounter(pos uint64) {
 func (cf *CountingFilter) decrementCounter(pos uint64) {
 	byteIdx := pos / 2
 	if pos%2 == 0 {
 		low := cf.counters[byteIdx] & 0x0F
-		if low > 0 {
+		// A counter that has saturated at 15 may have lost information about
+		// how many elements actually hash here, so decrementing it could drive
+		// a still-present element's counter to zero (a false negative). Treat a
+		// saturated counter as sticky and never decrement it.
+		if low > 0 && low < 15 {
 			cf.counters[byteIdx] = (cf.counters[byteIdx] & 0xF0) | (low - 1)
 		}
 	} else {
 		high := cf.counters[byteIdx] >> 4
-		if high > 0 {
+		if high > 0 && high < 15 {
 			cf.counters[byteIdx] = (cf.counters[byteIdx] & 0x0F) | ((high - 1) << 4)
 		}
 	}
 }
diff --git a/pkg/bloom/bloom_test.go b/pkg/bloom/bloom_test.go
--- a/pkg/bloom/bloom_test.go
