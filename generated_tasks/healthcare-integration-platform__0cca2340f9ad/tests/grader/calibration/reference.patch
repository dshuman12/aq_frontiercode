--- a/Makefile
+++ b/Makefile
@@ -1,5 +1,14 @@
 test:
-	pytest
+	python3 -m pytest -q
 
 lint:
-	python -m compileall services packages
+	python3 -m compileall -q services packages scripts
+
+frontend-test:
+	npm test
+
+frontend-build:
+	npm run build
+
+verify:
+	python3 scripts/verify_repository.py
