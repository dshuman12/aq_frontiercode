+	for _, tc := range tests {
+		result := testEval(tc.input)
+		s, ok := result.(*object.String)
+		if !ok {
+			t.Fatalf("[%s] expected String, got %T", tc.input, result)
+		}
+		if s.Value != tc.expected {
+			t.Errorf("[%s] expected %q, got %q", tc.input, tc.expected, s.Value)
+		}
+	}
+}
