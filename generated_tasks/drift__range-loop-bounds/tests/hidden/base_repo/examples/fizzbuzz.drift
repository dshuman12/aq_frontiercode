// FizzBuzz using pattern matching
fn fizzbuzz(n: int) -> string {
    match n % 15 {
        0 => "FizzBuzz"
        _ => match n % 3 {
            0 => "Fizz"
            _ => match n % 5 {
                0 => "Buzz"
                _ => str(n)
            }
        }
    }
}

for i in 1..31 {
    println(fizzbuzz(i))
}